, "lines": ["s010-l1", "s010-l2"], "segs": ["s010-g1", "s010-g2"]}, "s010-s2": {"text": "که این نامه را دست پیش آورم ز دفتر به گفتار خویش آورم", "lines": ["s010-l3", "s010-l4"], "segs": ["s010-g3", "s010-g4"]}, "s010-s3": {"text": "بپرسیدم از هر کسی بی‌شمار بترسیدم از گردش روزگار", "lines": ["s010-l5", "s010-l6"], "segs": ["s010-g5", "s010-g6"]}, "s010-s4": {"text": "مگر خود درنگم نباشد بسی بباید سپردن به دیگر کسی", "lines": ["s010-l7", "s010-l8"], "segs": ["s010-g7", "s010-g8"]}, "s010-s5": {"text": "و دیگر که گنجم وفادار نیست همین رنج را کس خریدار نیست", "lines": ["s010-l9", "s010-l10"], "segs": ["s010-g9", "s010-g10"]}, "s010-s6": {"text": "بر این‌گونه یک چند بگذاشتم سخن را نهفته همی داشتم", "lines": ["s010-l11", "s010-l12"], "segs": ["s010-g11", "s010-g12"]}, "s010-s7": {"text": "سراسر زمانه پر از جنگ بود به جویندگان بر جهان تنگ بود", "lines": ["s010-l13", "s010-l14"], "segs": ["s010-g13", "s010-g14"]}, "s010-s8": {"text": "ز نیکو سخن به چه اندر جهان به نزد سخن‌سنج فرخ مهان", "lines": ["s010-l15", "s010-l16"], "segs": ["s010-g15", "s010-g16"]}, "s010-s9": {"text": "اگر نامدی این سخن از خدای نبی کی بدی نزد ما رهنمای", "lines": ["s010-l17", "s010-l18"], "segs": ["s010-g17", "s010-g18"]}, "s010-s10": {"text": "به شهرم یکی مهربان دوست بود تو گفتی که با من به یک پوست بود", "lines": ["s010-l19", "s010-l20"], "segs": ["s010-g19", "s010-g20"]}, "s010-s11": {"text": "مرا گفت خوب آمد این رای تو به نیکی گراید همی پای تو", "lines": ["s010-l21", "s010-l22"], "segs": ["s010-g21", "s010-g22"]}, "s010-s12": {"text": "نبشته من این نامه پهلوی به پیش تو آرم مگر نغنوی", "lines": ["s010-l23", "s010-l24"], "segs": ["s010-g23", "s010-g24"]}, "s010-s13": {"text": "گشاده‌زبان و جوانیت هست سخن گفتن پهلوانیت هست", "lines": ["s010-l25", "s010-l26"], "segs": ["s010-g25", "s010-g26"]}, "s010-s14": {"text": "شو این نامه خسروان باز گوی بدین جوی نزد مهان آبروی", "lines": ["s010-l27", "s010-l28"], "segs": ["s010-g27", "s010-g28"]}, "s010-s15": {"text": "چو آورد این نامه نزدیک من بر افروخت این جان تاریک من", "lines": ["s010-l29", "s010-l30"], "segs": ["s010-g29", "s010-g30"]}}, "segments": {"s010-g1": {"text": "دل روشن من چو برگشت از اوی", "sid": "s010-s1", "lines": ["s010-l1"]}, "s010-g2": {"text": "سوی تخت شاه جهان کرد روی", "sid": "s010-s1", "lines": ["s010-l2"]}, "s010-g3": {"text": "که این نامه را دست پیش آورم", "sid": "s010-s2", "lines": ["s010-l3"]}, "s010-g4": {"text": "ز دفتر به گفتار خویش آورم", "sid": "s010-s2", "lines": ["s010-l4"]}, "s010-g5": {"text": "بپرسیدم از هر کسی بی‌شمار", "sid": "s010-s3", "lines": ["s010-l5"]}, "s010-g6": {"text": "بترسیدم از گردش روزگار", "sid": "s010-s3", "lines": ["s010-l6"]}, "s010-g7": {"text": "مگر خود درنگم نباشد بسی", "sid": "s010-s4", "lines": ["s010-l7"]}, "s010-g8": {"text": "بباید سپردن به دیگر کسی", "sid": "s010-s4", "lines": ["s010-l8"]}, "s010-g9": {"text": "و دیگر که گنجم وفادار نیست", "sid": "s010-s5", "lines": ["s010-l9"]}, "s010-g10": {"text": "همین رنج را کس خریدار نیست", "sid": "s010-s5", "lines": ["s010-l10"]}, "s010-g11": {"text": "بر این‌گونه یک چند بگذاشتم", "sid": "s010-s6", "lines": ["s010-l11"]}, "s010-g12": {"text": "سخن را نهفته همی داشتم", "sid": "s010-s6", "lines": ["s010-l12"]}, "s010-g13": {"text": "سراسر زمانه پر از جنگ بود", "sid": "s010-s7", "lines": ["s010-l13"]}, "s010-g14": {"text": "به جویندگان بر جهان تنگ بود", "sid": "s010-s7", "lines": ["s010-l14"]}, "s010-g15": {"text": "ز نیکو سخن به چه اندر جهان", "sid": "s010-s8", "lines": ["s010-l15"]}, "s010-g16": {"text": "به نزد سخن‌سنج فرخ مهان", "sid": "s010-s8", "lines": ["s010-l16"]}, "s010-g17": {"text": "اگر نامدی این سخن از خدای", "sid": "s010-s9", "lines": ["s010-l17"]}, "s010-g18": {"text": "نبی کی بدی نزد ما رهنمای", "sid": "s010-s9", "lines": ["s010-l18"]}, "s010-g19": {"text": "به شهرم یکی مهربان دوست بود", "sid": "s010-s10", "lines": ["s010-l19"]}, "s010-g20": {"text": "تو گفتی که با من به یک پوست بود", "sid": "s010-s10", "lines": ["s010-l20"]}, "s010-g21": {"text": "مرا گفت خوب آمد این رای تو", "sid": "s010-s11", "lines