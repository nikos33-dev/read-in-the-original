"s191-s1": {"text": "تخوار سراینده گفت آن زمان که آمد بر کوه کوهی دمان", "lines": ["s191-l1", "s191-l2"], "segs": ["s191-g1", "s191-g2"]}, "s191-s2": {"text": "سپهدار طوسست کامد بجنگ نتابی تو با کار دیده نهنگ", "lines": ["s191-l3", "s191-l4"], "segs": ["s191-g3", "s191-g4"]}, "s191-s3": {"text": "برو تا در دژ ببندیم سخت ببینیم تا چیست فرجام بخت", "lines": ["s191-l5", "s191-l6"], "segs": ["s191-g5", "s191-g6"]}, "s191-s4": {"text": "چو فرزند و داماد او را برزم تبه کردی اکنون میندیش بزم", "lines": ["s191-l7", "s191-l8"], "segs": ["s191-g7", "s191-g8"]}, "s191-s5": {"text": "فرود جوان تیز شد با تخوار که چون رزم پیش آید و کارزار", "lines": ["s191-l9", "s191-l10"], "segs": ["s191-g9", "s191-g10"]}, "s191-s6": {"text": "چه طوس و چه شیر و چه پیل ژیان چه جنگی نهنگ و چه ببر بیان", "lines": ["s191-l11", "s191-l12"], "segs": ["s191-g11", "s191-g12"]}, "s191-s7": {"text": "بجنگ اندرون مرد را دل دهند نه بر آتش تیز بر گل نهند", "lines": ["s191-l13", "s191-l14"], "segs": ["s191-g13", "s191-g14"]}, "s191-s8": {"text": "چنین گفت با شاهزاده تخوار که شاهان سخن را ندارند خوار", "lines": ["s191-l15", "s191-l16"], "segs": ["s191-g15", "s191-g16"]}, "s191-s9": {"text": "تو هم یک سواری اگر ز آهنی همی کوه خارا ز بن برکنی", "lines": ["s191-l17", "s191-l18"], "segs": ["s191-g17", "s191-g18"]}, "s191-s10": {"text": "از ایرانیان نامور سی هزار برزم تو آیند بر کوهسار", "lines": ["s191-l19", "s191-l20"], "segs": ["s191-g19", "s191-g20"]}, "s191-s11": {"text": "نه دژ ماند اینجا نه سنگ و نه خاک سراسر ز جا اندر آرند پاک", "lines": ["s191-l21", "s191-l22"], "segs": ["s191-g21", "s191-g22"]}, "s191-s12": {"text": "وگر طوس را زین گزندی رسد به خسرو ز دردش نژندی رسد", "lines": ["s191-l23", "s191-l24"], "segs": ["s191-g23", "s191-g24"]}, "s191-s13": {"text": "بکین پدرت اندر آید شکست شکستی که هرگز نشایدش بست", "lines": ["s191-l25", "s191-l26"], "segs": ["s191-g25", "s191-g26"]}, "s191-s14": {"text": "بگردان عنان و مینداز تیر بدژ شو مبر رنج بر خیره‌خیر", "lines": ["s191-l27", "s191-l28"], "segs": ["s191-g27", "s191-g28"]}, "s191-s15": {"text": "سخن هرچ از پیش بایست گفت نگفت و همی داشت اندر نهفت", "lines": ["s191-l29", "s191-l30"], "segs": ["s191-g29", "s191-g30"]}, "s191-s16": {"text": "ز بی‌مایه دستور ناکاردان ورا جنگ سود آمد و جان زیان", "lines": ["s191-l31", "s191-l32"], "segs": ["s191-g31", "s191-g32"]}}, "segments": {"s191-g1": {"text": "تخوار سراینده گفت آن زمان", "sid": "s191-s1", "lines": ["s191-l1"]}, "s191-g2": {"text": "که آمد بر کوه کوهی دمان", "sid": "s191-s1", "lines": ["s191-l2"]}, "s191-g3": {"text": "سپهدار طوسست کامد بجنگ", "sid": "s191-s2", "lines": ["s191-l3"]}, "s191-g4": {"text": "نتابی تو با کار دیده نهنگ", "sid": "s191-s2", "lines": ["s191-l4"]}, "s191-g5": {"text": "برو تا در دژ ببندیم سخت", "sid": "s191-s3", "lines": ["s191-l5"]}, "s191-g6": {"text": "ببینیم تا چیست فرجام بخت", "sid": "s191-s3", "lines": ["s191-l6"]}, "s191-g7": {"text": "چو فرزند و داماد او را برزم", "sid": "s191-s4", "lines": ["s191-l7"]}, "s191-g8": {"text": "تبه کردی اکنون میندیش بزم", "sid": "s191-s4", "lines": ["s191-l8"]}, "s191-g9": {"text": "فرود جوان تیز شد با تخوار", "sid": "s191-s5", "lines": ["s191-l9"]}, "s191-g10": {"text": "که چون رزم پیش آید و کارزار", "sid": "s191-s5", "lines": ["s191-l10"]}, "s191-g11": {"text": "چه طوس و چه شیر و چه پیل ژیان", "sid": "s191-s6", "lines": ["s191-l11"]}, "s191-g12": {"text": "چه جنگی نهنگ و چه ببر بیان", "sid": "s191-s6", "lines": ["s191-l12"]}, "s191-g13": {"text": "بجنگ اندرون مرد را دل دهند", "sid": "s191-s7", "lines": ["s191-l13"]}, "s191-g14": {"text": "نه بر آتش تیز بر گل نهند", "sid": "s191-s7", "lines": ["s191-l14"]}, "s191-g15": {"text": "چنین گفت با شاهزاده تخوار", "sid": "s191-s8", "lines": ["s191-l15"]}, "s191-g16": {"text": "که شاهان سخن را ندارند خوار", "sid": "s191-s8", "lines": ["s191-l16"]}, "s191-g17": {"text": "تو هم یک سواری اگر ز آهنی", "sid": "s191-s9", "lines": ["s191-l17"]}, "s191-g18": {"text": "همی کوه خارا ز بن برکنی", "sid": "s191-s9", "lines": ["s191-l18"]}, "s191-g19": {"text": "از ایرانیان نامور 