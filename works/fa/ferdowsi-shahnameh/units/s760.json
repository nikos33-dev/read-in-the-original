  "sentences": {
    "s760-s1": {
      "text": "ز جهرم فرخ‌زاد راخواندند بران تخت شاهیش بنشاندند",
      "lines": [
        "s760-l1",
        "s760-l2"
      ],
      "segs": [
        "s760-g1",
        "s760-g2"
      ]
    },
    "s760-s2": {
      "text": "چو برتخت بنشست و کرد آفرین ز نیکی دهش بر جهان‌آفرین",
      "lines": [
        "s760-l3",
        "s760-l4"
      ],
      "segs": [
        "s760-g3",
        "s760-g4"
      ]
    },
    "s760-s3": {
      "text": "منم گفت فرزند شاهنشهان نخواهم جز از ایمنی در جهان",
      "lines": [
        "s760-l5",
        "s760-l6"
      ],
      "segs": [
        "s760-g5",
        "s760-g6"
      ]
    },
    "s760-s4": {
      "text": "ز گیتی هرآنکس که جوید گزند چو من شاه باشم نگردد بلند",
      "lines": [
        "s760-l7",
        "s760-l8"
      ],
      "segs": [
        "s760-g7",
        "s760-g8"
      ]
    },
    "s760-s5": {
      "text": "هر آنکس که جوید به دل راستی نیارد به کار اندرون کاستی",
      "lines": [
        "s760-l9",
        "s760-l10"
      ],
      "segs": [
        "s760-g9",
        "s760-g10"
      ]
    },
    "s760-s6": {
      "text": "بدارمش چون جان پاک ارجمند نجویم ابر بی‌گزندان گزند",
      "lines": [
        "s760-l11",
        "s760-l12"
      ],
      "segs": [
        "s760-g11",
        "s760-g12"
      ]
    },
    "s760-s7": {
      "text": "چو یک ماه بگذشت بر تخت اوی بخاک اندر آمد سر و بخت اوی",
      "lines": [
        "s760-l13",
        "s760-l14"
      ],
      "segs": [
        "s760-g13",
        "s760-g14"
      ]
    },
    "s760-s8": {
      "text": "همین بودش از روز و آرام بهر یکی بنده در می‌برآمیخت زهر",
      "lines": [
        "s760-l15",
        "s760-l16"
      ],
      "segs": [
        "s760-g15",
        "s760-g16"
      ]
    },
    "s760-s9": {
      "text": "بخورد و یکی هفته زان پس بزیست هرآنکس که بشنید بروی گریست",
      "lines": [
        "s760-l17",
        "s760-l18"
      ],
      "segs": [
        "s760-g17",
        "s760-g18"
      ]
    },
    "s760-s10": {
      "text": "همی پادشاهی به پایان رسید ز هر سو همی دشمن آمد پدید",
      "lines": [
        "s760-l19",
        "s760-l20"
      ],
      "segs": [
        "s760-g19",
        "s760-g20"
      ]
    },
    "s760-s11": {
      "text": "چنین است کردار گردنده دهر نگه کن کزو چند یابی تو بهر",
      "lines": [
        "s760-l21",
        "s760-l22"
      ],
      "segs": [
        "s760-g21",
        "s760-g22"
      ]
    },
    "s760-s12": {
      "text": "بخور هرچ داری به فردا مپای که فردا مگر دیگر آیدش رای",
      "lines": [
        "s760-l23",
        "s760-l24"
      ],
      "segs": [
        "s760-g23",
        "s760-g24"
      ]
    },
    "s760-s13": {
      "text": "ستاند ز تو دیگری را دهد جهان خوانیش بی‌گمان بر جهد",
      "lines": [
        "s760-l25",
        "s760-l26"
      ],
      "segs": [
        "s760-g25",
        "s760-g26"
      ]
    },
    "s760-s14": {
      "text": "بخور هرچ داری فزونی بده تو رنجیده‌ای بهر دشمن منه",
      "lines": [
        "s760-l27",
        "s760-l28"
      ],
      "segs": [
        "s760-g27",
        "s760-g28"
      ]
    },
    "s760-s15": {
      "text": "هرآنگه که روز تو اندر گذشت نهاده همه باد گردد به دشت",
      "lines": [
        "s760-l29",
        "s760-l30"
      ],
      "segs": [
        "s760-g29",
        "s760-g30"
      ]
    }
  },
