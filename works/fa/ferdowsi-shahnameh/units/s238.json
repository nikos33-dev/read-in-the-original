: "ز", "pos": "NOUN", "seg": "s238-g50", "sid": "s238-s25"}, {"s": 2, "e": 4, "surface": "هر", "lemma": "هر", "pos": "NOUN", "seg": "s238-g50", "sid": "s238-s25"}, {"s": 5, "e": 7, "surface": "سو", "lemma": "سو", "pos": "NOUN", "seg": "s238-g50", "sid": "s238-s25"}, {"s": 8, "e": 14, "surface": "بجستند", "lemma": "بجستند", "pos": "NOUN", "seg": "s238-g50", "sid": "s238-s25"}, {"s": 15, "e": 21, "surface": "بی‌راه", "lemma": "بی‌راه", "pos": "NOUN", "seg": "s238-g50", "sid": "s238-s25"}, {"s": 22, "e": 23, "surface": "و", "lemma": "و", "pos": "NOUN", "seg": "s238-g50", "sid": "s238-s25"}, {"s": 24, "e": 27, "surface": "راه", "lemma": "راه", "pos": "NOUN", "seg": "s238-g50", "sid": "s238-s25"}]}, "s238-l51": {"text": "نشانی نیامد ز افراسیاب", "sids": ["s238-s26"], "tokens": [{"s": 0, "e": 5, "surface": "نشانی", "lemma": "نشانی", "pos": "NOUN", "seg": "s238-g51", "sid": "s238-s26"}, {"s": 6, "e": 11, "surface": "نیامد", "lemma": "نیامد", "pos": "NOUN", "seg": "s238-g51", "sid": "s238-s26"}, {"s": 12, "e": 13, "surface": "ز", "lemma": "ز", "pos": "NOUN", "seg": "s238-g51", "sid": "s238-s26"}, {"s": 14, "e": 22, "surface": "افراسیاب", "lemma": "افراسیاب", "pos": "NOUN", "seg": "s238-g51", "sid": "s238-s26"}]}, "s238-l52": {"text": "نه بر کوه و دریا نه بر خشک و آب", "sids": ["s238-s26"], "tokens": [{"s": 0, "e": 2, "surface": "نه", "lemma": "نه", "pos": "NUM", "seg": "s238-g52", "sid": "s238-s26"}, {"s": 3, "e": 5, "surface": "بر", "lemma": "بر", "pos": "NOUN", "seg": "s238-g52", "sid": "s238-s26"}, {"s": 6, "e": 9, "surface": "کوه", "lemma": "کوه", "pos": "NOUN", "seg": "s238-g52", "sid": "s238-s26"}, {"s": 10, "e": 11, "surface": "و", "lemma": "و", "pos": "NOUN", "seg": "s238-g52", "sid": "s238-s26"}, {"s": 12, "e": 16, "surface": "دریا", "lemma": "دریا", "pos": "NOUN", "seg": "s238-g52", "sid": "s238-s26"}, {"s": 17, "e": 19, "surface": "نه", "lemma": "نه", "pos": "NUM", "seg": "s238-g52", "sid": "s238-s26"}, {"s": 20, "e": 22, "surface": "بر", "lemma": "بر", "pos": "NOUN", "seg": "s238-g52", "sid": "s238-s26"}, {"s": 23, "e": 26, "surface": "خشک", "lemma": "خشک", "pos": "NOUN", "seg": "s238-g52", "sid": "s238-s26"}, {"s": 27, "e": 28, "surface": "و", "lemma": "و", "pos": "NOUN", "seg": "s238-g52", "sid": "s238-s26"}, {"s": 29, "e": 31, "surface": "آب", "lemma": "آب", "pos": "NOUN", "seg": "s238-g52", "sid": "s238-s26"}]}}, "sentences": {"s238-s1": {"text": "سپهبد چنان کرد کو راه دید همی دست ازان رزم کوتاه دید", "lines": ["s238-l1", "s238-l2"], "segs": ["s238-g1", "s238-g2"]}, "s238-s2": {"text": "چو رستم بیامد مرا پای نیست جز از رفتن از پیش او رای نیست", "lines": ["s238-l3", "s238-l4"], "segs": ["s238-g3", "s238-g4"]}, "s238-s3": {"text": "بباید شدن تا بدان روی چین گر ایدونک گنجد کسی در زمین", "lines": ["s238-l5", "s238-l6"], "segs": ["s238-g5", "s238-g6"]}, "s238-s4": {"text": "درفشش بماندند و او خود برفت سوی چین و ماچین خرامید تفت", "lines": ["s238-l7", "s238-l8"], "segs": ["s238-g7", "s238-g8"]}, "s238-s5": {"text": "سپاه اندر آمد بپیش سپاه زمین گشت برسان ابر سیاه", "lines": ["s238-l9", "s238-l10"], "segs": ["s238-g9", "s238-g10"]}, "s238-s6": {"text": "تهمتن به آواز گفت آن زمان که نیزه مدارید و تیر و کمان", "lines": ["s238-l11", "s238-l12"], "segs": ["s238-g11", "s238-g12"]}, "s238-s7": {"text": "بکوشید و شمشیر و گرز آورید هنرها ز بالای برز آورید", "lines": ["s238-l13", "s238-l14"], "segs": ["s238-g13", "s238-g14"]}, "s238-s8": {"text": "پلنگ آن زمان پیچد از کین خویش که نخچیر بیند ببالین خویش", "lines": ["s238-l15", "s238-l16"], "segs": ["s238-g15", "s238-g16"]}, "s238-s9": {"text": "سپه سربسر نعره برداشتند همه نیزه بر کوه بگذاشتند", "lines": ["s238-l17", "s238-l18"], "segs": ["s238-g17", "s238-g18"]}, "s238-s10": {"text": "چنان شد در و دشت آوردگاه که از کشته جایی ندیدند راه", "lines": ["s238-l19", "s238-l20"], "segs": ["s238-g19", "s238-g20"]}, "s238-s11": {"text": "برفتند یک بهره زنهار خواه گریزان برفتند بهری براه", "lines": ["s238-l21", "s238-l22"], "segs": ["s238-g21", "s238-g22"]}, "s238-s12": {"text": "شد از بی‌شبانی رمه تال و مال همه دشت تن بود بی‌دست و یال", "lines": ["s238-l23", "s238-l24"], "segs": ["s238-g23", "s238-g24"]}, "s238-s13": {"text": "چنین گفت رستم که کشتن بسست که زهر زمان بهر دیگر کسست", "lines": ["s238-l25", "s238-l26"], "segs": ["s238-g25", "s238-g26"]}, "s238-s14": {"text": "زمانی همی بار زهر آورد زمانی ز تریاک بهر آورد", "lines": ["s238-l27", "s238-l28"], "segs": ["s238-g27", "s238-g28"]}, "s238-s15": {"text": "همه جامه رزم بیرون کنید همه خوبکاری بافزون کنید", "lines": ["s238-l29", "s238-l30"], "segs": ["s238-g29", "s238-g30"]}, "s238-s16": {"text": "چه بندی دل اندر سرای سپنج که دانا نداند یکی را ز پنج", "lines": ["s238-l31", "s238-l32"], "segs": ["s238-g31", "s238-g32"]}, "s238-s17": {"text": "زمانی چو آهرمن آید بجنگ زمانی عروسی پر از بوی و رنگ", "lines": ["s238-l33", "s238-l34"], "segs": ["s238-g33", "s238-g34"]}, "s238-s18": {"text": "بی‌آزاری و جام می‌برگزین که گوید که نفرین به از آفرین", "lines": ["s238-l35", "s238-l36"], "segs": ["s238-g35", "s238-g36"]}, "s238-s19": {"text": "بخور آنچ داری و انده مخور که گیتی سپنج است و ما بر گذر", "lines": ["s238-l37", "s238-l38"], "segs": ["s238-g37", "s238-g38"]}, "s238-s20": {"text": "میازار کس را ز بهر درم مکن تا توانی بکس بر ستم", "lines": ["s238-l39", "s238-l40"], "segs": ["s238-g39", "s238-g40"]}, "s238-s21": {"text": "بجست اندران دشت چیزی که بود ز زرین وز گوهر نابسود", "lines": ["s238-l41", "s238-l42"], "segs": ["s238-g41", "s238-g42"]}, "s238-s22": {"text": "سراسر فرستاد نزدیک شاه غلامان و اسپان و تیغ و کلاه", "lines": ["s238-l43", "s238-l44"], "segs": ["s238-g43", "s238-g44"]}, "s238-s23": {"text": "وزان بهره خویشتن برگرفت همه افسر و مشک و عنبر گرفت", "lines": ["s238-l45", "s238-l46"], "segs": ["s238-g45", "s238-g46"]}, "s238-s24": {"text": "ببخشید دیگر همه بر سپاه ز چیزی که بود اندران رزمگاه", "lines": ["s238-l47", "s238-l48"], "segs": ["s238-g47", "s238-g48"]}, "s238-s25": {"text": "نشان خواست از شاه توران سپاه ز هر سو بجستند بی‌راه و راه", "lines": ["s238-l49", "s238-l50"], "segs": ["s238-g49", "s238-g50"