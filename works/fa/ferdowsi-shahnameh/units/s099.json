g2"]}, "s099-s2": {"text": "خروشیدن کوس با کرنای همان ژنده پیلان و هندی درای", "lines": ["s099-l3", "s099-l4"], "segs": ["s099-g3", "s099-g4"]}, "s099-s3": {"text": "برآمد ز زاولستان رستخیز زمین خفته را بانگ برزد که خیز", "lines": ["s099-l5", "s099-l6"], "segs": ["s099-g5", "s099-g6"]}, "s099-s4": {"text": "به پیش اندرون رستم پهلوان پس پشت او سالخورده گوان", "lines": ["s099-l7", "s099-l8"], "segs": ["s099-g7", "s099-g8"]}, "s099-s5": {"text": "چنان شد ز لشکر در و دشت و راغ که بر سر نیارست پرید زاغ", "lines": ["s099-l9", "s099-l10"], "segs": ["s099-g9", "s099-g10"]}, "s099-s6": {"text": "تبیره زدندی همی شست جای جهان را نه سر بود پیدا نه پای", "lines": ["s099-l11", "s099-l12"], "segs": ["s099-g11", "s099-g12"]}, "s099-s7": {"text": "به هنگام بشکوفه گلستان بیاورد لشکر ز زابلستان", "lines": ["s099-l13", "s099-l14"], "segs": ["s099-g13", "s099-g14"]}, "s099-s8": {"text": "ز زال آگهی یافت افراسیاب برآمد ز آرام و از خورد و خواب", "lines": ["s099-l15", "s099-l16"], "segs": ["s099-g15", "s099-g16"]}, "s099-s9": {"text": "بیاورد لشکر سوی خوار ری بران مرغزاری که بد آب و نی", "lines": ["s099-l17", "s099-l18"], "segs": ["s099-g17", "s099-g18"]}, "s099-s10": {"text": "ز ایران بیامد دمادم سپاه ز راه بیابان سوی رزمگاه", "lines": ["s099-l19", "s099-l20"], "segs": ["s099-g19", "s099-g20"]}, "s099-s11": {"text": "ز لشکر به لشکر دو فرسنگ ماند سپهبد جهاندیدگان را بخواند", "lines": ["s099-l21", "s099-l22"], "segs": ["s099-g21", "s099-g22"]}, "s099-s12": {"text": "بدیشان چنین گفت کای بخردان جهاندیده و کارکرده ردان", "lines": ["s099-l23", "s099-l24"], "segs": ["s099-g23", "s099-g24"]}, "s099-s13": {"text": "هم ایدر من این لشکر آراستم بسی سروری و مهی خواستم", "lines": ["s099-l25", "s099-l26"], "segs": ["s099-g25", "s099-g26"]}, "s099-s14": {"text": "پراگنده شد رای بی تخت شاه همه کار بی‌روی و بی‌سر سپاه", "lines": ["s099-l27", "s099-l28"], "segs": ["s099-g27", "s099-g28"]}, "s099-s15": {"text": "چو بر تخت بنشست فرخنده زو ز گیتی یکی آفرین خاست نو", "lines": ["s099-l29", "s099-l30"], "segs": ["s099-g29", "s099-g30"]}, "s099-s16": {"text": "شهی باید اکنون ز تخم کیان به تخت کیی بر کمر بر میان", "lines": ["s099-l31", "s099-l32"], "segs": ["s099-g31", "s099-g32"]}, "s099-s17": {"text": "شهی کاو باورنگ دارد ز می که بی‌سر نباشد تن آدمی", "lines": ["s099-l33", "s099-l34"], "segs": ["s099-g33", "s099-g34"]}, "s099-s18": {"text": "نشان داد موبد مرا در زمان یکی شاه با فر و بخت جوان", "lines": ["s099-l35", "s099-l36"], "segs": ["s099-g35", "s099-g36"]}, "s099-s19": {"text": "ز تخم فریدون یل کیقباد که با فر و برزست و با رای و داد", "lines": ["s099-l37", "s099-l38"], "segs": ["s099-g37", "s099-g38"]}}, "segments": {"s099-g1": {"text": "بزد مهره در جام بر پشت پیل", "sid": "s099-s1", "lines": ["s099-l1"]}, "s099-g2": {"text": "ازو برشد آواز تا چند میل", "sid": "s099-s1", "lines": ["s099-l2"]}, "s099-g3": {"text": "خروشیدن کوس با کرنای", "sid": "s099-s2", "lines": ["s099-l3"]}, "s099-g4": {"text": "همان ژنده پیلان و هندی درای", "sid": "s099-s2", "lines": ["s099-l4"]}, "s099-g5": {"text": "برآمد ز زاولستان رستخیز", "sid": "s099-s3", "lines": ["s099-l5"]}, "s099-g6": {"text": "زمین خفته را بانگ برزد که خیز", "sid": "s099-s3", "lines": ["s099-l6"]}, "s099-g7": {"text": "به پیش اندرون رستم پهلوان", "sid": "s099-s4", "lines": ["s099-l7"]}, "s099-g8": {"text": "پس پشت او سالخورده گوان", "sid": "s099-s4", "lines": ["s099-l8"]}, "s099-g9": {"text": "چنان شد ز لشکر در و دشت و راغ", "sid": "s099-s5", "lines": ["s099-l9"]}, "s099-g10": {"text": "که بر سر نیارست پرید زاغ", "sid": "s099-s5", "lines": ["s099-l10"]}, "s099-g11": {"text": "تبیره زدندی همی شست جای", "sid": "s099-s6", "lines": ["s099-l11"]}, "s099-g12": {"text": "جهان را نه سر بود پیدا نه پای", "sid": "s099-s6", "lines": ["s099-l12"]}, "s099-g13": {"text": "به هنگام بشکوفه گلستان", "sid": "s099-s7", "lines": ["s099-l13"]}, "s099-g14": {"text": "بیاورد لشکر ز زابلستان", "sid": "s099-s7", "lines": ["s099-l14"]}, "s099-g15": {"text": "ز زال آگهی یافت افراسیاب", "sid": "s099-s8", "lines": ["s099-l15"]}, "s099-g16": {"text": 