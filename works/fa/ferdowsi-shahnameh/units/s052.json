30"]}, "s052-s16": {"text": "چنان چون سر ایرج شهریار به تابوت زر اندر افگند خوار", "lines": ["s052-l31", "s052-l32"], "segs": ["s052-g31", "s052-g32"]}, "s052-s17": {"text": "به نامه درون این سخن کرد یاد هیونی برافگند برسان باد", "lines": ["s052-l33", "s052-l34"], "segs": ["s052-g33", "s052-g34"]}, "s052-s18": {"text": "فرستاده آمد رخی پر ز شرم دو چشم از فریدون پر از آب گرم", "lines": ["s052-l35", "s052-l36"], "segs": ["s052-g35", "s052-g36"]}, "s052-s19": {"text": "که چون برد خواهد سر شاه چین بریده بر شاه ایران‌زمین", "lines": ["s052-l37", "s052-l38"], "segs": ["s052-g37", "s052-g38"]}, "s052-s20": {"text": "که فرزند‌گر سر بپیچید ز دین پدر را بدو مهر افزون ز کین", "lines": ["s052-l39", "s052-l40"], "segs": ["s052-g39", "s052-g40"]}, "s052-s21": {"text": "گنه بس گران بود و پوزش نبرد و دیگر که کین خواه او بود گرد", "lines": ["s052-l41", "s052-l42"], "segs": ["s052-g41", "s052-g42"]}, "s052-s22": {"text": "بیامد فرستاده شوخ روی سر تور بنهاد در پیش اوی", "lines": ["s052-l43", "s052-l44"], "segs": ["s052-g43", "s052-g44"]}, "s052-s23": {"text": "فریدون همی بر منوچهر بر یکی آفرین خواست از دادگر", "lines": ["s052-l45", "s052-l46"], "segs": ["s052-g45", "s052-g46"]}}, "segments": {"s052-g1": {"text": "به شاه آفریدون یکی نامه کرد", "sid": "s052-s1", "lines": ["s052-l1"]}, "s052-g2": {"text": "ز مشک و ز عنبر سر خامه کرد", "sid": "s052-s1", "lines": ["s052-l2"]}, "s052-g3": {"text": "نخست از جهان‌آفرین کرد یاد", "sid": "s052-s2", "lines": ["s052-l3"]}, "s052-g4": {"text": "خداوند خوبی و پاکی و داد", "sid": "s052-s2", "lines": ["s052-l4"]}, "s052-g5": {"text": "سپاس از جهاندار فریادرس", "sid": "s052-s3", "lines": ["s052-l5"]}, "s052-g6": {"text": "نگیرد به سختی جز او دست کس", "sid": "s052-s3", "lines": ["s052-l6"]}, "s052-g7": {"text": "دگر آفرین بر فریدون برز", "sid": "s052-s4", "lines": ["s052-l7"]}, "s052-g8": {"text": "خداوند تاج و خداوند گرز", "sid": "s052-s4", "lines": ["s052-l8"]}, "s052-g9": {"text": "همش داد و هم دین و هم فرهی", "sid": "s052-s5", "lines": ["s052-l9"]}