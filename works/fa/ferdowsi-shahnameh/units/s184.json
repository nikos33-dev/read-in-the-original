{"text": "ز یک‌سو بیابان بی‌آب و نم کلات از دگر سوی و راه چرم", "lines": ["s184-l19", "s184-l20"], "segs": ["s184-g19", "s184-g20"]}, "s184-s11": {"text": "بماندند بر جای پیلان و کوس بدان تا بیاید سپهدار طوس", "lines": ["s184-l21", "s184-l22"], "segs": ["s184-g21", "s184-g22"]}, "s184-s12": {"text": "کدامین پسند آیدش زین دو راه بفرمان رود هم بران ره سپاه", "lines": ["s184-l23", "s184-l24"], "segs": ["s184-g23", "s184-g24"]}, "s184-s13": {"text": "چو آمد بر سرکشان طوس نرم سخن گفت ازان راه بی‌آب و گرم", "lines": ["s184-l25", "s184-l26"], "segs": ["s184-g25", "s184-g26"]}, "s184-s14": {"text": "بگودرز گفت این بیابان خشک اگر گرد عنبر دهد باد مشک", "lines": ["s184-l27", "s184-l28"], "segs": ["s184-g27", "s184-g28"]}, "s184-s15": {"text": "چو رانیم روزی به تندی دراز بآب و بآسایش آید نیاز", "lines": ["s184-l29", "s184-l30"], "segs": ["s184-g29", "s184-g30"]}, "s184-s16": {"text": "همان به که سوی کلات و چرم برانیم و منزل کنیم از می‌م", "lines": ["s184-l31", "s184-l32"], "segs": ["s184-g31", "s184-g32"]}, "s184-s17": {"text": "چپ و راست آباد و آب روان بیابان چه جوییم و رنج روان", "lines": ["s184-l33", "s184-l34"], "segs": ["s184-g33", "s184-g34"]}, "s184-s18": {"text": "مرا بود روزی بدین ره گذر چو گژدهم پیش سپه راهبر", "lines": ["s184-l35", "s184-l36"], "segs": ["s184-g35", "s184-g36"]}, "s184-s19": {"text": "ندیدیم از این راه رنجی دراز مگر بود لختی نشیب و فراز", "lines": ["s184-l37", "s184-l38"], "segs": ["s184-g37", "s184-g38"]}, "s184-s20": {"text": "بدو گفت گودرز پرمایه شاه ترا پیش‌رو کرد پیش سپاه", "lines": ["s184-l39", "s184-l40"], "segs": ["s184-g39", "s184-g40"]}, "s184-s21": {"text": "بران ره که گفت او سپه را بران نباید که آید کسی را زیان", "lines": ["s184-l41", "s184-l42"], "segs": ["s184-g41", "s184-g42"]}, "s184-s22": {"text": "نباید که گردد دل‌آزرده شاه بد آید ز آزار او بر سپاه", "lines": ["s184-l43", "s184-l44"], "segs": ["s184-g43", "s184-g44"]}, "s184-s23": {"text": "بدو گفت طوس‌ای گو نامدار ازین گونه اندیشه در دل مدار", "lines": ["s184-l45", "s184-l46"], "segs": ["s184-g45", "s184-g46"]}, "s184-s24": {"text": "کزین شاه را دل نگردد دژم سزد‌گر نداری روان جفت غم", "lines": ["s184-l47", "s184-l48"], "segs": ["s184-g47", "s184-g48"]}, "s184-s25": {"text": "همان به که لشکر بدین سو بریم بیابان و فرسنگها نشمریم", "lines": ["s184-l49", "s184-l50"], "segs": ["s184-g49", "s184-g50"]}, "s184-s26": {"text": "بدین گفته بودند همداستان برین بر نزد نیز کس داستان", "lines": ["s184-l51", "s184-l52"], "segs": ["s184-g51", "s184-g52"]}, "s184-s27": {"text": "براندند ازان راه پیلان و کوس بفرمان و رای سپهدار طوس", "lines": ["s184-l53", "s184-l54"], "segs": ["s184-g53", "s184-g54"]}}, "segments": {"s184-g1": {"text": "سپهبد بشد تیز و برگشت شاه", "sid": "s184-s1", "lines": ["s184-l1"]}, "s184-g2": {"text": "سوی کاخ با رستم و با سپاه", "sid": "s184-s1", "lines": ["s184-l2"]}, "s184-g3": {"text": "یکی مجلس آراست با پیلتن", "sid": "s184-s2", "lines": ["s184-l3"]}, "s184-g4": {"text": "رد و موبد و خسرو رای زن", "sid": "s184-s2", "lines": ["s184-l4"]}, "s184-g5": {"text": "فراوان سخن گفت ز افراسیاب", "sid": "s184-s3", "lines": ["s184-l5"]}, "s184-g6": {"text": "ز رنج تن خویش وز درد باب", "sid": "s184-s3", "lines": ["s184-l6"]}, "s184-g7": {"text": "ز آزردن مادر پارسا", "sid": "s184-s4", "lines": ["s184-l7"]}, "s184-g8": {"text": "که با ما چه کرد آن بد پرجفا", "sid": "s184-s4", "lines": ["s184-l8"]}, "s184-g9": {"text": "مرا زی شبانان بی‌مایه داد", "sid": "s184-s5", "lines": ["s184-l9"]}, "s184-g10": {"text": "ز من کس ندانست نام و نژاد", "sid": "s184-s5", "lines": ["s184-l10"]}, "s184-g11": {"text": "فرستادم این بار طوس و سپاه", "sid": "s184-s6", "lines": ["s184-l11"]}, "s184-g12": {"text": "ازین پس من و تو گذاریم راه", "sid": "s184-s6", "lines": ["s184-l12"]}, "s184-g13": {"text": "جهان بر بداندیش تنگ آوریم", "sid": "s184-s7", "lines": ["s184-l13"]}, "s184-g14": {"text": "سر دشمنان زیر سنگ آوریم", "sid": "s184-s7", "lines": ["s184-l14"]}, "s184-g15": {"text": "ورا پیلتن گفت کین غم مدار", "sid": "s184-s8", "lines": ["s184-l15"]}, "s184-g16": {"text"