        "s538-g7",
        "s538-g8"
      ]
    },
    "s538-s5": {
      "text": "که اندر جهان داد گنج منست جهان زنده از بخت و رنج منست",
      "lines": [
        "s538-l9",
        "s538-l10"
      ],
      "segs": [
        "s538-g9",
        "s538-g10"
      ]
    },
    "s538-s6": {
      "text": "کس این گنج نتواند از من ستد بد آید به مردم ز کردار بد",
      "lines": [
        "s538-l11",
        "s538-l12"
      ],
      "segs": [
        "s538-g11",
        "s538-g12"
      ]
    },
    "s538-s7": {
      "text": "چو خشنود باشد جهاندار پاک ندارد دریغ از من این تیره خاک",
      "lines": [
        "s538-l13",
        "s538-l14"
      ],
      "segs": [
        "s538-g13",
        "s538-g14"
      ]
    },
    "s538-s8": {
      "text": "جهان سر به سر در پناه منست پسندیدن داد راه منست",
      "lines": [
        "s538-l15",
        "s538-l16"
      ],
      "segs": [
        "s538-g15",
        "s538-g16"
      ]
    },
    "s538-s9": {
      "text": "نباید که از کارداران من ز سرهنگ و جنگی سواران من",
      "lines": [
        "s538-l17",
        "s538-l18"
      ],
      "segs": [
        "s538-g17",
        "s538-g18"
      ]
    },
    "s538-s10": {
      "text": "بخسپد کسی دل پر از آرزوی گر از بنده‌گر مردم نیک‌خوی",
      "lines": [
        "s538-l19",
        "s538-l20"
      ],
      "segs": [
        "s538-g19",
        "s538-g20"
      ]
    },
    "s538-s11": {
      "text": "گشادست بر هرکس این بارگاه ز بدخواه وز مردم نیک‌خواه",
      "lines": [
        "s538-l21",
        "s538-l22"
      ],
      "segs": [
        "s538-g21",
        "s538-g22"
      ]
    },
    "s538-s12": {
      "text": "همه انجمن خواندند آفرین که آباد بادا به دادت زمین",
      "lines": [
        "s538-l23",
        "s538-l24"
      ],
      "segs": [
        "s538-g23",
        "s538-g24"
      ]
    },
    "s538-s13": {
      "text": "فرستاد بر هر سوی لشکری که هرجا که باشد ز دشمن سری",
      "lines": [
        "s538-l25",
        "s538-l26"
      ],
      "segs": [
        "s538-g25",
        "s538-g26"
      ]
    },
    "s538-s14": {
      "text": "سر کینه‌ورشان به راه آورید گر آیین شمشیر و گاه آورید",
      "lines": [
        "s538-l27",
        "s538-l28"
      ],
      "segs": [
        "s538-g27",
        "s538-g28"
      ]
    }
  },
  "segments": {
