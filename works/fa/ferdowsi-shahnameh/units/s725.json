  "sentences": {
    "s725-s1": {
      "text": "چو پیروز شد سوی ایران کشید بر شهریار دلیران کشید",
      "lines": [
        "s725-l1",
        "s725-l2"
      ],
      "segs": [
        "s725-g1",
        "s725-g2"
      ]
    },
    "s725-s2": {
      "text": "به‌روز چهارم به آموی شد ندیدی زنی کو جهانجوی شد",
      "lines": [
        "s725-l3",
        "s725-l4"
      ],
      "segs": [
        "s725-g3",
        "s725-g4"
      ]
    },
    "s725-s3": {
      "text": "به آموی یک چند بنشست و بود به دلش اندرون داوریها فزود",
      "lines": [
        "s725-l5",
        "s725-l6"
      ],
      "segs": [
        "s725-g5",
        "s725-g6"
      ]
    },
    "s725-s4": {
      "text": "یکی نامه سوی برادر بدرد نوشت و ز هر کارش آگاه کرد",
      "lines": [
        "s725-l7",
        "s725-l8"
      ],
      "segs": [
        "s725-g7",
        "s725-g8"
      ]
    },
    "s725-s5": {
      "text": "نخستین سخن گفت بهرام گرد به تیمار و درد برادر بمرد",
      "lines": [
        "s725-l9",
        "s725-l10"
      ],
      "segs": [
        "s725-g9",
        "s725-g10"
      ]
    },
    "s725-s6": {
      "text": "تو را و مرا مزد بسیار باد روان وی از ما بی‌آزار باد",
      "lines": [
        "s725-l11",
        "s725-l12"
      ],
      "segs": [
        "s725-g11",
        "s725-g12"
      ]
    },
    "s725-s7": {
      "text": "دگر گفت با شهریار بلند بگوی آنچ از من شنیدی ز پند",
      "lines": [
        "s725-l13",
        "s725-l14"
      ],
      "segs": [
        "s725-g13",
        "s725-g14"
      ]
    },
    "s725-s8": {
      "text": "پس ما بیامد سپاهی گران همه نامداران جنگاوران",
      "lines": [
        "s725-l15",
        "s725-l16"
      ],
      "segs": [
        "s725-g15",
        "s725-g16"
      ]
    },
    "s725-s9": {
      "text": "برآن گونه برگاشتمشان ز رزم که نه رزم بینند زان پس نه بزم",
      "lines": [
        "s725-l17",
        "s725-l18"
      ],
      "segs": [
        "s725-g17",
        "s725-g18"
      ]
    },
    "s725-s10": {
      "text": "بسی نامور مهتران با منند نبادی که آید بریشان گزند",
      "lines": [
        "s725-l19",
        "s725-l20"
      ],
      "segs": [
        "s725-g19",
        "s725-g20"
      ]
    },
    "s725-s11": {
      "text": "نشستم به آموی تا پاسخم بیارد مگر اختر فرخم",
      "lines": [
        "s725-l21",
        "s725-l22"
      ],
      "segs": [
        "s725-g21",
        "s725-g22"
      ]
    }
  },
