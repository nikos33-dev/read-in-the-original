ce": "منوچهر", "lemma": "منوچهر", "pos": "NOUN", "seg": "s072-g42", "sid": "s072-s21"}, {"s": 14, "e": 21, "surface": "پیروزگر", "lemma": "پیروزگر", "pos": "NOUN", "seg": "s072-g42", "sid": "s072-s21"}]}, "s072-l43": {"text": "برو آفرین کرد شاه جهان", "sids": ["s072-s22"], "tokens": [{"s": 0, "e": 3, "surface": "برو", "lemma": "برو", "pos": "NOUN", "seg": "s072-g43", "sid": "s072-s22"}, {"s": 4, "e": 9, "surface": "آفرین", "lemma": "آفرین", "pos": "NOUN", "seg": "s072-g43", "sid": "s072-s22"}, {"s": 10, "e": 13, "surface": "کرد", "lemma": "کرد#کن", "pos": "NOUN", "seg": "s072-g43", "sid": "s072-s22"}, {"s": 14, "e": 17, "surface": "شاه", "lemma": "شاه", "pos": "NOUN", "seg": "s072-g43", "sid": "s072-s22"}, {"s": 18, "e": 22, "surface": "جهان", "lemma": "جهان", "pos": "NOUN", "seg": "s072-g43", "sid": "s072-s22"}]}, "s072-l44": {"text": "چو برگشت بستودش اندر نهان", "sids": ["s072-s22"], "tokens": [{"s": 0, "e": 2, "surface": "چو", "lemma": "چو", "pos": "NOUN", "seg": "s072-g44", "sid": "s072-s22"}, {"s": 3, "e": 8, "surface": "برگشت", "lemma": "برگشت", "pos": "NOUN", "seg": "s072-g44", "sid": "s072-s22"}, {"s": 9, "e": 15, "surface": "بستودش", "lemma": "بستودش", "pos": "NOUN", "seg": "s072-g44", "sid": "s072-s22"}, {"s": 16, "e": 20, "surface": "اندر", "lemma": "اندر", "pos": "NOUN", "seg": "s072-g44", "sid": "s072-s22"}, {"s": 21, "e": 25, "surface": "نهان", "lemma": "نهان", "pos": "NOUN", "seg": "s072-g44", "sid": "s072-s22"}]}}, "sentences": {"s072-s1": {"text": "پس آگاهی آمد سوی شهریار که آمد ز ره زال سام سوار", "lines": ["s072-l1", "s072-l2"], "segs": ["s072-g1", "s072-g2"]}, "s072-s2": {"text": "پذیره شدندش همه سرکشان که بودند در پادشاهی نشان", "lines": ["s072-l3", "s072-l4"], "segs": ["s072-g3", "s072-g4"]}, "s072-s3": {"text": "چو آمد به نزدیکی بارگاه سبک نزد شاهش گشادند راه", "lines": ["s072-l5", "s072-l6"], "segs": ["s072-g5", "s072-g6"]}, "s072-s4": {"text": "چو نزدیک شاه اندر آمد زمین ببوسید و بر شاه کرد آفرین", "lines": ["s072-l7", "s072-l8"], "segs": ["