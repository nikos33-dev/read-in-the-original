: ["s090-s23"], "tokens": [{"s": 0, "e": 3, "surface": "بشد", "lemma": "بشد", "pos": "NOUN", "seg": "s090-g45", "sid": "s090-s23"}, {"s": 4, "e": 8, "surface": "ویسه", "lemma": "ویسه", "pos": "NOUN", "seg": "s090-g45", "sid": "s090-s23"}, {"s": 9, "e": 11, "surface": "تا", "lemma": "تا", "pos": "NOUN", "seg": "s090-g45", "sid": "s090-s23"}, {"s": 12, "e": 15, "surface": "پیش", "lemma": "پیش", "pos": "NOUN", "seg": "s090-g45", "sid": "s090-s23"}, {"s": 16, "e": 24, "surface": "افراسیاب", "lemma": "افراسیاب", "pos": "NOUN", "seg": "s090-g45", "sid": "s090-s23"}]}, "s090-l46": {"text": "ز درد پسر مژه کرده پرآب", "sids": ["s090-s23"], "tokens": [{"s": 0, "e": 1, "surface": "ز", "lemma": "ز", "pos": "NOUN", "seg": "s090-g46", "sid": "s090-s23"}, {"s": 2, "e": 5, "surface": "درد", "lemma": "درد", "pos": "NOUN", "seg": "s090-g46", "sid": "s090-s23"}, {"s": 6, "e": 9, "surface": "پسر", "lemma": "پسر", "pos": "NOUN", "seg": "s090-g46", "sid": "s090-s23"}, {"s": 10, "e": 13, "surface": "مژه", "lemma": "مژه", "pos": "NOUN", "seg": "s090-g46", "sid": "s090-s23"}, {"s": 14, "e": 18, "surface": "کرده", "lemma": "کرده", "pos": "NOUN", "seg": "s090-g46", "sid": "s090-s23"}, {"s": 19, "e": 23, "surface": "پرآب", "lemma": "پرآب", "pos": "NOUN", "seg": "s090-g46", "sid": "s090-s23"}]}}, "sentences": {"s090-s1": {"text": "بشد ویسه سالار توران سپاه ابا لشکری نامور کینه‌خواه", "lines": ["s090-l1", "s090-l2"], "segs": ["s090-g1", "s090-g2"]}, "s090-s2": {"text": "ازان پیشتر تابه قارن رسید گرامیش را کشته افگنده دید", "lines": ["s090-l3", "s090-l4"], "segs": ["s090-g3", "s090-g4"]}, "s090-s3": {"text": "دلیران و گردان توران سپاه بسی نیز با او فگنده به راه", "lines": ["s090-l5", "s090-l6"], "segs": ["s090-g5", "s090-g6"]}, "s090-s4": {"text": "دریده درفش و نگونسار کوس چو لاله کفن روی چون سندروس", "lines": ["s090-l7", "s090-l8"], "segs": ["s090-g7", "s090-g8"]}, "s090-s5": {"text": "ز ویسه به قارن رسید آگهی که آمد به پیروزی و فرهی", "lines": ["s090-l9", "s090-l10"], "segs": ["s090-g9", "s090-g10"]}, "s090-s6": {"text": "ستوران تازی سوی نیمروز فرستاد و خود رفت گیتی فروز", "lines": ["s090-l11", "s090-l12"], "segs": ["s090-g11", "s090-g12"]}, "s090-s7": {"text": "ز درد پسر ویسه جنگجوی سوی پارس چون باد بنهاد روی", "lines": ["s090-l13", "s090-l14"], "segs": ["s090-g13", "s090-g14"]}, "s090-s8": {"text": "چو از پارس قارن به هامون کشید ز دست چپش لشکر آمد پدید", "lines": ["s090-l15", "s090-l16"], "segs": ["s090-g15", "s090-g16"]}, "s090-s9": {"text": "ز گرد اندر آمد درفش سیاه سپهدار ترکان به پیش سپاه", "lines": ["s090-l17", "s090-l18"], "segs": ["s090-g17", "s090-g18"]}, "s090-s10": {"text": "رده برکشیدند بر هر دو روی برفتند گردان پرخاشجوی", "lines": ["s090-l19", "s090-l20"], "segs": ["s090-g19", "s090-g20"]}, "s090-s11": {"text": "ز قلب سپه ویسه آواز داد که شد تاج و تخت بزرگی به باد", "lines": ["s090-l21", "s090-l22"], "segs": ["s090-g21", "s090-g22"]}, "s090-s12": {"text": "ز قنوج تا مرز کابلستان همان تا در بست و زابلستان", "lines": ["s090-l23", "s090-l24"], "segs": ["s090-g23", "s090-g24"]}, "s090-s13": {"text": "همه سر به سر پاک در چنگ ماست بر ایوانها نقش و نیرنگ ماست", "lines": ["s090-l25", "s090-l26"], "segs": ["s090-g25", "s090-g26"]}, "s090-s14": {"text": "کجا یافت خواهی تو آرامگاه ازان پس کجا شد گرفتار شاه", "lines": ["s090-l27", "s090-l28"], "segs": ["s090-g27", "s090-g28"]}, "s090-s15": {"text": "چنین داد پاسخ که من قارنم گلیم اندر آب روان افگنم", "lines": ["s090-l29", "s090-l30"], "segs": ["s090-g29", "s090-g30"]}, "s090-s16": {"text": "نه از بیم رفتم نه از گفت‌وگوی به پیش پسرت آمدم کینه جوی", "lines": ["s090-l31", "s090-l32"], "segs": ["s090-g31", "s090-g32"]}, "s090-s17": {"text": "چو از کین او دل بپرداختم کنون کین و جنگ ترا ساختم", "lines": ["s090-l33", "s090-l34"], "segs": ["s090-g33", "s090-g34"]}, "s090-s18": {"text": "برآمد چپ و راست گرد سیاه نه روی هوا ماند روشن نه ماه", "lines": ["s090-l35", "s090-l36"], "segs": ["s090-g35", "s090-g36"]}, "s090-s19": {"text": "سپه یک به دیگر برآویختند چو رود روان خون همی ریختند", "lines": ["s090-l37", "s090