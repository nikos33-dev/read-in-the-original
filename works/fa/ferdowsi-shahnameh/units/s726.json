  "sentences": {
    "s726-s1": {
      "text": "ازآن پس به آرام بنشست شاه چو برخاست بهرام جنگی ز راه",
      "lines": [
        "s726-l1",
        "s726-l2"
      ],
      "segs": [
        "s726-g1",
        "s726-g2"
      ]
    },
    "s726-s2": {
      "text": "ندید از بزرگان کسی کینه جوی که با او بروی اندر آورد روی",
      "lines": [
        "s726-l3",
        "s726-l4"
      ],
      "segs": [
        "s726-g3",
        "s726-g4"
      ]
    },
    "s726-s3": {
      "text": "به دستور پاکیزه یک روز گفت که اندیشه تا کی بود در نهفت",
      "lines": [
        "s726-l5",
        "s726-l6"
      ],
      "segs": [
        "s726-g5",
        "s726-g6"
      ]
    },
    "s726-s4": {
      "text": "کشنده پدر هر زمان پیش من همی‌بگذرد چون بود خویش من",
      "lines": [
        "s726-l7",
        "s726-l8"
      ],
      "segs": [
        "s726-g7",
        "s726-g8"
      ]
    },
    "s726-s5": {
      "text": "چوروشن روانم پر از خون بود همی پادشاهی کنم چون بود",
      "lines": [
        "s726-l9",
        "s726-l10"
      ],
      "segs": [
        "s726-g9",
        "s726-g10"
      ]
    },
    "s726-s6": {
      "text": "نهادند خوان و می‌چند خورد هم آن روز بندوی رابند کرد",
      "lines": [
        "s726-l11",
        "s726-l12"
      ],
      "segs": [
        "s726-g11",
        "s726-g12"
      ]
    },
    "s726-s7": {
      "text": "ازان پس چنین گفت با رهنما که او را هم‌اکنون ببردست وپا",
      "lines": [
        "s726-l13",
        "s726-l14"
      ],
      "segs": [
        "s726-g13",
        "s726-g14"
      ]
    },
    "s726-s8": {
      "text": "بریدند هم در زمان او بمرد پر از خون روانش به خسرو سپرد",
      "lines": [
        "s726-l15",
        "s726-l16"
      ],
      "segs": [
        "s726-g15",
        "s726-g16"
      ]
    }
  },
