009-l17", "s009-l18"], "segs": ["s009-g17", "s009-g18"]}, "s009-s10": {"text": "الهی عفو کن گناه ورا بیفزای در حشر جاه ورا", "lines": ["s009-l19", "s009-l20"], "segs": ["s009-g19", "s009-g20"]}}, "segments": {"s009-g1": {"text": "چو از دفتر این داستان‌ها بسی", "sid": "s009-s1", "lines": ["s009-l1"]}, "s009-g2": {"text": "همی‌خواند خواننده بر هر کسی", "sid": "s009-s1", "lines": ["s009-l2"]}, "s009-g3": {"text": "جهان دل نهاده بدین داستان", "sid": "s009-s2", "lines": ["s009-l3"]}, "s009-g4": {"text": "همان بخردان نیز و هم راستان", "sid": "s009-s2", "lines": ["s009-l4"]}, "s009-g5": {"text": "جوانی بیامد گشاده‌زبان", "sid": "s009-s3", "lines": ["s009-l5"]}, "s009-g6": {"text": "سخن گفتن خوب و طبع روان", "sid": "s009-s3", "lines": ["s009-l6"]}, "s009-g7": {"text": "به شعر آرم این نامه را گفت من", "sid": "s009-s4", "lines": ["s009-l7"]}, "s009-g8": {"text": "از او شادمان شد دل انجمن", "sid": "s009-s4", "lines": ["s009-l8"]}, "s009-g9": {"text": "جوانیش را خوی بد یار بود", "sid": "s009-s5", "lines": ["s009-l9"]}, "s009-g10": {"text": "ابا بد همیشه به پیکار بود", "sid": "s009-s5", "lines": ["s009-l10"]}, "s009-g11": {"text": "بر او تاختن کرد ناگاه مرگ", "sid": "s009-s6", "lines": ["s009-l11"]}, "s009-g12": {"text": "نهادش به سر بر یکی تیره ترگ", "sid": "s009-s6", "lines": ["s009-l12"]}, "s009-g13": {"text": "بدان خوی بد جان شیرین بداد", "sid": "s009-s7", "lines": ["s009-l13"]}, "s009-g14": {"text": "نبد از جوانیش یک روز شاد", "sid": "s009-s7", "lines": ["s009-l14"]}, "s009-g15": {"text": "یکایک از او بخت‌برگشته شد", "sid": "s009-s8", "lines": ["s009-l15"]}, "s009-g16": {"text": "به دست یکی بنده بر کشته شد", "sid": "s009-s8", "lines": ["s009-l16"]}, "s009-g17": {"text": "برفت او و این نامه ناگفته ماند", "sid": "s009-s9", "lines": ["s009-l17"]}, "s009-g18": {"text": "چنان بخت بیدار او خفته ماند", "sid": "s009-s9", "lines": ["s009-l18"]}, "s009-g19": {"text": "الهی عفو کن گناه ورا", "sid": "s009-s10", "lines": ["s009-l19"]}, "s009-g20": {"text": "بیفزای در حشر جاه ورا", "sid"