g37", "s442-g38"]}, "s442-s20": {"text": "که‌ای برتر از نام وز جایگاه روان تهمتن بشوی از گناه", "lines": ["s442-l39", "s442-l40"], "segs": ["s442-g39", "s442-g40"]}, "s442-s21": {"text": "بدان گیتیش جای ده در بهشت برش ده ز تخمی که ایدر بکشت", "lines": ["s442-l41", "s442-l42"], "segs": ["s442-g41", "s442-g42"]}}, "segments": {"s442-g1": {"text": "چنین گفت رودابه روزی به زال", "sid": "s442-s1", "lines": ["s442-l1"]}, "s442-g2": {"text": "که از داغ و سوگ تهمتن بنال", "sid": "s442-s1", "lines": ["s442-l2"]}, "s442-g3": {"text": "همانا که تا هست گیتی فروز", "sid": "s442-s2", "lines": ["s442-l3"]}, "s442-g4": {"text": "ازین تیره‌تر کس ندیدست روز", "sid": "s442-s2", "lines": ["s442-l4"]}, "s442-g5": {"text": "بدو گفت زال‌ای زن کم خرد", "sid": "s442-s3", "lines": ["s442-l5"]}, "s442-g6": {"text": "غم ناچریدن بدین بگذرد", "sid": "s442-s3", "lines": ["s442-l6"]}, "s442-g7": {"text": "برآشفت رودابه سوگند خورد", "sid": "s442-s4", "lines": ["s442-l7"]}, "s442-g8": {"text": "که هرگز نیابد تنم خواب و خورد", "sid": "s442-s4", "lines": ["s442-l8"]}, "s442-g9": {"text": "روانم روان گو پیلتن", "sid": "s442-s5", "lines": ["s442-l9"]}, "s442-g10": {"text": "مگر باز بیند بران انجمن", "sid": "s442-s5", "lines": ["s442-l10"]}, "s442-g11": {"text": "ز خوردن یکی هفته تن باز داشت", "sid": "s442-s6", "lines": ["s442-l11"]}, "s442-g12": {"text": "که با جان رستم به دل راز داشت", "sid": "s442-s6", "lines": ["s442-l12"]}, "s442-g13": {"text": "ز ناخوردنش چشم تاریک شد", "sid": "s442-s7", "lines": ["s442-l13"]}, "s442-g14": {"text": "تن نازکش نیز باریک شد", "sid": "s442-s7", "lines": ["s442-l14"]}, "s442-g15": {"text": "ز هر سو که رفتی پرستنده چند", "sid": "s442-s8", "lines": ["s442-l15"]}, "s442-g16": {"text": "همی رفت با او ز بیم گزند", "sid": "s442-s8", "lines": ["s442-l16"]}, "s442-g17": {"text": "سر هفته را زو خرد دور شد", "sid": "s442-s9", "lines": ["s442-l17"]}, "s442-g18": {"text": "ز بیچارگی ماتمش سور شد", "sid": "s442-s9", "lines": ["s442-l18"]}, "s442-g19": {"text": "بیامد به بستان به هنگ