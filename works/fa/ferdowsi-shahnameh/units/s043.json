"lemma": "بلند", "pos": "NOUN", "seg": "s043-g40", "sid": "s043-s20"}, {"s": 12, "e": 15, "surface": "کشد", "lemma": "کشت#کش", "pos": "NOUN", "seg": "s043-g40", "sid": "s043-s20"}, {"s": 16, "e": 19, "surface": "زیر", "lemma": "زیر", "pos": "NOUN", "seg": "s043-g40", "sid": "s043-s20"}, {"s": 20, "e": 23, "surface": "پای", "lemma": "پای", "pos": "NOUN", "seg": "s043-g40", "sid": "s043-s20"}]}, "s043-l41": {"text": "برین گونه از جای برخاستند", "sids": ["s043-s21"], "tokens": [{"s": 0, "e": 2, "surface": "بر", "lemma": "بر", "pos": "NOUN", "seg": "s043-g41", "sid": "s043-s21"}, {"s": 2, "e": 4, "surface": "ین", "lemma": "ین", "pos": "NOUN", "seg": "s043-g41", "sid": "s043-s21"}, {"s": 5, "e": 9, "surface": "گونه", "lemma": "گونه", "pos": "NOUN", "seg": "s043-g41", "sid": "s043-s21"}, {"s": 10, "e": 12, "surface": "از", "lemma": "از", "pos": "NOUN", "seg": "s043-g41", "sid": "s043-s21"}, {"s": 13, "e": 16, "surface": "جای", "lemma": "جای", "pos": "NOUN", "seg": "s043-g41", "sid": "s043-s21"}, {"s": 17, "e": 25, "surface": "برخاستند", "lemma": "برخاستند", "pos": "NOUN", "seg": "s043-g41", "sid": "s043-s21"}]}, "s043-l42": {"text": "همه شب همی چاره آراستند", "sids": ["s043-s21"], "tokens": [{"s": 0, "e": 3, "surface": "همه", "lemma": "همه", "pos": "NOUN", "seg": "s043-g42", "sid": "s043-s21"}, {"s": 4, "e": 6, "surface": "شب", "lemma": "شب", "pos": "NOUN", "seg": "s043-g42", "sid": "s043-s21"}, {"s": 7, "e": 10, "surface": "همی", "lemma": "همی", "pos": "NOUN", "seg": "s043-g42", "sid": "s043-s21"}, {"s": 11, "e": 15, "surface": "چاره", "lemma": "چاره", "pos": "NOUN", "seg": "s043-g42", "sid": "s043-s21"}, {"s": 16, "e": 23, "surface": "آراستند", "lemma": "آراست#آرای", "pos": "NOUN", "seg": "s043-g42", "sid": "s043-s21"}]}}, "sentences": {"s043-s1": {"text": "چو تنگ اندر آمد به نزدیکشان نبود آگه از رای تاریکشان", "lines": ["s043-l1", "s043-l2"], "segs": ["s043-g1", "s043-g2"]}, "s043-s2": {"text": "پذیره شدندش به آیین خویش سپه سربسر باز بردند پیش", "lines": ["s043-l3", "s