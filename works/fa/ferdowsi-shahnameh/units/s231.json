surface": "رخش", "lemma": "رخش", "pos": "NOUN", "seg": "s231-g41", "sid": "s231-s21"}]}, "s231-l42": {"text": "منم گفت شیراوژن تاج‌بخش", "sids": ["s231-s21"], "tokens": [{"s": 0, "e": 3, "surface": "منم", "lemma": "منم", "pos": "NOUN", "seg": "s231-g42", "sid": "s231-s21"}, {"s": 4, "e": 7, "surface": "گفت", "lemma": "گفت#گو", "pos": "NOUN", "seg": "s231-g42", "sid": "s231-s21"}, {"s": 8, "e": 15, "surface": "شیراوژن", "lemma": "شیراوژن", "pos": "NOUN", "seg": "s231-g42", "sid": "s231-s21"}, {"s": 16, "e": 23, "surface": "تاج‌بخش", "lemma": "تاج‌بخش", "pos": "NOUN", "seg": "s231-g42", "sid": "s231-s21"}]}, "s231-l43": {"text": "تنی زورمند و ببازو کمند", "sids": ["s231-s22"], "tokens": [{"s": 0, "e": 3, "surface": "تنی", "lemma": "تنی", "pos": "NOUN", "seg": "s231-g43", "sid": "s231-s22"}, {"s": 4, "e": 10, "surface": "زورمند", "lemma": "زورمند", "pos": "NOUN", "seg": "s231-g43", "sid": "s231-s22"}, {"s": 11, "e": 12, "surface": "و", "lemma": "و", "pos": "NOUN", "seg": "s231-g43", "sid": "s231-s22"}, {"s": 13, "e": 18, "surface": "ببازو", "lemma": "ببازو", "pos": "NOUN", "seg": "s231-g43", "sid": "s231-s22"}, {"s": 19, "e": 23, "surface": "کمند", "lemma": "کمند", "pos": "NOUN", "seg": "s231-g43", "sid": "s231-s22"}]}, "s231-l44": {"text": "چه روز فریبست و هنگام بند", "sids": ["s231-s22"], "tokens": [{"s": 0, "e": 2, "surface": "چه", "lemma": "چه", "pos": "NOUN", "seg": "s231-g44", "sid": "s231-s22"}, {"s": 3, "e": 6, "surface": "روز", "lemma": "روز", "pos": "NOUN", "seg": "s231-g44", "sid": "s231-s22"}, {"s": 7, "e": 13, "surface": "فریبست", "lemma": "فریبست", "pos": "NOUN", "seg": "s231-g44", "sid": "s231-s22"}, {"s": 14, "e": 15, "surface": "و", "lemma": "و", "pos": "NOUN", "seg": "s231-g44", "sid": "s231-s22"}, {"s": 16, "e": 21, "surface": "هنگام", "lemma": "هنگام", "pos": "NOUN", "seg": "s231-g44", "sid": "s231-s22"}, {"s": 22, "e": 25, "surface": "بند", "lemma": "بند", "pos": "NOUN", "seg": "s231-g44", "sid": "s231-s22"}]}, "s231-l45": {"text": "چه خاقان چینی ک