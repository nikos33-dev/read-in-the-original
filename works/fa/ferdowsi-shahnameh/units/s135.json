 "s135-s21"}, {"s": 21, "e": 24, "surface": "سخن", "lemma": "سخن", "pos": "NOUN", "seg": "s135-g42", "sid": "s135-s21"}]}}, "sentences": {"s135-s1": {"text": "تهمتن برانگیخت رخش از شتاب پس پشت جنگ‌آور افراسیاب", "lines": ["s135-l1", "s135-l2"], "segs": ["s135-g1", "s135-g2"]}, "s135-s2": {"text": "چنین گفت با رخش کای نیک یار مکن سستی اندر گه کارزار", "lines": ["s135-l3", "s135-l4"], "segs": ["s135-g3", "s135-g4"]}, "s135-s3": {"text": "که من شاه را بر تو بی‌جان کنم به خون سنگ را رنگ مرجان کنم", "lines": ["s135-l5", "s135-l6"], "segs": ["s135-g5", "s135-g6"]}, "s135-s4": {"text": "چنان گرم شد رخش آتش گهر که گفتی برآمد ز پهلوش پر", "lines": ["s135-l7", "s135-l8"], "segs": ["s135-g7", "s135-g8"]}, "s135-s5": {"text": "ز فتراک بگشاد رستم کمند همی خواست آورد او را ببند", "lines": ["s135-l9", "s135-l10"], "segs": ["s135-g9", "s135-g10"]}, "s135-s6": {"text": "به ترک اندر افتاد خم دوال سپهدار ترکان بدزدید یال", "lines": ["s135-l11", "s135-l12"], "segs": ["s135-g11", "s135-g12"]}, "s135-s7": {"text": "و دیگر که زیر اندرش بادپای به کردار آتش برآمد ز جای", "lines": ["s135-l13", "s135-l14"], "segs": ["s135-g13", "s135-g14"]}, "s135-s8": {"text": "بجست از کمند گو پیلتن دهن خشک وز رنج پر آب تن", "lines": ["s135-l15", "s135-l16"], "segs": ["s135-g15", "s135-g16"]}, "s135-s9": {"text": "ز لشکر هرانکس که بد جنگ‌ساز دو بهره نیامد به خرگاه باز", "lines": ["s135-l17", "s135-l18"], "segs": ["s135-g17", "s135-g18"]}, "s135-s10": {"text": "اگر کشته بودند اگر خسته تن گرفتار در دست آن انجمن", "lines": ["s135-l19", "s135-l20"], "segs": ["s135-g19", "s135-g20"]}, "s135-s11": {"text": "ز پرمایه اسپان زرین ستام ز ترگ و ز شمشیر زرین نیام", "lines": ["s135-l21", "s135-l22"], "segs": ["s135-g21", "s135-g22"]}, "s135-s12": {"text": "جزین هرچه پرمایه‌تر بود نیز به ایرانیان ماند بسیار چیز", "lines": ["s135-l23", "s135-l24"], "segs": ["s135-g23", "s135-g24"]}, "s135-s13": {"text": "میان بازنگشاد کس کشته را نجستند مردان برگشته را", "lines": ["s135-l25", "s135-l26"], "segs": ["s135-g25", "s135-g26"]}, "s135-s14": {"text": "بدان دشت نخچیر باز آمدند ز هر نیکویی بی‌نیاز آمدند", "lines": ["s135-l27", "s135-l28"], "segs": ["s135-g27", "s135-g28"]}, "s135-s15": {"text": "نوشتند نامه به کاووس شاه ز ترکان وز دشت نخچیرگاه", "lines": ["s135-l29", "s135-l30"], "segs": ["s135-g29", "s135-g30"]}, "s135-s16": {"text": "وزان کز دلیران نشد کشته کس زواره ز اسپ اندر افتاد و بس", "lines": ["s135-l31", "s135-l32"], "segs": ["s135-g31", "s135-g32"]}, "s135-s17": {"text": "بران دشت فرخنده بر پهلوان دو هفته همی بود روشن‌روان", "lines": ["s135-l33", "s135-l34"], "segs": ["s135-g33", "s135-g34"]}, "s135-s18": {"text": "سیم را به درگاه شاه آمدند به دیدار فرخ کلاه آمدند", "lines": ["s135-l35", "s135-l36"], "segs": ["s135-g35", "s135-g36"]}, "s135-s19": {"text": "چنین است رسم سرای سپنج یکی زو تن آسان و دیگر به رنج", "lines": ["s135-l37", "s135-l38"], "segs": ["s135-g37", "s135-g38"]}, "s135-s20": {"text": "برین و بران روز هم بگذرد خردمند مردم چرا غم خورد", "lines": ["s135-l39", "s135-l40"], "segs": ["s135-g39", "s135-g40"]}, "s135-s21": {"text": "سخنهای این داستان شد به بن ز سهراب و رستم سرایم سخن", "lines": ["s135-l41", "s135-l42"], "segs": ["s135-g41", "s135-g42"]}}, "segments": {"s135-g1": {"text": "تهمتن برانگیخت رخش از شتاب", "sid": "s135-s1", "lines": ["s135-l1"]}, "s135-g2": {"text": "پس پشت جنگ‌آور افراسیاب", "sid": "s135-s1", "lines": ["s135-l2"]}, "s135-g3": {"text": "چنین گفت با رخش کای نیک یار", "sid": "s135-s2", "lines": ["s135-l3"]}, "s135-g4": {"text": "مکن سستی اندر گه کارزار", "sid": "s135-s2", "lines": ["s135-l4"]}, "s135-g5": {"text": "که من شاه را بر تو بی‌جان کنم", "sid": "s135-s3", "lines": ["s135-l5"]}, "s135-g6": {"text": "به خون سنگ را رنگ مرجان کنم", "sid": "s135-s3", "lines": ["s135-l6"]}, "s135-g7": {"text": "چنان گرم شد رخش آتش گهر", "sid": "s135-s4", "lines": ["s135-l7"]}, "s135-g8": {"text": "که گفتی برآمد ز پهلوش پر", "sid": "s135-s4", "lines": ["s135-l8"]}, "s135-g9": {"text": "ز فتراک بگشاد رستم کمند", "sid": "s135-s5", "lines": ["s135-l9"]}, "s135-g10": {"