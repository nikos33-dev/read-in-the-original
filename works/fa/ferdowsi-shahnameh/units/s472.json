472-s27"}, {"s": 12, "e": 15, "surface": "کیی", "lemma": "کیی", "pos": "NOUN", "seg": "s472-g54", "sid": "s472-s27"}, {"s": 16, "e": 18, "surface": "بر", "lemma": "بر", "pos": "NOUN", "seg": "s472-g54", "sid": "s472-s27"}, {"s": 19, "e": 23, "surface": "نهاد", "lemma": "نهاد", "pos": "NOUN", "seg": "s472-g54", "sid": "s472-s27"}]}}, "sentences": {"s472-s1": {"text": "دلارای چون آن سخنها شنید یکی باد سرد از جگر برکشید", "lines": ["s472-l1", "s472-l2"], "segs": ["s472-g1", "s472-g2"]}, "s472-s2": {"text": "ز دارا ز دیده ببارید خون که بد ریخته زیر خاک اندرون", "lines": ["s472-l3", "s472-l4"], "segs": ["s472-g3", "s472-g4"]}, "s472-s3": {"text": "نویسنده نامه را پیش خواند همه خون ز مژگان به رخ برفشاند", "lines": ["s472-l5", "s472-l6"], "segs": ["s472-g5", "s472-g6"]}, "s472-s4": {"text": "مر آن نامه را خوب پاسخ نوشت سخنهای با مغز و فرخ نوشت", "lines": ["s472-l7", "s472-l8"], "segs": ["s472-g7", "s472-g8"]}, "s472-s5": {"text": "نخست آفرین کرد بر کردگار جهاندار دادار پروردگار", "lines": ["s472-l9", "s472-l10"], "segs": ["s472-g9", "s472-g10"]}, "s472-s6": {"text": "دگر گفت کز کار گردان سپهر کزویست پرخاش و آرام و مهر", "lines": ["s472-l11", "s472-l12"], "segs": ["s472-g11", "s472-g12"]}, "s472-s7": {"text": "همی فر دارا همی خواستیم زبان را به نام وی آراستیم", "lines": ["s472-l13", "s472-l14"], "segs": ["s472-g13", "s472-g14"]}, "s472-s8": {"text": "کنون چون زمان وی اندر گذشت سر گاه او چوب تابوت گشت", "lines": ["s472-l15", "s472-l16"], "segs": ["s472-g15", "s472-g16"]}, "s472-s9": {"text": "ترا خواهم اندر جهان نیکوی بزرگی و پیروزی و خسروی", "lines": ["s472-l17", "s472-l18"], "segs": ["s472-g17", "s472-g18"]}, "s472-s10": {"text": "به کام تو خواهم که باشد جهان برین آشکارا ندارم نهان", "lines": ["s472-l19", "s472-l20"], "segs": ["s472-g19", "s472-g20"]}, "s472-s11": {"text": "شنیدم همه هرچ گفتی ز مهر که از جان تو شاد بادا سپهر", "lines": ["s472-l21", "s472-l22"], "segs": ["s472-g21", "s472-g22"]}, "s472-s12": {"text": "ازان دخمه و دار وز ماهیار مکافات بدخواه جانوشیار", "lines": ["s472-l23", "s472-l24"], "segs": ["s472-g23", "s472-g24"]}, "s472-s13": {"text": "چو خون خداوند ریزد کسی به گیتی درنگش نباشد بسی", "lines": ["s472-l25", "s472-l26"], "segs": ["s472-g25", "s472-g26"]}, "s472-s14": {"text": "دگر آنک جستی همی آشتی بسی روز با پند بگذاشتی", "lines": ["s472-l27", "s472-l28"], "segs": ["s472-g27", "s472-g28"]}, "s472-s15": {"text": "نیاید ز شاهان پرستندگی نجوید کس از تاجور بندگی", "lines": ["s472-l29", "s472-l30"], "segs": ["s472-g29", "s472-g30"]}, "s472-s16": {"text": "به جای شهنشاه ما را توی چو خورشید شد ماه ما را توی", "lines": ["s472-l31", "s472-l32"], "segs": ["s472-g31", "s472-g32"]}, "s472-s17": {"text": "مبادا به گیتی به جز کام تو همیشه بر ایوانها نام تو", "lines": ["s472-l33", "s472-l34"], "segs": ["s472-g33", "s472-g34"]}, "s472-s18": {"text": "دگر آنک از روشنک یاد کرد دل ما بدان آرزو شاد کرد", "lines": ["s472-l35", "s472-l36"], "segs": ["s472-g35", "s472-g36"]}, "s472-s19": {"text": "پرستنده تست ما بنده‌ایم به فرمان و رایت سرافگنده‌ایم", "lines": ["s472-l37", "s472-l38"], "segs": ["s472-g37", "s472-g38"]}, "s472-s20": {"text": "درودت فرستاد و پاسخ نوشت یکی خوب پاسخ بسان بهشت", "lines": ["s472-l39", "s472-l40"], "segs": ["s472-g39", "s472-g40"]}, "s472-s21": {"text": "چو شاه زمانه ترا برگزید سر از رای او کس نیارد کشید", "lines": ["s472-l41", "s472-l42"], "segs": ["s472-g41", "s472-g42"]}, "s472-s22": {"text": "نوشتیم نامه سوی مهتران به پهلو نژادان جنگاوران", "lines": ["s472-l43", "s472-l44"], "segs": ["s472-g43", "s472-g44"]}, "s472-s23": {"text": "که فرمان داراست فرمان تو نپیچد کسی سر ز پیمان تو", "lines": ["s472-l45", "s472-l46"], "segs": ["s472-g45", "s472-g46"]}, "s472-s24": {"text": "فرستاده را جامه و بدره داد ز گنجش ز هرگونه‌ای بهره داد", "lines": ["s472-l47", "s472-l48"], "segs": ["s472-g47", "s472-g48"]}, "s472-s25": {"text": "چو رومی به نزد سکندر رسید همه یاد کرد آنچ دید و شنید", "lines": ["s472-l49", "s472-l50"], "segs": ["s472-g49", "s472-g50"]}, "s472-s26": {"text": "وزان تخت و آیین و آن بارگاه تو گفتی که زنده‌ست بر گاه شاه", "lines": ["s472-l51", "s472-l52"], "segs": ["s472-g51", "s472-g52"]}, "s472-s27": {"text": "سکندر ز گفتار او گشت شاد به آرام تاج کیی بر نهاد", "lines": ["s472-l53", "s472-l54"], "segs": ["s472-g53", "s472-g54"]}}, "segments": {"s472-g1": {"text": "دلارای چون آن سخنها شنید", "sid": "s472-s1", "lines": ["s472-l1"]}, "s472-g2": {"text": "یکی باد سرد از جگر برکشید", "sid": "s472-s1", "lines": ["s472-l2"]}, "s472-g3": {"text": "ز دارا ز دیده ببارید خون", "sid": "s472-s2", "lines": ["s472-l3"]}, "s472-g4": {"text": "که بد ریخته زیر خاک اندرون", "sid": "s472-s2", "lines": ["s472-l4"]}, "s472-g5": {"text": "نویسنده نامه را پیش خواند", "sid": "s472-s3", "lines": ["s472-l5"]}, "s472-g6": {"text": "همه خون ز مژگان به رخ برفشاند", "sid": "s472-s3", "lines": ["s472-l6"]}, "s472-g7": {"text": "مر آن نامه را خوب پاسخ نوشت", "sid": "s472-s4", "lines": ["s472-l7"]}, "s472-g8": {"text": "سخنهای با مغز و فرخ نوشت", "sid": "s472-s4", "lines": ["s472-l8"]}, "s472-g9": {"text": "نخست آفرین کرد بر کردگار", "sid": "s472-s5", "lines": ["s472-l9"]}, "s472-g10": {"text": "جهاندار دادار پروردگار", "sid": "s472-s5", "lines": ["s472-l10"]}, "s472-g11": {"text": "دگر گفت کز کار گردان سپهر", "sid": "s472-s6", "lines": ["s472-l11"]}, "s472-g12": {"text": "کزویست پرخاش و آرام و مهر", "sid": "s472-s6", "lines": ["s472-l12"]}, "s472-g13": {"text": "همی فر دارا همی خواستیم", "sid": "s472-s7", "lines": ["s472-l13"]}, "s472-g14": {"text": "زبان را به نام وی آراستیم", "sid": "s472-s7", "lines": ["s472-l14"]}, "s472-g15": {"text": "کنون چون زمان وی اندر گذشت", "sid": "s472-s8", "lines": ["s472-l15"]}, "s472-g16": {"text": "سر گاه او چوب تابوت گشت", "sid": "s472-s8", "lines": ["s472-l16"]}, "s472-g17": {"text": "ترا خواهم اندر جهان نیکوی", "sid": "s472-s9", "lines": ["s472-l17"]}, "s472-g18": {"text": "بزرگی و پیروزی و خسروی", "sid": "s472-s9", "lines": ["s472-l18"]}, "s472-g19": {"text": "به کام تو خواهم که باشد جهان", "sid": "s472-s10", "lines": ["s472-l19"]}, "s472-g20": {"text": "برین آشک