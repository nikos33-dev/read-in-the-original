  "sentences": {
    "s558-s1": {
      "text": "برو نیز بگذشت سال دراز سر تاجور اندر آمد به گاز",
      "lines": [
        "s558-l1",
        "s558-l2"
      ],
      "segs": [
        "s558-g1",
        "s558-g2"
      ]
    },
    "s558-s2": {
      "text": "یکی پور بودش دلارام بود ورا نام بهرام بهرام بود",
      "lines": [
        "s558-l3",
        "s558-l4"
      ],
      "segs": [
        "s558-g3",
        "s558-g4"
      ]
    },
    "s558-s3": {
      "text": "بیاورد و بنشاندش زیر تخت بدو گفت کای سبز شاخ درخت",
      "lines": [
        "s558-l5",
        "s558-l6"
      ],
      "segs": [
        "s558-g5",
        "s558-g6"
      ]
    },
    "s558-s4": {
      "text": "نبودم فراوان من از تخت شاد همه روزگار تو فرخنده باد",
      "lines": [
        "s558-l7",
        "s558-l8"
      ],
      "segs": [
        "s558-g7",
        "s558-g8"
      ]
    },
    "s558-s5": {
      "text": "سراینده باش و فزاینده باش شب و روز بآرامش و خنده باش",
      "lines": [
        "s558-l9",
        "s558-l10"
      ],
      "segs": [
        "s558-g9",
        "s558-g10"
      ]
    },
    "s558-s6": {
      "text": "چنان رو که پرسند روز شمار نپیچی سر از شرم پروردگار",
      "lines": [
        "s558-l11",
        "s558-l12"
      ],
      "segs": [
        "s558-g11",
        "s558-g12"
      ]
    },
    "s558-s7": {
      "text": "به داد و دهش گیتی آباد دار دل زیردستان خود شاد دار",
      "lines": [
        "s558-l13",
        "s558-l14"
      ],
      "segs": [
        "s558-g13",
        "s558-g14"
      ]
    },
    "s558-s8": {
      "text": "که برکس نماند جهان جاودان نه بر تاجدار و نه بر موبدان",
      "lines": [
        "s558-l15",
        "s558-l16"
      ],
      "segs": [
        "s558-g15",
        "s558-g16"
      ]
    },
    "s558-s9": {
      "text": "تو از چرخ گردان مدان این ستم چو از باد چندی گذاری به دم",
      "lines": [
        "s558-l17",
        "s558-l18"
      ],
      "segs": [
        "s558-g17",
        "s558-g18"
      ]
    },
    "s558-s10": {
      "text": "به سه سال و سه ماه و بر سر سه روز تهی ماند زو تخت گیتی فروز",
      "lines": [
        "s558-l19",
        "s558-l20"
      ],
      "segs": [
        "s558-g19",
        "s558-g20"
      ]
    },
    "s558-s11": {
      "text": "چو بهرام گیتی به بهرام داد پسر مر ورا دخمه آرام داد",
      "lines": [
        "s558-l21",
        "s558-l22"
      ],
      "segs": [
        "s558-g21",
        "s558-g22"
      ]
    },
    "s558-s12": {
      "text": "چنین بود تا بود چرخ بلند به انده چه داری دلت را نژند",
      "lines": [
        "s558-l23",
        "s558-l24"
      ],
      "segs": [
        "s558-g23",
        "s558-g24"
      ]
    },
    "s558-s13": {
      "text": "چه گویی چه جویی چه شاید بدن برین داستانی نشاید زدن",
      "lines": [
        "s558-l25",
        "s558-l26"
      ],
      "segs": [
        "s558-g25",
        "s558-g26"
      ]
    },
    "s558-s14": {
      "text": "روانت‌گر از آز فرتوت نیست نشست تو جز تنگ تابوت نیست",
      "lines": [
        "s558-l27",
        "s558-l28"
      ],
      "segs": [
        "s558-g27",
        "s558-g28"
      ]
    },
    "s558-s15": {
      "text": "اگر مرگ دارد چنین طبع گرگ پر از می‌یکی جام خواهم بزرگ",
      "lines": [
        "s558-l29",
        "s558-l30"
      ],
      "segs": [
        "s558-g29",
        "s558-g30"
      ]
    }
  },
