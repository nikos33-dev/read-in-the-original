  "sentences": {
    "s720-s1": {
      "text": "چو بشنید خاقان که بهرام را چه آمد بروی از پی نام را",
      "lines": [
        "s720-l1",
        "s720-l2"
      ],
      "segs": [
        "s720-g1",
        "s720-g2"
      ]
    },
    "s720-s2": {
      "text": "چوآن نامه نزدیک خاقان رسید شد از درد گریان هران کان شنید",
      "lines": [
        "s720-l3",
        "s720-l4"
      ],
      "segs": [
        "s720-g3",
        "s720-g4"
      ]
    },
    "s720-s3": {
      "text": "از آن آگهی شد دلش پر ز درد دو دیده پر از خون و رخ لاژورد",
      "lines": [
        "s720-l5",
        "s720-l6"
      ],
      "segs": [
        "s720-g5",
        "s720-g6"
      ]
    },
    "s720-s4": {
      "text": "ازان کار او در شگفتی بماند جهاندیدگان را همه پیش خواند",
      "lines": [
        "s720-l7",
        "s720-l8"
      ],
      "segs": [
        "s720-g7",
        "s720-g8"
      ]
    },
    "s720-s5": {
      "text": "بگفت آنک بهرام یل را رسید بشد زار و گریان هران کوشنید",
      "lines": [
        "s720-l9",
        "s720-l10"
      ],
      "segs": [
        "s720-g9",
        "s720-g10"
      ]
    },
    "s720-s6": {
      "text": "همه چین برو زار و گریان شدند ابی آتش تیز بریان شدند",
      "lines": [
        "s720-l11",
        "s720-l12"
      ],
      "segs": [
        "s720-g11",
        "s720-g12"
      ]
    },
    "s720-s7": {
      "text": "یکایک همه کار او را بساخت نگه کرد کاین بدبریشان که تاخت",
      "lines": [
        "s720-l13",
        "s720-l14"
      ],
      "segs": [
        "s720-g13",
        "s720-g14"
      ]
    },
    "s720-s8": {
      "text": "قلون را به توران دو فرزند بود ز هر گونه‌ای خویش و پیوند بود",
      "lines": [
        "s720-l15",
        "s720-l16"
      ],
      "segs": [
        "s720-g15",
        "s720-g16"
      ]
    },
    "s720-s9": {
      "text": "چو دانسته شد آتشی بر فروخت سرای و همه بر زن او بسوخت",
      "lines": [
        "s720-l17",
        "s720-l18"
      ],
      "segs": [
        "s720-g17",
        "s720-g18"
      ]
    },
    "s720-s10": {
      "text": "دو فرزند او را بر آتش نهاد همه چیز او را به تاراج داد",
      "lines": [
        "s720-l19",
        "s720-l20"
      ],
      "segs": [
        "s720-g19",
        "s720-g20"
      ]
    },
    "s720-s11": {
      "text": "ازان پس چو نوبت به خاتون رسید ز پرده به گیسوش بیرون کشید",
      "lines": [
        "s720-l21",
        "s720-l22"
      ],
      "segs": [
        "s720-g21",
        "s720-g22"
      ]
    },
    "s720-s12": {
      "text": "به ایوان کشید آن همه گنج اوی نکرد ایچ یاد از در رنج اوی",
      "lines": [
        "s720-l23",
        "s720-l24"
      ],
      "segs": [
        "s720-g23",
        "s720-g24"
      ]
    },
    "s720-s13": {
      "text": "فرستاد هرسو هیونان مست نیامدش خراد برزین بدست",
      "lines": [
        "s720-l25",
        "s720-l26"
      ],
      "segs": [
        "s720-g25",
        "s720-g26"
      ]
    },
    "s720-s14": {
      "text": "همه هرچ در چین و را بنده بود به پوشیدشان جامه‌های کبود",
      "lines": [
        "s720-l27",
        "s720-l28"
      ],
      "segs": [
        "s720-g27",
        "s720-g28"
      ]
    },
    "s720-s15": {
      "text": "بیک چند با سوک بهرام بود که خاقان ازان کار بدنام بود",
      "lines": [
        "s720-l29",
        "s720-l30"
      ],
      "segs": [
        "s720-g29",
        "s720-g30"
      ]
    }
  },
