  "sentences": {
    "s773-s1": {
      "text": "چنین داد خوانیم بر یزدگرد وگر کینه خوانیم ازین هفت گرد",
      "lines": [
        "s773-l1",
        "s773-l2"
      ],
      "segs": [
        "s773-g1",
        "s773-g2"
      ]
    },
    "s773-s2": {
      "text": "اگر خود نداند همی کین و داد مرا فیلسوف ایچ پاسخ نداد",
      "lines": [
        "s773-l3",
        "s773-l4"
      ],
      "segs": [
        "s773-g3",
        "s773-g4"
      ]
    },
    "s773-s3": {
      "text": "وگر گفت دینی همه بسته گفت بماند همی پاسخ اندر نهفت",
      "lines": [
        "s773-l5",
        "s773-l6"
      ],
      "segs": [
        "s773-g5",
        "s773-g6"
      ]
    },
    "s773-s4": {
      "text": "اگر هیچ گنجست ای نیک رای بیارای و دل را به فردا مپای",
      "lines": [
        "s773-l7",
        "s773-l8"
      ],
      "segs": [
        "s773-g7",
        "s773-g8"
      ]
    },
    "s773-s5": {
      "text": "که گیتی همی بر تو بر بگذرد زمانه دم ما همی‌بشمرد",
      "lines": [
        "s773-l9",
        "s773-l10"
      ],
      "segs": [
        "s773-g9",
        "s773-g10"
      ]
    },
    "s773-s6": {
      "text": "در خوردنت چیره کن برنهاد اگر خود بمانی دهد آنک داد",
      "lines": [
        "s773-l11",
        "s773-l12"
      ],
      "segs": [
        "s773-g11",
        "s773-g12"
      ]
    },
    "s773-s7": {
      "text": "مرا دخل و خرج ار برابر بدی زمانه مرا چون برادر بدی",
      "lines": [
        "s773-l13",
        "s773-l14"
      ],
      "segs": [
        "s773-g13",
        "s773-g14"
      ]
    },
    "s773-s8": {
      "text": "تگرگ آمد امسال بر سان مرگ مرا مرگ بهتر بدی از تگرگ",
      "lines": [
        "s773-l15",
        "s773-l16"
      ],
      "segs": [
        "s773-g15",
        "s773-g16"
      ]
    },
    "s773-s9": {
      "text": "در هیزم و گندم و گوسفند ببست این برآورده چرخ بلند",
      "lines": [
        "s773-l17",
        "s773-l18"
      ],
      "segs": [
        "s773-g17",
        "s773-g18"
      ]
    },
    "s773-s10": {
      "text": "می‌آور که از روزمان بس نماند چنین بود تا بود و بر کس نماند",
      "lines": [
        "s773-l19",
        "s773-l20"
      ],
      "segs": [
        "s773-g19",
        "s773-g20"
      ]
    }
  },
