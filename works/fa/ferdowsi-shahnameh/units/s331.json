seg": "s331-g44", "sid": "s331-s22"}, {"s": 6, "e": 8, "surface": "کس", "lemma": "کس", "pos": "NOUN", "seg": "s331-g44", "sid": "s331-s22"}, {"s": 9, "e": 11, "surface": "او", "lemma": "او", "pos": "NOUN", "seg": "s331-g44", "sid": "s331-s22"}, {"s": 12, "e": 14, "surface": "را", "lemma": "را", "pos": "NOUN", "seg": "s331-g44", "sid": "s331-s22"}, {"s": 15, "e": 17, "surface": "به", "lemma": "به", "pos": "NOUN", "seg": "s331-g44", "sid": "s331-s22"}, {"s": 18, "e": 22, "surface": "آفاق", "lemma": "آفاق", "pos": "NOUN", "seg": "s331-g44", "sid": "s331-s22"}, {"s": 23, "e": 26, "surface": "جفت", "lemma": "جفت", "pos": "NOUN", "seg": "s331-g44", "sid": "s331-s22"}]}}, "sentences": {"s331-s1": {"text": "به ایرانیان گفت هنگام من فراز آمد و تازه شد کام من", "lines": ["s331-l1", "s331-l2"], "segs": ["s331-g1", "s331-g2"]}, "s331-s2": {"text": "بخواهید چیزی که باید ز من که آمد پراگندن انجمن", "lines": ["s331-l3", "s331-l4"], "segs": ["s331-g3", "s331-g4"]}, "s331-s3": {"text": "همه مهتران زار و گریان شدند ز درد شهنشاه بریان شدند", "lines": ["s331-l5", "s331-l6"], "segs": ["s331-g5", "s331-g6"]}, "s331-s4": {"text": "همی گفت هرکس که‌ای شهریار که را مانی این تاج را یادگار", "lines": ["s331-l7", "s331-l8"], "segs": ["s331-g7", "s331-g8"]}, "s331-s5": {"text": "چو بشنید دستان خسرو پرست زمین را ببوسید و برپای جست", "lines": ["s331-l9", "s331-l10"], "segs": ["s331-g9", "s331-g10"]}, "s331-s6": {"text": "چنین گفت کای شهریار جهان سزد کآرزوها ندارم نهان", "lines": ["s331-l11", "s331-l12"], "segs": ["s331-g11", "s331-g12"]}, "s331-s7": {"text": "تو دانی که رستم به ایران چه کرد به رزم و به بزم و به ننگ و نبرد", "lines": ["s331-l13", "s331-l14"], "segs": ["s331-g13", "s331-g14"]}, "s331-s8": {"text": "چو کاووس کی شد به مازندران رهی دور و فرسنگهای گران", "lines": ["s331-l15", "s331-l16"], "segs": ["s331-g15", "s331-g16"]}, "s331-s9": {"text": "چو دیوان ببستند کاووس را چو گودرز گردنکش و طوس را", "lines": ["s331-l17", "s331-l18"], "segs": ["s331-g17", "s331-g18"]}, "s331-s10": {"text": "تهمتن چو بشنید تنها برفت به مازندران روی بنهاد تفت", "lines": ["s331-l19", "s331-l20"], "segs": ["s331-g19", "s331-g20"]}, "s331-s11": {"text": "بیابان و تاریکی و دیو و شیر همان جادوی و اژدهای دلیر", "lines": ["s331-l21", "s331-l22"], "segs": ["s331-g21", "s331-g22"]}, "s331-s12": {"text": "بدان رنج و تیمار ببرید راه به مازندران شد به نزدیک شاه", "lines": ["s331-l23", "s331-l24"], "segs": ["s331-g23", "s331-g24"]}, "s331-s13": {"text": "بدرید پهلوی دیو سپید جگرگاه پولاد غندی و بید", "lines": ["s331-l25", "s331-l26"], "segs": ["s331-g25", "s331-g26"]}, "s331-s14": {"text": "سر سنجه را ناگه از تن بکند خروشش برآمد به ابر بلند", "lines": ["s331-l27", "s331-l28"], "segs": ["s331-g27", "s331-g28"]}, "s331-s15": {"text": "چو سهراب فرزند کاندر جهان کسی را نبود از کهان و مهان", "lines": ["s331-l29", "s331-l30"], "segs": ["s331-g29", "s331-g30"]}, "s331-s16": {"text": "بکشت از پی کین کاووس شاه ز دردش بگرید همی سال و ماه", "lines": ["s331-l31", "s331-l32"], "segs": ["s331-g31", "s331-g32"]}, "s331-s17": {"text": "وز آن پس کجا رزم کاموس کرد به مردی به ابر اندر آورد گرد", "lines": ["s331-l33", "s331-l34"], "segs": ["s331-g33", "s331-g34"]}, "s331-s18": {"text": "ز کردار او چند رانم سخن که هم داستانها نیاید به بن", "lines": ["s331-l35", "s331-l36"], "segs": ["s331-g35", "s331-g36"]}, "s331-s19": {"text": "اگر شاه سیر آمد از تاج و گاه چه ماند بدین شیردل نیک‌خواه", "lines": ["s331-l37", "s331-l38"], "segs": ["s331-g37", "s331-g38"]}, "s331-s20": {"text": "چنین داد پاسخ که کردار اوی به نزدیک ما رنج و تیمار اوی", "lines": ["s331-l39", "s331-l40"], "segs": ["s331-g39", "s331-g40"]}, "s331-s21": {"text": "که داند مگر کردگار سپهر نماینده کام و آرام و مهر", "lines": ["s331-l41", "s331-l42"], "segs": ["s331-g41", "s331-g42"]}, "s331-s22": {"text": "سخنهای او نیست اندر نهفت نداند کس او را به آفاق جفت", "lines": ["s331-l43", "s331-l44"], "segs": ["s331-g43", "s331-g44"]}}, "segments": {"s331-g1": {"text": "به ایرانیان گفت هنگام من", "sid": "s331-s1", "lines": ["s331-l1"]}, "s331-g2": {"text"