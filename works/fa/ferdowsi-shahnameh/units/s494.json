: "s494-s17"}, {"s": 24, "e": 25, "surface": "و", "lemma": "و", "pos": "NOUN", "seg": "s494-g34", "sid": "s494-s17"}, {"s": 26, "e": 28, "surface": "نه", "lemma": "نه", "pos": "NUM", "seg": "s494-g34", "sid": "s494-s17"}, {"s": 29, "e": 32, "surface": "بخت", "lemma": "بخت", "pos": "NOUN", "seg": "s494-g34", "sid": "s494-s17"}]}}, "sentences": {"s494-s1": {"text": "سکندر بیامد دلی همچو کوه رها گشته از شاه دانش‌پژوه", "lines": ["s494-l1", "s494-l2"], "segs": ["s494-g1", "s494-g2"]}, "s494-s2": {"text": "نبودش ز قیدافه چین در بروی نبرداشت هرگز دل از آرزوی", "lines": ["s494-l3", "s494-l4"], "segs": ["s494-g3", "s494-g4"]}, "s494-s3": {"text": "ببود آن شب و بامداد پگاه ز ایوان بیامد به نزدیک شاه", "lines": ["s494-l5", "s494-l6"], "segs": ["s494-g5", "s494-g6"]}, "s494-s4": {"text": "سپهدار در خان پیل‌استه بود همه گرد بر گرد او رسته بود", "lines": ["s494-l7", "s494-l8"], "segs": ["s494-g7", "s494-g8"]}, "s494-s5": {"text": "سر خانه را پیکر از جزع و زر به زر اندرون چند گونه گهر", "lines": ["s494-l9", "s494-l10"], "segs": ["s494-g9", "s494-g10"]}, "s494-s6": {"text": "به پیش اندرون دسته مشک بوی دو فرزند بایسته در پیش اوی", "lines": ["s494-l11", "s494-l12"], "segs": ["s494-g11", "s494-g12"]}, "s494-s7": {"text": "چو طینوش اسپ‌افگن و قیدروش نهاده به گفتار قیدافه گوش", "lines": ["s494-l13", "s494-l14"], "segs": ["s494-g13", "s494-g14"]}, "s494-s8": {"text": "به مادر چنین گفت کهتر پسر که‌ای شاه نیک اختر و دادگر", "lines": ["s494-l15", "s494-l16"], "segs": ["s494-g15", "s494-g16"]}, "s494-s9": {"text": "چنان کن که از پیش تو بیطقون شود شاد و خشنود با رهنمون", "lines": ["s494-l17", "s494-l18"], "segs": ["s494-g17", "s494-g18"]}, "s494-s10": {"text": "به ره بر کسی تا نیازاردش ور از دشمنان نیز نشماردش", "lines": ["s494-l19", "s494-l20"], "segs": ["s494-g19", "s494-g20"]}, "s494-s11": {"text": "که زنده کن پاک جان من اوست برآنم که روشن‌روان من اوست", "lines": ["s494-l21", "s494-l22"], "segs": ["s494-g21", "s494-g22"]}, "s494-s12": {"text": "بدو گفت مادر که ایدون کنم که او را بزرگی بر افزون کنم", "lines": ["s494-l23", "s494-l24"], "segs": ["s494-g23", "s494-g24"]}, "s494-s13": {"text": "به اسکندر نامور شاه گفت که پیدا کن اکنون نهان از نهفت", "lines": ["s494-l25", "s494-l26"], "segs": ["s494-g25", "s494-g26"]}, "s494-s14": {"text": "چه خواهی و رای سکندر به چیست چه رانی تو از شاه و دستور کیست", "lines": ["s494-l27", "s494-l28"], "segs": ["s494-g27", "s494-g28"]}, "s494-s15": {"text": "سکندر بدو گفت کای سرفراز به نزد تو شد بودن من دراز", "lines": ["s494-l29", "s494-l30"], "segs": ["s494-g29", "s494-g30"]}, "s494-s16": {"text": "مرا گفت رو باژ مرزش بخواه وگر دیر مانی بیارم سپاه", "lines": ["s494-l31", "s494-l32"], "segs": ["s494-g31", "s494-g32"]}, "s494-s17": {"text": "نمانم بدو کشور و تاج و تخت نه زور و نه شاهی نه گنج و نه بخت", "lines": ["s494-l33", "s494-l34"], "segs": ["s494-g33", "s494-g34"]}}, "segments": {"s494-g1": {"text": "سکندر بیامد دلی همچو کوه", "sid": "s494-s1", "lines": ["s494-l1"]}, "s494-g2": {"text": "رها گشته از شاه دانش‌پژوه", "sid": "s494-s1", "lines": ["s494-l2"]}, "s494-g3": {"text": "نبودش ز قیدافه چین در بروی", "sid": "s494-s2", "lines": ["s494-l3"]}, "s494-g4": {"text": "نبرداشت هرگز دل از آرزوی", "sid": "s494-s2", "lines": ["s494-l4"]}, "s494-g5": {"text": "ببود آن شب و بامداد پگاه", "sid": "s494-s3", "lines": ["s494-l5"]}, "s494-g6": {"text": "ز ایوان بیامد به نزدیک شاه", "sid": "s494-s3", "lines": ["s494-l6"]}, "s494-g7": {"text": "سپهدار در خان پیل‌استه بود", "sid": "s494-s4", "lines": ["s494-l7"]}, "s494-g8": {"text": "همه گرد بر گرد او رسته بود", "sid": "s494-s4", "lines": ["s494-l8"]}, "s494-g9": {"text": "سر خانه را پیکر از جزع و زر", "sid": "s494-s5", "lines": ["s494-l9"]}, "s494-g10": {"text": "به زر اندرون چند گونه گهر", "sid": "s494-s5", "lines": ["s494-l10"]}, "s494-g11": {"text": "به پیش اندرون دسته مشک بوی", "sid": "s494-s6", "lines": ["s494-l11"]}, "s494-g12": {"text": "دو فرزند بایسته در پیش اوی", "sid": "s494-s6", "lines": ["s494-l12"]}, "s494-g13": {"text": "چو طینوش اسپ‌افگن و قیدروش", "sid": "s494-s7", "lines": ["s494-l13"]}, "s494-g14": {"text": "نهاده به گفتار قیدافه گوش", "sid": "s494-s7", "lines": ["s494-l14"]}, "s494-g15": {"text": "به مادر چنین گفت کهتر پسر", "sid": "s494-s8", "lines": ["s494-l15"]}, "s494-g16": {"text": "که‌ای شاه نیک اختر و دادگر", "sid": "s494-s8", "lines": ["s494-l16"]}, "s494-g17": {"text": "چنان کن که از پیش تو بیطقون", "sid": "s494-s9", "lines": ["s494-l17"]}, "s494-g18": {"text": "شود شاد و خشنود با رهنمون", "sid": "s494-s9", "lines": ["s494-l18"]}, "s494-g19": {"text": "به ره بر کسی تا نیازاردش", "sid": "s494-s10", "lines": ["s494-l19"]}, "s494-g20": {"text": "ور از دشمنان نیز نشماردش", "sid": "s494-s10", "lines": ["s494-l20"]}, "s494-g21": {"text": "که زنده کن پاک جان من اوست", "sid": "s494-s11", "lines": ["s494-l21"]}, "s494-g22": {"text": "برآنم که روشن‌روان من اوست", "sid": "s494-s11", "lines": ["s494-l22"]}, "s494-g23": {"text": "بدو گفت مادر که ایدون کنم", "sid": "s494-s12", "lines": ["s494-l23"]}, "s494-g24": {"text": "که او را بزرگی بر افزون کنم", "sid": "s494-s12", "lines": ["s494-l24"]}, "s494-g25": {"text": "به اسکندر نامور شاه گفت", "sid": "s494-s13", "lines": ["s494-l25"]}, "s494-g26": {"text": "که پیدا کن اکنون نهان از نهفت", "sid": "s494-s13", "lines": ["s494-l26"]}, "s494-g27": {"text": "چه خواهی و رای سکندر به چیست", "sid": "s494-s14", "lines": ["s494-l27"]}, "s494-g28": {"text": "چه رانی تو از شاه و دستور کیست", "sid": "s494-s14", "lines": ["s494-l28"]}, "s494-g29": {"text": "سکندر بدو گفت کای سرفراز", "sid": "s494-s15", "lines": ["s494-l29"]}, "s494-g30": {"text": "به نزد تو شد بودن من دراز", "sid": "s494-s15", "lines": ["s494-l30"]}, "s494-g31": {"text": "مرا گفت رو باژ مرزش بخواه", "sid": "s494-s16", "lines": ["s494-l31"]}, "s494-g32": {"text": "وگر دیر مانی بیارم سپاه", "sid": "s494-s16", "lines": ["s494-l32"]}, "s494-g33": {"text": "نمانم بدو کشور و تاج و تخت", "sid": "s494-s17", "lines": ["s494-l33"]}, "s494-g34": {"text": "نه زور و نه شاهی نه گنج و نه بخت", "sid": "s494-s17", "lines": ["s494-l34"]}}}