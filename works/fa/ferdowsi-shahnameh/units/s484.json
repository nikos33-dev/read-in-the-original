ace": "رزم", "lemma": "رزم", "pos": "NOUN", "seg": "s484-g40", "sid": "s484-s20"}, {"s": 8, "e": 12, "surface": "گفتی", "lemma": "گفت#گو", "pos": "NOUN", "seg": "s484-g40", "sid": "s484-s20"}, {"s": 13, "e": 16, "surface": "گهی", "lemma": "گهی", "pos": "NOUN", "seg": "s484-g40", "sid": "s484-s20"}, {"s": 17, "e": 20, "surface": "بزم", "lemma": "بزم", "pos": "NOUN", "seg": "s484-g40", "sid": "s484-s20"}, {"s": 21, "e": 22, "surface": "و", "lemma": "و", "pos": "NOUN", "seg": "s484-g40", "sid": "s484-s20"}, {"s": 23, "e": 26, "surface": "سور", "lemma": "سور", "pos": "NOUN", "seg": "s484-g40", "sid": "s484-s20"}]}, "s484-l41": {"text": "فرستاده آمد به درگه فراز", "sids": ["s484-s21"], "tokens": [{"s": 0, "e": 7, "surface": "فرستاده", "lemma": "فرستاده", "pos": "NOUN", "seg": "s484-g41", "sid": "s484-s21"}, {"s": 8, "e": 11, "surface": "آمد", "lemma": "آمد#آ", "pos": "NOUN", "seg": "s484-g41", "sid": "s484-s21"}, {"s": 12, "e": 14, "surface": "به", "lemma": "به", "pos": "NOUN", "seg": "s484-g41", "sid": "s484-s21"}, {"s": 15, "e": 19, "surface": "درگه", "lemma": "درگه", "pos": "NOUN", "seg": "s484-g41", "sid": "s484-s21"}, {"s": 20, "e": 24, "surface": "فراز", "lemma": "فراز", "pos": "NOUN", "seg": "s484-g41", "sid": "s484-s21"}]}, "s484-l42": {"text": "بگفتند با فور گردن‌فراز", "sids": ["s484-s21"], "tokens": [{"s": 0, "e": 6, "surface": "بگفتند", "lemma": "بگفتند", "pos": "NOUN", "seg": "s484-g42", "sid": "s484-s21"}, {"s": 7, "e": 9, "surface": "با", "lemma": "با", "pos": "NOUN", "seg": "s484-g42", "sid": "s484-s21"}, {"s": 10, "e": 13, "surface": "فور", "lemma": "فور", "pos": "NOUN", "seg": "s484-g42", "sid": "s484-s21"}, {"s": 14, "e": 23, "surface": "گردن‌فراز", "lemma": "گردن‌فراز", "pos": "NOUN", "seg": "s484-g42", "sid": "s484-s21"}]}, "s484-l43": {"text": "جهاندیده را پیش او خواندند", "sids": ["s484-s22"], "tokens": [{"s": 0, "e": 8, "surface": "جهاندیده", "lemma": "جهاندیده", "pos": "NOUN", "seg": "s484-g43", "sid": "s484-s22"}, {"s": 9, "e": 11, "surface": "را", "lemma": "را", "pos": "NOUN", "seg": "s484-g43", "sid": "s484-s22"}, {"s": 12, "e": 15, "surface": "پیش", "lemma": "پیش", "pos": "NOUN", "seg": "s484-g43", "sid": "s484-s22"}, {"s": 16, "e": 18, "surface": "او", "lemma": "او", "pos": "NOUN", "seg": "s484-g43", "sid": "s484-s22"}, {"s": 19, "e": 26, "surface": "خواندند", "lemma": "خواند#خوان", "pos": "NOUN", "seg": "s484-g43", "sid": "s484-s22"}]}, "s484-l44": {"text": "بر تخت نزدیک بنشاندند", "sids": ["s484-s22"], "tokens": [{"s": 0, "e": 2, "surface": "بر", "lemma": "بر", "pos": "NOUN", "seg": "s484-g44", "sid": "s484-s22"}, {"s": 3, "e": 6, "surface": "تخت", "lemma": "تخت", "pos": "NOUN", "seg": "s484-g44", "sid": "s484-s22"}, {"s": 7, "e": 12, "surface": "نزدیک", "lemma": "نزدیک", "pos": "NOUN", "seg": "s484-g44", "sid": "s484-s22"}, {"s": 13, "e": 21, "surface": "بنشاندند", "lemma": "بنشاندند", "pos": "NOUN", "seg": "s484-g44", "sid": "s484-s22"}]}}, "sentences": {"s484-s1": {"text": "ز میلاد چون باد لشکر براند به قنوج شد گنجش آنجا بماند", "lines": ["s484-l1", "s484-l2"], "segs": ["s484-g1", "s484-g2"]}, "s484-s2": {"text": "چو آورد لشکر به نزدیک فور یکی نامه فرمود پر جنگ و شور", "lines": ["s484-l3", "s484-l4"], "segs": ["s484-g3", "s484-g4"]}, "s484-s3": {"text": "ز شاهنشه اسکندر فیلقوس فروزنده آتش و نعم و بوس", "lines": ["s484-l5", "s484-l6"], "segs": ["s484-g5", "s484-g6"]}, "s484-s4": {"text": "سوی فور هندی سپهدار هند بلند اختر و لشکر آرای سند", "lines": ["s484-l7", "s484-l8"], "segs": ["s484-g7", "s484-g8"]}, "s484-s5": {"text": "سر نامه کرد آفرین خدای کجا بود و باشد همیشه به جای", "lines": ["s484-l9", "s484-l10"], "segs": ["s484-g9", "s484-g10"]}, "s484-s6": {"text": "کسی را که او کرد پیروزبخت بماند بدو کشور و تاج و تخت", "lines": ["s484-l11", "s484-l12"], "segs": ["s484-g11", "s484-g12"]}, "s484-s7": {"text": "گرش خوار گیرد بماند نژد نتابد برو آفتاب بلند", "lines": ["s484-l13", "s484-l14"], "segs": ["s484-g13", "s484-g14"]}, "s484-s8": {"text": "شنیدی همانا که یزدان پاک چه دادست ما را بدین تیره خاک", "lines": ["s484-l15", "s484-l16"], "segs": ["s484-g15", "s484-g16"]}, "s484-s9": {"text": "ز پیروزی و بخت وز فرهی ز دیهیم وز تخت شاهنشهی", "lines": ["s484-l17", "s484-l18"], "segs": ["s484-g17", "s484-g18"]}, "s484-s10": {"text": "نماند همی روز ما بگذرد کسی دیگر آید کزو بر خورد", "lines": ["s484-l19", "s484-l20"], "segs": ["s484-g19", "s484-g20"]}, "s484-s11": {"text": "همی نام کوشم که ماند نه ننگ بدین مرکز ماه و پرگار تنگ", "lines": ["s484-l21", "s484-l22"], "segs": ["s484-g21", "s484-g22"]}, "s484-s12": {"text": "چو این نامه آرند نزدیک تو بی‌آزار کن رای تاریک تو", "lines": ["s484-l23", "s484-l24"], "segs": ["s484-g23", "s484-g24"]}, "s484-s13": {"text": "ز تخت بلندی به اسپ اندر آی مزن رای با موبد و رهنمای", "lines": ["s484-l25", "s484-l26"], "segs": ["s484-g25", "s484-g26"]}, "s484-s14": {"text": "ز ما ایمنی خواه و چاره مساز که بر چاره‌گر کار گردد دراز", "lines": ["s484-l27", "s484-l28"], "segs": ["s484-g27", "s484-g28"]}, "s484-s15": {"text": "ز فرمان اگر یک زمان بگذری بلندی گزینی و کنداوری", "lines": ["s484-l29", "s484-l30"], "segs": ["s484-g29", "s484-g30"]}, "s484-s16": {"text": "بیارم چو آتش سپاهی گران گزیده دلیران کنداوران", "lines": ["s484-l31", "s484-l32"], "segs": ["s484-g31", "s484-g32"]}, "s484-s17": {"text": "چو من باسواران بیایم به جنگ پشیمانی آید ترا زین درنگ", "lines": ["s484-l33", "s484-l34"], "segs": ["s484-g33", "s484-g34"]}, "s484-s18": {"text": "چو زین باره گفتارها سخته شد نویسنده از نامه پردخته شد", "lines": ["s484-l35", "s484-l36"], "segs": ["s484-g35", "s484-g36"]}, "s484-s19": {"text": "نهادند مهر سکندر به روی بجستند پیدا یکی نامجوی", "lines": ["s484-l37", "s484-l38"], "segs": ["s484-g37", "s484-g38"]}, "s484-s20": {"text": "فرستاده شاهش به نزدیک فور گهی رزم گفتی گهی بزم و سور", "lines": ["s484-l39", "s484-l40"], "segs": ["s484-g39", "s484-g40"]}, "s484-s21": {"text": "فرستاده آمد به درگه فراز بگفتند با فور گردن‌فراز", "lines": ["s484-l41", "s484-l42"], "segs": ["s484-g41", "s484-g42"]}, "s484-s22": {"text": "جهاندیده را پیش او خواندند بر ت