s456-s23"}]}, "s456-l47": {"text": "ز هر پیشه‌ای کارگر خواستند", "sids": ["s456-s24"], "tokens": [{"s": 0, "e": 1, "surface": "ز", "lemma": "ز", "pos": "NOUN", "seg": "s456-g47", "sid": "s456-s24"}, {"s": 2, "e": 4, "surface": "هر", "lemma": "هر", "pos": "NOUN", "seg": "s456-g47", "sid": "s456-s24"}, {"s": 5, "e": 12, "surface": "پیشه‌ای", "lemma": "پیشه", "pos": "NOUN", "seg": "s456-g47", "sid": "s456-s24"}, {"s": 13, "e": 18, "surface": "کارگر", "lemma": "کارگر", "pos": "NOUN", "seg": "s456-g47", "sid": "s456-s24"}, {"s": 19, "e": 26, "surface": "خواستند", "lemma": "خواست#خواه", "pos": "NOUN", "seg": "s456-g47", "sid": "s456-s24"}]}, "s456-l48": {"text": "همی شهر ایران بیاراستند", "sids": ["s456-s24"], "tokens": [{"s": 0, "e": 3, "surface": "همی", "lemma": "همی", "pos": "NOUN", "seg": "s456-g48", "sid": "s456-s24"}, {"s": 4, "e": 7, "surface": "شهر", "lemma": "شهر", "pos": "NOUN", "seg": "s456-g48", "sid": "s456-s24"}, {"s": 8, "e": 13, "surface": "ایران", "lemma": "ایران", "pos": "NOUN", "seg": "s456-g48", "sid": "s456-s24"}, {"s": 14, "e": 23, "surface": "بیاراستند", "lemma": "بیاراستند", "pos": "NOUN", "seg": "s456-g48", "sid": "s456-s24"}]}, "s456-l49": {"text": "به هر سو فرستاد بی‌مر سپاه", "sids": ["s456-s25"], "tokens": [{"s": 0, "e": 2, "surface": "به", "lemma": "به", "pos": "NOUN", "seg": "s456-g49", "sid": "s456-s25"}, {"s": 3, "e": 5, "surface": "هر", "lemma": "هر", "pos": "NOUN", "seg": "s456-g49", "sid": "s456-s25"}, {"s": 6, "e": 8, "surface": "سو", "lemma": "سو", "pos": "NOUN", "seg": "s456-g49", "sid": "s456-s25"}, {"s": 9, "e": 15, "surface": "فرستاد", "lemma": "فرستاد#فرست", "pos": "NOUN", "seg": "s456-g49", "sid": "s456-s25"}, {"s": 16, "e": 21, "surface": "بی‌مر", "lemma": "بی‌مر", "pos": "NOUN", "seg": "s456-g49", "sid": "s456-s25"}, {"s": 22, "e": 26, "surface": "سپاه", "lemma": "سپاه", "pos": "NOUN", "seg": "s456-g49", "sid": "s456-s25"}]}, "s456-l50": {"text": "ز دشمن همی داشت گیتی نگاه", "sids": ["s456-s25"], "tokens": [{"s": 0, "e": 1, "s