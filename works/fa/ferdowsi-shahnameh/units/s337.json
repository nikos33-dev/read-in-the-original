"seg": "s337-g51", "sid": "s337-s26"}, {"s": 24, "e": 28, "surface": "سپاه", "lemma": "سپاه", "pos": "NOUN", "seg": "s337-g51", "sid": "s337-s26"}]}, "s337-l52": {"text": "به بزم اندرون ماه بد با کلاه", "sids": ["s337-s26"], "tokens": [{"s": 0, "e": 2, "surface": "به", "lemma": "به", "pos": "NOUN", "seg": "s337-g52", "sid": "s337-s26"}, {"s": 3, "e": 6, "surface": "بزم", "lemma": "بزم", "pos": "NOUN", "seg": "s337-g52", "sid": "s337-s26"}, {"s": 7, "e": 13, "surface": "اندرون", "lemma": "اندرون", "pos": "NOUN", "seg": "s337-g52", "sid": "s337-s26"}, {"s": 14, "e": 17, "surface": "ماه", "lemma": "ماه", "pos": "NOUN", "seg": "s337-g52", "sid": "s337-s26"}, {"s": 18, "e": 20, "surface": "بد", "lemma": "بد", "pos": "NOUN", "seg": "s337-g52", "sid": "s337-s26"}, {"s": 21, "e": 23, "surface": "با", "lemma": "با", "pos": "NOUN", "seg": "s337-g52", "sid": "s337-s26"}, {"s": 24, "e": 28, "surface": "کلاه", "lemma": "کلاه", "pos": "NOUN", "seg": "s337-g52", "sid": "s337-s26"}]}}, "sentences": {"s337-s1": {"text": "چو بهری ز تیره شب اندر چمید کی نامور پیش چشمه رسید", "lines": ["s337-l1", "s337-l2"], "segs": ["s337-g1", "s337-g2"]}, "s337-s2": {"text": "بر آن آب روشن سر و تن بشست همی خواند اندر نهان زند و است", "lines": ["s337-l3", "s337-l4"], "segs": ["s337-g3", "s337-g4"]}, "s337-s3": {"text": "چنین گفت با نامور بخردان که باشید پدرود تا جاودان", "lines": ["s337-l5", "s337-l6"], "segs": ["s337-g5", "s337-g6"]}, "s337-s4": {"text": "کنون چون برآرد سنان آفتاب مبینید دیگر مرا جز به خواب", "lines": ["s337-l7", "s337-l8"], "segs": ["s337-g7", "s337-g8"]}, "s337-s5": {"text": "شما بازگردید ز این ریگ خشک مباشید اگر بارد از ابر مشک", "lines": ["s337-l9", "s337-l10"], "segs": ["s337-g9", "s337-g10"]}, "s337-s6": {"text": "ز کوه اندر آید یکی باد سخت کجا بشکند شاخ و برگ درخت", "lines": ["s337-l11", "s337-l12"], "segs": ["s337-g11", "s337-g12"]}, "s337-s7": {"text": "ببارد بسی برف ز ابر سیاه شما سوی ایران نیابید راه", "lines": ["s337-l13", "s337-l14"], "segs": ["s337-g13", "s337-g14"]}, "s337-s8": {"text": "سر مهتران زآن سخن شد گران بخفتند با درد کنداواران", "lines": ["s337-l15", "s337-l16"], "segs": ["s337-g15", "s337-g16"]}, "s337-s9": {"text": "چو از کوه خورشید سر برکشید ز چشم مهان شاه شد ناپدید", "lines": ["s337-l17", "s337-l18"], "segs": ["s337-g17", "s337-g18"]}, "s337-s10": {"text": "ببودند ز آن جایگه شاه‌جوی به ریگ بیابان نهادند روی", "lines": ["s337-l19", "s337-l20"], "segs": ["s337-g19", "s337-g20"]}, "s337-s11": {"text": "ز خسرو ندیدند جایی نشان ز ره بازگشتند چون بیهشان", "lines": ["s337-l21", "s337-l22"], "segs": ["s337-g21", "s337-g22"]}, "s337-s12": {"text": "همه تنگ‌دل گشته و تافته سپرده زمین شاه نایافته", "lines": ["s337-l23", "s337-l24"], "segs": ["s337-g23", "s337-g24"]}, "s337-s13": {"text": "خروشان بدان چشمه بازآمدند پر از غم دل و با گداز آمدند", "lines": ["s337-l25", "s337-l26"], "segs": ["s337-g25", "s337-g26"]}, "s337-s14": {"text": "بر آن آب هر کس که آمد فرود همی داد شاه جهان را درود", "lines": ["s337-l27", "s337-l28"], "segs": ["s337-g27", "s337-g28"]}, "s337-s15": {"text": "فریبرز گفت آنچه خسرو بگفت که با جان پاکش خرد باد جفت", "lines": ["s337-l29", "s337-l30"], "segs": ["s337-g29", "s337-g30"]}, "s337-s16": {"text": "چو آسوده باشیم و چیزی خوریم یک امشب از این چشمه برنگذریم", "lines": ["s337-l31", "s337-l32"], "segs": ["s337-g31", "s337-g32"]}, "s337-s17": {"text": "زمین گرم و نرم است و روشن هوا بدین رنجگی نیست رفتن روا", "lines": ["s337-l33", "s337-l34"], "segs": ["s337-g33", "s337-g34"]}, "s337-s18": {"text": "بر آن چشمه یکسر فرود آمدند ز خسرو بسی داستانها زدند", "lines": ["s337-l35", "s337-l36"], "segs": ["s337-g35", "s337-g36"]}, "s337-s19": {"text": "که چونین شگفتی نبیند کسی وگر در زمانه بماند بسی", "lines": ["s337-l37", "s337-l38"], "segs": ["s337-g37", "s337-g38"]}, "s337-s20": {"text": "کز این رفتن شاه نادیده‌ایم ز گردنکشان نیز نشنیده‌ایم", "lines": ["s337-l39", "s337-l40"], "segs": ["s337-g39", "s337-g40"]}, "s337-s21": {"text": "دریغ آن بلند اختر و رای او بزرگی و دیدار و بالای او", "lines": ["s337-l41", "s337-l42"], "segs": ["s337-g41", "s337-g42"]}, "s337-s22": {"text": "خردمند از این کار خندان شود که زنده کسی پیش یزدان شود", "lines": ["s337-l43", "s337-l44"], "segs": ["s337-g43", "s337-g44"]}, "s337-s23": {"text": "که داند به گیتی که او را چه بود چه گوییم و گوش که یارد شنود", "lines": ["s337-l45", "s337-l46"], "segs": ["s337-g45", "s337-g46"]}, "s337-s24": {"text": "بدان نامداران چنین گفت گیو که هرگز چنین نشنود گوش نیو", "lines": ["s337-l47", "s337-l48"], "segs": ["s337-g47", "s337-g48"]}, "s337-s25": {"text": "به مردی و بخشش به داد و هنر به دیدار و بالا و فر و گهر", "lines": ["s337-l49", "s337-l50"], "segs": ["s337-g49", "s337-g50"]}, "s337-s26": {"text": "به رزم اندرون پیل بد با سپاه به بزم اندرون ماه بد با کلاه", "lines": ["s337-l51", "s337-l52"], "segs": ["s337-g51", "s337-g52"]}}, "segments": {"s337-g1": {"text": "چو بهری ز تیره شب اندر چمید", "sid": "s337-s1", "lines": ["s337-l1"]}, "s337-g2": {"text": "کی نامور پیش چشمه رسید", "sid": "s337-s1", "lines": ["s337-l2"]}, "s337-g3": {"text": "بر آن آب روشن سر و تن بشست", "sid": "s337-s2", "lines": ["s337-l3"]}, "s337-g4": {"text": "همی خواند اندر نهان زند و است", "sid": "s337-s2", "lines": ["s337-l4"]}, "s337-g5": {"text": "چنین گفت با نامور بخردان", "sid": "s337-s3", "lines": ["s337-l5"]}, "s337-g6": {"text": "که باشید پدرود تا جاودان", "sid": "s337-s3", "lines": ["s337-l6"]}, "s337-g7": {"text": "کنون چون برآرد سنان آفتاب", "sid": "s337-s4", "lines": ["s337-l7"]}, "s337-g8": {"text": "مبینید دیگر مرا جز به خواب", "sid": "s337-s4", "lines": ["s337-l8"]}, "s337-g9": {"text": "شما بازگردید ز این ریگ خشک", "sid": "s337-s5", "lines": ["s337-l9"]}, "s337-g10": {"text": "مباشید اگر بارد از ابر مشک", "sid": "s337-s5", "lines": ["s337-l10"]}, "s337-g11": {"text": "ز کوه اندر آید یکی باد سخت", "sid": "s337-s6", "lines": ["s337-l11"]}, "s337-g12": {"text": "کجا بشکند شاخ و برگ درخت", "sid": "s337-s6", "lines": ["s337-l12"]}, "s337-g13": {"text": "ببارد بسی برف ز ابر سیاه", "sid": "s337-s7", "lines": ["s337-l13"]}, "s337-g14": {"t