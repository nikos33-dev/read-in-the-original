  "sentences": {
    "s721-s1": {
      "text": "چوخراد برزین به خسرو رسید بگفت آن کجا کرد و دید و شنید",
      "lines": [
        "s721-l1",
        "s721-l2"
      ],
      "segs": [
        "s721-g1",
        "s721-g2"
      ]
    },
    "s721-s2": {
      "text": "دل شاه پرویز ازان شاد شد کزان بد گهر دشمن آزاد شد",
      "lines": [
        "s721-l3",
        "s721-l4"
      ],
      "segs": [
        "s721-g3",
        "s721-g4"
      ]
    },
    "s721-s3": {
      "text": "به درویش بخشید چندی درم ز پوشیدنیها و از بیش وکم",
      "lines": [
        "s721-l5",
        "s721-l6"
      ],
      "segs": [
        "s721-g5",
        "s721-g6"
      ]
    },
    "s721-s4": {
      "text": "بهر پادشاهی و خودکامه‌ای نوشتند بر پهلوی نامه‌ای",
      "lines": [
        "s721-l7",
        "s721-l8"
      ],
      "segs": [
        "s721-g7",
        "s721-g8"
      ]
    },
    "s721-s5": {
      "text": "که دارای دارنده یزدان چه کرد ز دشمن چگونه برآورد گرد",
      "lines": [
        "s721-l9",
        "s721-l10"
      ],
      "segs": [
        "s721-g9",
        "s721-g10"
      ]
    },
    "s721-s6": {
      "text": "به قیصر یکی نامه بنوشت شاه چناچون بود درخور پیشگاه",
      "lines": [
        "s721-l11",
        "s721-l12"
      ],
      "segs": [
        "s721-g11",
        "s721-g12"
      ]
    },
    "s721-s7": {
      "text": "به یک هفته مجلس بیاراستند بهر برزنی رود و می‌خواستند",
      "lines": [
        "s721-l13",
        "s721-l14"
      ],
      "segs": [
        "s721-g13",
        "s721-g14"
      ]
    },
    "s721-s8": {
      "text": "به آتشکده هم فرستاد چیز بران موبدان خلعت افگند نیز",
      "lines": [
        "s721-l15",
        "s721-l16"
      ],
      "segs": [
        "s721-g15",
        "s721-g16"
      ]
    },
    "s721-s9": {
      "text": "بخراد برزین چنین گفت شاه که زیبد تو راگر دهم تاج و گاه",
      "lines": [
        "s721-l17",
        "s721-l18"
      ],
      "segs": [
        "s721-g17",
        "s721-g18"
      ]
    },
    "s721-s10": {
      "text": "دهانش پر از گوهر شاهوار بیاگند و دینار چون صد هزار",
      "lines": [
        "s721-l19",
        "s721-l20"
      ],
      "segs": [
        "s721-g19",
        "s721-g20"
      ]
    },
    "s721-s11": {
      "text": "همی‌ریخت گنجور در پای اوی برین گونه تا تنگ شد جای اوی",
      "lines": [
        "s721-l21",
        "s721-l22"
      ],
      "segs": [
        "s721-g21",
        "s721-g22"
      ]
    },
    "s721-s12": {
      "text": "بدو گفت هرکس که پیچد ز راه شود روز روشن برو بر سیاه",
      "lines": [
        "s721-l23",
        "s721-l24"
      ],
      "segs": [
        "s721-g23",
        "s721-g24"
      ]
    },
    "s721-s13": {
      "text": "چو بهرام باشد به دشت نبرد کزو ترک پیرش برآورد گرد",
      "lines": [
        "s721-l25",
        "s721-l26"
      ],
      "segs": [
        "s721-g25",
        "s721-g26"
      ]
    },
    "s721-s14": {
      "text": "همه موبدان خواندند آفرین که بی تو مبیناد کهتر زمین",
      "lines": [
        "s721-l27",
        "s721-l28"
      ],
      "segs": [
        "s721-g27",
        "s721-g28"
      ]
    },
    "s721-s15": {
      "text": "چو بهرام باد آنک با مهر تو نخواهد که رخشان بود چهر تو",
      "lines": [
        "s721-l29",
        "s721-l30"
      ],
      "segs": [
        "s721-g29",
        "s721-g30"
      ]
    }
  },
