, "segs": ["s333-g15", "s333-g16"]}, "s333-s9": {"text": "جهاندار سیر آمد از تاج و گاه هم او چشم دارد به نیکی ز شاه", "lines": ["s333-l17", "s333-l18"], "segs": ["s333-g17", "s333-g18"]}, "s333-s10": {"text": "چنین داد پاسخ که بیش است از این که بر گیو بادا هزار آفرین", "lines": ["s333-l19", "s333-l20"], "segs": ["s333-g19", "s333-g20"]}, "s333-s11": {"text": "خداوند گیتی ورا یار باد دل بدسگالانش پرخار باد", "lines": ["s333-l21", "s333-l22"], "segs": ["s333-g21", "s333-g22"]}, "s333-s12": {"text": "کم و بیش ما پاک بر دست تست که روشن‌روان بادی و تن درست", "lines": ["s333-l23", "s333-l24"], "segs": ["s333-g23", "s333-g24"]}, "s333-s13": {"text": "بفرمود عهد قم و اصفهان نهاد بزرگان و جای مهان", "lines": ["s333-l25", "s333-l26"], "segs": ["s333-g25", "s333-g26"]}, "s333-s14": {"text": "نویسد ز مشک و ز عنبر دبیر یکی نامه از پادشا بر حریر", "lines": ["s333-l27", "s333-l28"], "segs": ["s333-g27", "s333-g28"]}, "s333-s15": {"text": "یکی مهر زرین بر او برنهاد بر آن نامه شاه آفرین کرد یاد", "lines": ["s333-l29", "s333-l30"], "segs": ["s333-g29", "s333-g30"]}, "s333-s16": {"text": "که یزدان ز گودرز خشنود باد دل بدسگالانش پر دود باد", "lines": ["s333-l31", "s333-l32"], "segs": ["s333-g31", "s333-g32"]}, "s333-s17": {"text": "به ایرانیان گفت گیو دلیر مبادا که آید ز کردار سیر", "lines": ["s333-l33", "s333-l34"], "segs": ["s333-g33", "s333-g34"]}, "s333-s18": {"text": "بدانید کو یادگار من است به نزد شما زینهار من است", "lines": ["s333-l35", "s333-l36"], "segs": ["s333-g35", "s333-g36"]}, "s333-s19": {"text": "مر او را همه پاک فرمان برید ز گفتار گودرز بر مگذرید", "lines": ["s333-l37", "s333-l38"], "segs": ["s333-g37", "s333-g38"]}, "s333-s20": {"text": "ز گودرزیان هرکه بد پیش‌رو یکی آفرینی بگسترد نو", "lines": ["s333-l39", "s333-l40"], "segs": ["s333-g39", "s333-g40"]}}, "segments": {"s333-g1": {"text": "جهاندیده گودرز برپای خاست", "sid": "s333-s1", "lines": ["s333-l1"]}, "s333-g2": {"text": "بیاراست با شاه گفتار راست", "sid": "s333-s1", "lines": ["s333-l2"]}, "s333-g3": {"text": "چ