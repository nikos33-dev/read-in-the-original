ace": "و", "lemma": "و", "pos": "NOUN", "seg": "s325-g40", "sid": "s325-s20"}, {"s": 16, "e": 19, "surface": "تخت", "lemma": "تخت", "pos": "NOUN", "seg": "s325-g40", "sid": "s325-s20"}, {"s": 20, "e": 21, "surface": "و", "lemma": "و", "pos": "NOUN", "seg": "s325-g40", "sid": "s325-s20"}, {"s": 22, "e": 25, "surface": "کمر", "lemma": "کمر", "pos": "NOUN", "seg": "s325-g40", "sid": "s325-s20"}]}}, "sentences": {"s325-s1": {"text": "چو بشنید خسرو ز دستان سخن یکی دانشی پاسخ افگند بن", "lines": ["s325-l1", "s325-l2"], "segs": ["s325-g1", "s325-g2"]}, "s325-s2": {"text": "بدو گفت کای پیر پاکیزه مغز همه رای و گفتارهای تو نغز", "lines": ["s325-l3", "s325-l4"], "segs": ["s325-g3", "s325-g4"]}, "s325-s3": {"text": "ز گاه منوچهر تا این زمان نه‌ای جز بی‌آزار و نیکی گمان", "lines": ["s325-l5", "s325-l6"], "segs": ["s325-g5", "s325-g6"]}, "s325-s4": {"text": "همان نامور رستم پیلتن ستون کیان نازش انجمن", "lines": ["s325-l7", "s325-l8"], "segs": ["s325-g7", "s325-g8"]}, "s325-s5": {"text": "سیاووش را پروراننده اوست بدو نیکویها رساننده اوست", "lines": ["s325-l9", "s325-l10"], "segs": ["s325-g9", "s325-g10"]}, "s325-s6": {"text": "سپاهی که دیدند گوپال او سر ترگ و برز و فر و یال او", "lines": ["s325-l11", "s325-l12"], "segs": ["s325-g11", "s325-g12"]}, "s325-s7": {"text": "بسی جنگ ناکرده بگریختند همه دشت تیر و کمان ریختند", "lines": ["s325-l13", "s325-l14"], "segs": ["s325-g13", "s325-g14"]}, "s325-s8": {"text": "به پیش نیاکان من کینه‌خواه چو دستور فرخ نماینده راه", "lines": ["s325-l15", "s325-l16"], "segs": ["s325-g15", "s325-g16"]}, "s325-s9": {"text": "وگر نام و رنج تو گیرم به یاد بماند سخن تازه تا صد نژاد", "lines": ["s325-l17", "s325-l18"], "segs": ["s325-g17", "s325-g18"]}, "s325-s10": {"text": "ز گفتار چرب ار پژوهش کنم ترا این ستایش نکوهش کنم", "lines": ["s325-l19", "s325-l20"], "segs": ["s325-g19", "s325-g20"]}, "s325-s11": {"text": "دگر هرچه پرسیدی از کار من ز نادادن بار و آزار من", "lines": ["s325-l21", "s325-l22"], "segs": ["s325-g21", "s325-g22"]}, "s325-s12": {"text": "به یزدان یکی آرزو داشتم جهان را همه خوار بگذاشتم", "lines": ["s325-l23", "s325-l24"], "segs": ["s325-g23", "s325-g24"]}, "s325-s13": {"text": "کنون پنج هفتست تا من به پای همی خواهم از داور رهنمای", "lines": ["s325-l25", "s325-l26"], "segs": ["s325-g25", "s325-g26"]}, "s325-s14": {"text": "که بخشد گذشته گناه مرا درخشان کند تیره گاه مرا", "lines": ["s325-l27", "s325-l28"], "segs": ["s325-g27", "s325-g28"]}, "s325-s15": {"text": "برد مر مرا ز این سپنجی سرای بود در همه نیکوی رهنمای", "lines": ["s325-l29", "s325-l30"], "segs": ["s325-g29", "s325-g30"]}, "s325-s16": {"text": "نماند کز این راستی بگذرم چو شاهان پیشین یپیچد سرم", "lines": ["s325-l31", "s325-l32"], "segs": ["s325-g31", "s325-g32"]}, "s325-s17": {"text": "کنون یافتم هرچه جستم ز کام بباید پسیچید کآمد خرام", "lines": ["s325-l33", "s325-l34"], "segs": ["s325-g33", "s325-g34"]}, "s325-s18": {"text": "سحرگه مرا چشم بغنود دوش ز یزدان بیامد خجسته سروش", "lines": ["s325-l35", "s325-l36"], "segs": ["s325-g35", "s325-g36"]}, "s325-s19": {"text": "که برساز کآمد گه رفتنت سرآمد نژندی و ناخفتنت", "lines": ["s325-l37", "s325-l38"], "segs": ["s325-g37", "s325-g38"]}, "s325-s20": {"text": "کنون بارگاه من آمد به سر غم لشکر و تاج و تخت و کمر", "lines": ["s325-l39", "s325-l40"], "segs": ["s325-g39", "s325-g40"]}}, "segments": {"s325-g1": {"text": "چو بشنید خسرو ز دستان سخن", "sid": "s325-s1", "lines": ["s325-l1"]}, "s325-g2": {"text": "یکی دانشی پاسخ افگند بن", "sid": "s325-s1", "lines": ["s325-l2"]}, "s325-g3": {"text": "بدو گفت کای پیر پاکیزه مغز", "sid": "s325-s2", "lines": ["s325-l3"]}, "s325-g4": {"text": "همه رای و گفتارهای تو نغز", "sid": "s325-s2", "lines": ["s325-l4"]}, "s325-g5": {"text": "ز گاه منوچهر تا این زمان", "sid": "s325-s3", "lines": ["s325-l5"]}, "s325-g6": {"text": "نه‌ای جز بی‌آزار و نیکی گمان", "sid": "s325-s3", "lines": ["s325-l6"]}, "s325-g7": {"text": "همان نامور رستم پیلتن", "sid": "s325-s4", "lines": ["s325-l7"]}, "s325-g8": {"text": "ستون کیان نازش انجمن", "sid": "s325-s4", "lines": ["s325-l8"]}, "s325-