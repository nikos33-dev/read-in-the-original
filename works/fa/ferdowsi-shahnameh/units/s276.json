, "sid": "s276-s14", "lines": ["s276-l27"]}, "s276-g28": {"text": "به نعره همی کوه را کرد پست", "sid": "s276-s14", "lines": ["s276-l28"]}, "s276-g29": {"text": "به پیروزی شاه ایران‌زمین", "sid": "s276-s15", "lines": ["s276-l29"]}, "s276-g30": {"text": "همی خواند بر پهلوان آفرین", "sid": "s276-s15", "lines": ["s276-l30"]}}}