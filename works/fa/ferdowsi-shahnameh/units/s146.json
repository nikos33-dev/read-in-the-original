}, {"s": 18, "e": 27, "surface": "پرده‌سرای", "lemma": "پرده‌سرا", "pos": "NOUN", "seg": "s146-g49", "sid": "s146-s25"}]}, "s146-l50": {"text": "نماند ایچ بر دشت و بر کوه جای", "sids": ["s146-s25"], "tokens": [{"s": 0, "e": 5, "surface": "نماند", "lemma": "ماند#مان", "pos": "NOUN", "seg": "s146-g50", "sid": "s146-s25"}, {"s": 6, "e": 9, "surface": "ایچ", "lemma": "ایچ", "pos": "NOUN", "seg": "s146-g50", "sid": "s146-s25"}, {"s": 10, "e": 12, "surface": "بر", "lemma": "بر", "pos": "NOUN", "seg": "s146-g50", "sid": "s146-s25"}, {"s": 13, "e": 16, "surface": "دشت", "lemma": "دشت", "pos": "NOUN", "seg": "s146-g50", "sid": "s146-s25"}, {"s": 17, "e": 18, "surface": "و", "lemma": "و", "pos": "NOUN", "seg": "s146-g50", "sid": "s146-s25"}, {"s": 19, "e": 21, "surface": "بر", "lemma": "بر", "pos": "NOUN", "seg": "s146-g50", "sid": "s146-s25"}, {"s": 22, "e": 25, "surface": "کوه", "lemma": "کوه", "pos": "NOUN", "seg": "s146-g50", "sid": "s146-s25"}, {"s": 26, "e": 29, "surface": "جای", "lemma": "جای", "pos": "NOUN", "seg": "s146-g50", "sid": "s146-s25"}]}}, "sentences": {"s146-s1": {"text": "دگر روز فرمود تا گیو و طوس ببستند شبگیر بر پیل کوس", "lines": ["s146-l1", "s146-l2"], "segs": ["s146-g1", "s146-g2"]}, "s146-s2": {"text": "در گنج بگشاد و روزی بداد سپه برنشاند و بنه برنهاد", "lines": ["s146-l3", "s146-l4"], "segs": ["s146-g3", "s146-g4"]}, "s146-s3": {"text": "سپردار و جوشنوران صد هزار شمرده به لشکر گه آمد سوار", "lines": ["s146-l5", "s146-l6"], "segs": ["s146-g5", "s146-g6"]}, "s146-s4": {"text": "یکی لشکر آمد ز پهلو به دشت که از گرد ایشان هوا تیره گشت", "lines": ["s146-l7", "s146-l8"], "segs": ["s146-g7", "s146-g8"]}, "s146-s5": {"text": "سراپرده و خیمه زد بر دو میل بپوشید گیتی به نعل و به پیل", "lines": ["s146-l9", "s146-l10"], "segs": ["s146-g9", "s146-g10"]}, "s146-s6": {"text": "هوا نیلگون گشت و کوه آبنوس بجوشید دریا ز آواز کوس", "lines": ["s146-l11", "s146-l12"], "segs": ["s146-g11", "s146-g12"]}, "s146-s7": {"text": "همی رفت منزل به منزل جهان شده چون شب و روز گشته نهان", "lines": ["s146-l13", "s146-l14"], "segs": ["s146-g13", "s146-g14"]}, "s146-s8": {"text": "درخشیدن خشت و ژوپین ز گرد چو آتش پس پرده لاجورد", "lines": ["s146-l15", "s146-l16"], "segs": ["s146-g15", "s146-g16"]}, "s146-s9": {"text": "ز بس گونه‌گونه سنان و درفش سپرهای زرین و زرینه کفش", "lines": ["s146-l17", "s146-l18"], "segs": ["s146-g17", "s146-g18"]}, "s146-s10": {"text": "تو گفتی که ابری به رنگ آبنوس برآمد ببارید زو سندروس", "lines": ["s146-l19", "s146-l20"], "segs": ["s146-g19", "s146-g20"]}, "s146-s11": {"text": "جهان را شب و روز پیدا نبود تو گفتی سپهر و ثریا نبود", "lines": ["s146-l21", "s146-l22"], "segs": ["s146-g21", "s146-g22"]}, "s146-s12": {"text": "ازینسان بشد تا در دژ رسید بشد خاک و سنگ از جهان ناپدید", "lines": ["s146-l23", "s146-l24"], "segs": ["s146-g23", "s146-g24"]}, "s146-s13": {"text": "خروشی بلند آمد از دیدگاه به سهراب گفتند کامد سپاه", "lines": ["s146-l25", "s146-l26"], "segs": ["s146-g25", "s146-g26"]}, "s146-s14": {"text": "چو سهراب زان دیده آوا شنید به باره بیامد سپه بنگرید", "lines": ["s146-l27", "s146-l28"], "segs": ["s146-g27", "s146-g28"]}, "s146-s15": {"text": "به انگشت لشکر به هومان نمود سپاهی که آن را کرانه نبود", "lines": ["s146-l29", "s146-l30"], "segs": ["s146-g29", "s146-g30"]}, "s146-s16": {"text": "چو هومان ز دور آن سپه را بدید دلش گشت پربیم و دم درکشید", "lines": ["s146-l31", "s146-l32"], "segs": ["s146-g31", "s146-g32"]}, "s146-s17": {"text": "به هومان چنین گفت سهراب گرد که اندیشه از دل بباید سترد", "lines": ["s146-l33", "s146-l34"], "segs": ["s146-g33", "s146-g34"]}, "s146-s18": {"text": "نبینی تو زین لشکر بیکران یکی مرد جنگی و گرزی گران", "lines": ["s146-l35", "s146-l36"], "segs": ["s146-g35", "s146-g36"]}, "s146-s19": {"text": "که پیش من آید به آوردگاه گر ایدون که یاری دهد هور و ماه", "lines": ["s146-l37", "s146-l38"], "segs": ["s146-g37", "s146-g38"]}, "s146-s20": {"text": "سلیح‌ست بسیار و مردم بسی سرافراز نامی ندانم کسی", "lines": ["s146-l39", "s146-l40"], "segs": ["s146-g39", "s146-g40"]}, "s146-s21": {"text": "