-s22"}, {"s": 15, "e": 17, "surface": "تا", "lemma": "تا", "pos": "NOUN", "seg": "s503-g43", "sid": "s503-s22"}, {"s": 18, "e": 25, "surface": "بی‌گروه", "lemma": "بی‌گروه", "pos": "NOUN", "seg": "s503-g43", "sid": "s503-s22"}]}, "s503-l44": {"text": "پیاده شود بر سر تیغ کوه", "sids": ["s503-s22"], "tokens": [{"s": 0, "e": 5, "surface": "پیاده", "lemma": "پیاده", "pos": "NOUN", "seg": "s503-g44", "sid": "s503-s22"}, {"s": 6, "e": 9, "surface": "شود", "lemma": "شد#شو", "pos": "NOUN", "seg": "s503-g44", "sid": "s503-s22"}, {"s": 10, "e": 12, "surface": "بر", "lemma": "بر", "pos": "NOUN", "seg": "s503-g44", "sid": "s503-s22"}, {"s": 13, "e": 15, "surface": "سر", "lemma": "سر", "pos": "NOUN", "seg": "s503-g44", "sid": "s503-s22"}, {"s": 16, "e": 19, "surface": "تیغ", "lemma": "تیغ", "pos": "NOUN", "seg": "s503-g44", "sid": "s503-s22"}, {"s": 20, "e": 23, "surface": "کوه", "lemma": "کوه", "pos": "NOUN", "seg": "s503-g44", "sid": "s503-s22"}]}, "s503-l45": {"text": "ببیند که تا بر سر کوه چیست", "sids": ["s503-s23"], "tokens": [{"s": 0, "e": 5, "surface": "ببیند", "lemma": "دید#بین", "pos": "NOUN", "seg": "s503-g45", "sid": "s503-s23"}, {"s": 6, "e": 8, "surface": "که", "lemma": "که", "pos": "NOUN", "seg": "s503-g45", "sid": "s503-s23"}, {"s": 9, "e": 11, "surface": "تا", "lemma": "تا", "pos": "NOUN", "seg": "s503-g45", "sid": "s503-s23"}, {"s": 12, "e": 14, "surface": "بر", "lemma": "بر", "pos": "NOUN", "seg": "s503-g45", "sid": "s503-s23"}, {"s": 15, "e": 17, "surface": "سر", "lemma": "سر", "pos": "NOUN", "seg": "s503-g45", "sid": "s503-s23"}, {"s": 18, "e": 21, "surface": "کوه", "lemma": "کوه", "pos": "NOUN", "seg": "s503-g45", "sid": "s503-s23"}, {"s": 22, "e": 24, "surface": "چی", "lemma": "چی", "pos": "NOUN", "seg": "s503-g45", "sid": "s503-s23"}, {"s": 24, "e": 26, "surface": "ست", "lemma": "ست", "pos": "NOUN", "seg": "s503-g45", "sid": "s503-s23"}]}, "s503-l46": {"text": "کزو شادمان را بباید گریست", "sids": ["s503-s23"], "tokens": [{"s": 0, "e": 3, "surface": "کزو", "lemma": "کزو", "pos": "NOUN", "seg": "s503-g46", "sid": "s503-s23"}, {"s": 4, "e": 10, "surface": "شادمان", "lemma": "شادمان", "pos": "NOUN", "seg": "s503-g46", "sid": "s503-s23"}, {"s": 11, "e": 13, "surface": "را", "lemma": "را", "pos": "NOUN", "seg": "s503-g46", "sid": "s503-s23"}, {"s": 14, "e": 19, "surface": "بباید", "lemma": "بایست#بای", "pos": "NOUN", "seg": "s503-g46", "sid": "s503-s23"}, {"s": 20, "e": 25, "surface": "گریست", "lemma": "گریست#گری", "pos": "NOUN", "seg": "s503-g46", "sid": "s503-s23"}]}}, "sentences": {"s503-s1": {"text": "سکندر سوی روشنایی رسید یکی بر شد کوه رخشنده دید", "lines": ["s503-l1", "s503-l2"], "segs": ["s503-g1", "s503-g2"]}, "s503-s2": {"text": "زده بر سر کوه خارا عمود سرش تا به ابر اندر از چوب عود", "lines": ["s503-l3", "s503-l4"], "segs": ["s503-g3", "s503-g4"]}, "s503-s3": {"text": "بر هر عمودی کنامی بزرگ نشسته برو سبز مرغی سترگ", "lines": ["s503-l5", "s503-l6"], "segs": ["s503-g5", "s503-g6"]}, "s503-s4": {"text": "به آواز رومی سخن راندند جهاندار پیروز را خواندند", "lines": ["s503-l7", "s503-l8"], "segs": ["s503-g7", "s503-g8"]}, "s503-s5": {"text": "چو آواز بشنید قیصر برفت به نزدیک مرغان خرامید تفت", "lines": ["s503-l9", "s503-l10"], "segs": ["s503-g9", "s503-g10"]}, "s503-s6": {"text": "بدو مرغ گفت ای دلارای رنج چه جویی همی زین سرای سپنج", "lines": ["s503-l11", "s503-l12"], "segs": ["s503-g11", "s503-g12"]}, "s503-s7": {"text": "اگر سر برآری به چرخ بلند همان بازگردی ازو مستمند", "lines": ["s503-l13", "s503-l14"], "segs": ["s503-g13", "s503-g14"]}, "s503-s8": {"text": "کنون کامدی هیچ دیدی زنا وگر کرده از خشت پخته بنا", "lines": ["s503-l15", "s503-l16"], "segs": ["s503-g15", "s503-g16"]}, "s503-s9": {"text": "چنین داد پاسخ کزین هر دو هست زنا و برین گونه جای نشست", "lines": ["s503-l17", "s503-l18"], "segs": ["s503-g17", "s503-g18"]}, "s503-s10": {"text": "چو بشنید پاسخ فروتر نشست درو خیره شد مرد یزدان‌پرست", "lines": ["s503-l19", "s503-l20"], "segs": ["s503-g19", "s503-g20"]}, "s503-s11": {"text": "بپرسید کاندر جهان بانگ رود شنیدی و آوای مست و سرود", "lines": ["s503-l21", "s503-l22"], "segs": ["s503-g21", "s503-g22"]}, "s503-s12": {"text": "چنین داد پاسخ که هر کو ز دهر ز شادی همی برنگیرند بهر", "lines": ["s503-l23", "s503-l24"], "segs": ["s503-g23", "s503-g24"]}, "s503-s13": {"text": "ورا شاد مردم نخواند همی وگر جان و دل برفشاند همی", "lines": ["s503-l25", "s503-l26"], "segs": ["s503-g25", "s503-g26"]}, "s503-s14": {"text": "به خاک آمد از بر شده چوب عمود تهی ماند زان مرغ رنگین عمود", "lines": ["s503-l27", "s503-l28"], "segs": ["s503-g27", "s503-g28"]}, "s503-s15": {"text": "بپرسید دانایی و راستی فزونست اگر کمی و کاستی", "lines": ["s503-l29", "s503-l30"], "segs": ["s503-g29", "s503-g30"]}, "s503-s16": {"text": "چنین داد پاسخ که دانش‌پژوه همی سرفرازد ز هر دو گروه", "lines": ["s503-l31", "s503-l32"], "segs": ["s503-g31", "s503-g32"]}, "s503-s17": {"text": "به سوی عمود آمد از تیره خاک به منقار چنگالها کرد پاک", "lines": ["s503-l33", "s503-l34"], "segs": ["s503-g33", "s503-g34"]}, "s503-s18": {"text": "ز قیصر بپرسید یزدان‌پرست به شهر تو بر کوه دارد نشست", "lines": ["s503-l35", "s503-l36"], "segs": ["s503-g35", "s503-g36"]}, "s503-s19": {"text": "بدو گفت چون مرد شد پاک‌رای بیابد پرستنده بر کوه جای", "lines": ["s503-l37", "s503-l38"], "segs": ["s503-g37", "s503-g38"]}, "s503-s20": {"text": "ازان چوب جوینده شد بر کنام جهانجوی روشن‌دل و شادکام", "lines": ["s503-l39", "s503-l40"], "segs": ["s503-g39", "s503-g40"]}, "s503-s21": {"text": "به چنگال می‌کرد منقار تیز چو ایمن شد از گردش رستخیز", "lines": ["s503-l41", "s503-l42"], "segs": ["s503-g41", "s503-g42"]}, "s503-s22": {"text": "به قیصر بفرمود تا بی‌گروه پیاده شود بر سر تیغ کوه", "lines": ["s503-l43", "s503-l44"], "segs": ["s503-g43", "s503-g44"]}, "s503-s23": {"text": "ببیند که تا بر سر کوه چیست کزو شادمان را بباید گریست", "lines": ["s503-l45", "s503-l46"], "segs": ["s503-g45", "s503-g46"]}}, "segments": {"s503-g1": {"text": "سکندر سوی روشنایی رسید", "sid": "s503-s1", "lines": ["s503-l1"]}, "s503-g2": {"text": "یکی بر شد کوه رخشنده دید", "sid