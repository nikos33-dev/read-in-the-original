: "s130-s21"}, {"s": 2, "e": 6, "surface": "خوبی", "lemma": "خوبی", "pos": "NOUN", "seg": "s130-g42", "sid": "s130-s21"}, {"s": 7, "e": 8, "surface": "و", "lemma": "و", "pos": "NOUN", "seg": "s130-g42", "sid": "s130-s21"}, {"s": 9, "e": 11, "surface": "از", "lemma": "از", "pos": "NOUN", "seg": "s130-g42", "sid": "s130-s21"}, {"s": 12, "e": 15, "surface": "داد", "lemma": "داد", "pos": "NOUN", "seg": "s130-g42", "sid": "s130-s21"}, {"s": 16, "e": 23, "surface": "آموزگار", "lemma": "آموزگار", "pos": "NOUN", "seg": "s130-g42", "sid": "s130-s21"}]}, "s130-l43": {"text": "به رنجش گرفتار دیوان بدند", "sids": ["s130-s22"], "tokens": [{"s": 0, "e": 2, "surface": "به", "lemma": "به", "pos": "NOUN", "seg": "s130-g43", "sid": "s130-s22"}, {"s": 3, "e": 7, "surface": "رنجش", "lemma": "رنجش", "pos": "NOUN", "seg": "s130-g43", "sid": "s130-s22"}, {"s": 8, "e": 14, "surface": "گرفتار", "lemma": "گرفتار", "pos": "NOUN", "seg": "s130-g43", "sid": "s130-s22"}, {"s": 15, "e": 20, "surface": "دیوان", "lemma": "دیوان", "pos": "NOUN", "seg": "s130-g43", "sid": "s130-s22"}, {"s": 21, "e": 25, "surface": "بدند", "lemma": "بدند", "pos": "NOUN", "seg": "s130-g43", "sid": "s130-s22"}]}, "s130-l44": {"text": "ز بادافره او غریوان بدند", "sids": ["s130-s22"], "tokens": [{"s": 0, "e": 1, "surface": "ز", "lemma": "ز", "pos": "NOUN", "seg": "s130-g44", "sid": "s130-s22"}, {"s": 2, "e": 9, "surface": "بادافره", "lemma": "بادافره", "pos": "NOUN", "seg": "s130-g44", "sid": "s130-s22"}, {"s": 10, "e": 12, "surface": "او", "lemma": "او", "pos": "NOUN", "seg": "s130-g44", "sid": "s130-s22"}, {"s": 13, "e": 19, "surface": "غریوان", "lemma": "غریوان", "pos": "NOUN", "seg": "s130-g44", "sid": "s130-s22"}, {"s": 20, "e": 24, "surface": "بدند", "lemma": "بدند", "pos": "NOUN", "seg": "s130-g44", "sid": "s130-s22"}]}}, "sentences": {"s130-s1": {"text": "بیامد سوی پارس کاووس کی جهانی به شادی نوافگند پی", "lines": ["s130-l1", "s130-l2"], "segs": ["s130-g1", "s130-g2"]}, "s130-s2": {"text": "بیاراست تخت و بگسترد داد به شادی و خوردن دل اندر نهاد", "lines": ["s130-l3", "s130-l4"], "segs": ["s130-g3", "s130-g4"]}, "s130-s3": {"text": "فرستاد هر سو یکی پهلوان جهاندار و بیدار و روشن‌روان", "lines": ["s130-l5", "s130-l6"], "segs": ["s130-g5", "s130-g6"]}, "s130-s4": {"text": "به مرو و نشاپور و بلخ و هری فرستاد بر هر سویی لشکری", "lines": ["s130-l7", "s130-l8"], "segs": ["s130-g7", "s130-g8"]}, "s130-s5": {"text": "جهانی پر از داد شد یکسره همی روی برتافت گرگ از بره", "lines": ["s130-l9", "s130-l10"], "segs": ["s130-g9", "s130-g10"]}, "s130-s6": {"text": "ز بس گنج و زیبایی و فرهی پری و دد و دام گشتش رهی", "lines": ["s130-l11", "s130-l12"], "segs": ["s130-g11", "s130-g12"]}, "s130-s7": {"text": "مهان پیش کاووس کهتر شدند همه تاجدارنش لشکر شدند", "lines": ["s130-l13", "s130-l14"], "segs": ["s130-g13", "s130-g14"]}, "s130-s8": {"text": "جهان پهلوانی به رستم سپرد همه روزگار بهی زو شمرد", "lines": ["s130-l15", "s130-l16"], "segs": ["s130-g15", "s130-g16"]}, "s130-s9": {"text": "یکی خانه کرد اندر البرز کوه که دیو اندران رنج‌ها شد ستوه", "lines": ["s130-l17", "s130-l18"], "segs": ["s130-g17", "s130-g18"]}, "s130-s10": {"text": "بفرمود کز سنگ خارا کنند دو خانه برو هر یکی ده کمند", "lines": ["s130-l19", "s130-l20"], "segs": ["s130-g19", "s130-g20"]}, "s130-s11": {"text": "بیاراست آخر به سنگ اندرون ز پولاد میخ و ز خارا ستون", "lines": ["s130-l21", "s130-l22"], "segs": ["s130-g21", "s130-g22"]}, "s130-s12": {"text": "ببستند اسپان جنگی بدوی هم اشتر عماری‌کش و راه جوی", "lines": ["s130-l23", "s130-l24"], "segs": ["s130-g23", "s130-g24"]}, "s130-s13": {"text": "دو خانه دگر ز آبگینه بساخت زبرجد به هر جایش اندر نشاخت", "lines": ["s130-l25", "s130-l26"], "segs": ["s130-g25", "s130-g26"]}, "s130-s14": {"text": "چنان ساخت جای خرام و خورش که تن یابد از خوردنی پرورش", "lines": ["s130-l27", "s130-l28"], "segs": ["s130-g27", "s130-g28"]}, "s130-s15": {"text": "دو خانه ز بهر سلیح نبرد بفرمو کز نقره خام کرد", "lines": ["s130-l29", "s130-l30"], "segs": ["s130-g29", "s130-g30"]}, "s130-s16": {"text": "یکی کاخ زرین ز بهر نشست برآورد و بالاش داده دو شست", "lines": ["s130-l31", "s130-l32"], "segs": ["s130-g31", "s130-g32"]}, "s130-s17": {"text": "نبودی تموز ایچ پیدا ز دی هوا عنبرین بود و بارانش می", "lines": ["s130-l33", "s130-l34"], "segs": ["s130-g33", "s130-g34"]}, "s130-s18": {"text": "به ایوانش یاقوت برده بکار ز پیروزه کرده برو بر نگار", "lines": ["s130-l35", "s130-l36"], "segs": ["s130-g35", "s130-g36"]}, "s130-s19": {"text": "همه‌ساله روشن بهاران بدی گلان چون رخ غمگساران بدی", "lines": ["s130-l37", "s130-l38"], "segs": ["s130-g37", "s130-g38"]}, "s130-s20": {"text": "ز درد و غم و رنج دل دور بود بدی را تن دیو رنجور بود", "lines": ["s130-l39", "s130-l40"], "segs": ["s130-g39", "s130-g40"]}, "s130-s21": {"text": "به خواب اندر آمد بد روزگار ز خوبی و از داد آموزگار", "lines": ["s130-l41", "s130-l42"], "segs": ["s130-g41", "s130-g42"]}, "s130-s22": {"text": "به رنجش گرفتار دیوان بدند ز بادافره او غریوان بدند", "lines": ["s130-l43", "s130-l44"], "segs": ["s130-g43", "s130-g44"]}}, "segments": {"s130-g1": {"text": "بیامد سوی پارس کاووس کی", "sid": "s130-s1", "lines": ["s130-l1"]}, "s130-g2": {"text": "جهانی به شادی نوافگند پی", "sid": "s130-s1", "lines": ["s130-l2"]}, "s130-g3": {"text": "بیاراست تخت و بگسترد داد", "sid": "s130-s2", "lines": ["s130-l3"]}, "s130-g4": {"text": "به شادی و خوردن دل اندر نهاد", "sid": "s130-s2", "lines": ["s130-l4"]}, "s130-g5": {"text": "فرستاد هر سو یکی پهلوان", "sid": "s130-s3", "lines": ["s130-l5"]}, "s130-g6": {"text": "جهاندار و بیدار و روشن‌روان", "sid": "s130-s3", "lines": ["s130-l6"]}, "s130-g7": {"text": "به مرو و نشاپور و بلخ و هری", "sid": "s130-s4", "lines": ["s130-l7"]}, "s130-g8": {"text": "فرستاد بر هر سویی لشکری", "sid": "s130-s4", "lines": ["s130-l8"]}, "s130-g9": {"text": "جهانی پر از داد شد یکسره", "sid": "s130-s5", "lines": ["s130-l9"]}, "s130-g10": {"text": "همی روی برتافت گرگ از بره", "sid": "s130-s5", "lines": ["s130-l10"]}, "s130-g11": {"text": "ز بس گنج و زیبایی و فرهی", "sid": "s130-s6", "lines": ["s130-l11"]}, "s130-g12