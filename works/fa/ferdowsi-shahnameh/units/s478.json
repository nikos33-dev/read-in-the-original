8"}, {"s": 21, "e": 23, "surface": "به", "lemma": "به", "pos": "NOUN", "seg": "s478-g56", "sid": "s478-s28"}, {"s": 24, "e": 27, "surface": "جای", "lemma": "جای", "pos": "NOUN", "seg": "s478-g56", "sid": "s478-s28"}]}}, "sentences": {"s478-s1": {"text": "فرستاده آمد به کردار باد بگفت آنچ بشنید و نامه بداد", "lines": ["s478-l1", "s478-l2"], "segs": ["s478-g1", "s478-g2"]}, "s478-s2": {"text": "سکندر فرستاده از گفت رو به نزدیک آن نامور بازشو", "lines": ["s478-l3", "s478-l4"], "segs": ["s478-g3", "s478-g4"]}, "s478-s3": {"text": "بگویش که آن چیست کاندر جهان کسی را نبود آشکار و نهان", "lines": ["s478-l5", "s478-l6"], "segs": ["s478-g5", "s478-g6"]}, "s478-s4": {"text": "بدیدند خود بودنی هرچ بود سپهر آفرینش نخواهد فزود", "lines": ["s478-l7", "s478-l8"], "segs": ["s478-g7", "s478-g8"]}, "s478-s5": {"text": "بیامد فرستاده را نزد شاه به کردار آتش بپیمود راه", "lines": ["s478-l9", "s478-l10"], "segs": ["s478-g9", "s478-g10"]}, "s478-s6": {"text": "چنین گفت با کید کاین چار چیز که کس را به گیتی نبودست نیز", "lines": ["s478-l11", "s478-l12"], "segs": ["s478-g11", "s478-g12"]}, "s478-s7": {"text": "همی شاه خواهد که داند که چیست که نادیدنی پاک نابود نیست", "lines": ["s478-l13", "s478-l14"], "segs": ["s478-g13", "s478-g14"]}, "s478-s8": {"text": "چو بشنید کید آن ز بیگانه جای بپردخت و بنشست با رهنمای", "lines": ["s478-l15", "s478-l16"], "segs": ["s478-g15", "s478-g16"]}, "s478-s9": {"text": "فرستاده را پیش بنشاختند ز هر در فراوانش بنواختند", "lines": ["s478-l17", "s478-l18"], "segs": ["s478-g17", "s478-g18"]}, "s478-s10": {"text": "ازان پس فرستاده را شاه گفت که من دختری دارم اندر نهفت", "lines": ["s478-l19", "s478-l20"], "segs": ["s478-g19", "s478-g20"]}, "s478-s11": {"text": "که‌گر بیندش آفتاب بلند شود تیره از روی آن ارجمند", "lines": ["s478-l21", "s478-l22"], "segs": ["s478-g21", "s478-g22"]}, "s478-s12": {"text": "کمندست گیسوش همرنگ قیر همی آید از دو لبش بوی شیر", "lines": ["s478-l23", "s478-l24"], "segs": ["s478-g23", "s478-g24"]}, "s478-s13": {"text": "خم آرد ز بالای او سرو بن گلفشان شود چو سراید سخن", "lines": ["s478-l25", "s478-l26"], "segs": ["s478-g25", "s478-g26"]}, "s478-s14": {"text": "ز دیدار و چهرش سخن بگذرد همی داستان را خرد پرورد", "lines": ["s478-l27", "s478-l28"], "segs": ["s478-g27", "s478-g28"]}, "s478-s15": {"text": "چو خامش بود جان شرمست و بس چنو در زمانه ندیدست کس", "lines": ["s478-l29", "s478-l30"], "segs": ["s478-g29", "s478-g30"]}, "s478-s16": {"text": "سپهبد نژادست و یزدان‌پرست دل شرم و پرهیز دارد به دست", "lines": ["s478-l31", "s478-l32"], "segs": ["s478-g31", "s478-g32"]}, "s478-s17": {"text": "دگر جام دارم که پر می‌کنی وگر آب سر اندرو افگنی", "lines": ["s478-l33", "s478-l34"], "segs": ["s478-g33", "s478-g34"]}, "s478-s18": {"text": "به ده سال اگر با ندیمان به هم نشیند نگردد می‌از جام کم", "lines": ["s478-l35", "s478-l36"], "segs": ["s478-g35", "s478-g36"]}, "s478-s19": {"text": "همت می‌دهد جام هم آب سرد شگفت آنک کمی نگیرد ز خورد", "lines": ["s478-l37", "s478-l38"], "segs": ["s478-g37", "s478-g38"]}, "s478-s20": {"text": "سوم آنک دارم یکی نو پزشک که علت بگوید چو بیند سرشک", "lines": ["s478-l39", "s478-l40"], "segs": ["s478-g39", "s478-g40"]}, "s478-s21": {"text": "اگر باشد او سالیان پیش گاه ز دردی نپیچد جهاندار شاه", "lines": ["s478-l41", "s478-l42"], "segs": ["s478-g41", "s478-g42"]}, "s478-s22": {"text": "چهارم نهان دارم از انجمن یکی فیلسوفست نزدیک من", "lines": ["s478-l43", "s478-l44"], "segs": ["s478-g43", "s478-g44"]}, "s478-s23": {"text": "همه بودنیها بگوید به شاه ز گردنده خورشید و رخشنده ماه", "lines": ["s478-l45", "s478-l46"], "segs": ["s478-g45", "s478-g46"]}, "s478-s24": {"text": "فرستاده نامور بازگشت پی باره با باد انباز گشت", "lines": ["s478-l47", "s478-l48"], "segs": ["s478-g47", "s478-g48"]}, "s478-s25": {"text": "بیامد چو پیش سکندر بگفت دل شاه گیتی چو گل بر شگفت", "lines": ["s478-l49", "s478-l50"], "segs": ["s478-g49", "s478-g50"]}, "s478-s26": {"text": "بدو گفت اگر باشد این گفته راست بدین چار چیز او جهان را بهاست", "lines": ["s478-l51", "s478-l52"], "segs": ["s478-g51", "s478-g52"]}, "s478-s27": {"