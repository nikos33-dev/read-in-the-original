  "sentences": {
    "s550-s1": {
      "text": "الا‌ای خریدار مغز سخن دلت برگسل زین سرای کهن",
      "lines": [
        "s550-l1",
        "s550-l2"
      ],
      "segs": [
        "s550-g1",
        "s550-g2"
      ]
    },
    "s550-s2": {
      "text": "کجا چون من و چون تو بسیار دید نخواهد همی با کسی آرمید",
      "lines": [
        "s550-l3",
        "s550-l4"
      ],
      "segs": [
        "s550-g3",
        "s550-g4"
      ]
    },
    "s550-s3": {
      "text": "اگر شهریاری و‌گر پیشکار تو ناپایداری و او پایدار",
      "lines": [
        "s550-l5",
        "s550-l6"
      ],
      "segs": [
        "s550-g5",
        "s550-g6"
      ]
    },
    "s550-s4": {
      "text": "چه با رنج باشی چه با تاج و تخت ببایدت بستن به فرجام رخت",
      "lines": [
        "s550-l7",
        "s550-l8"
      ],
      "segs": [
        "s550-g7",
        "s550-g8"
      ]
    },
    "s550-s5": {
      "text": "اگر ز آهنی چرخ بگدازدت چو گشتی کهن نیز ننوازدت",
      "lines": [
        "s550-l9",
        "s550-l10"
      ],
      "segs": [
        "s550-g9",
        "s550-g10"
      ]
    },
    "s550-s6": {
      "text": "چو سرو دلارای گردد به خم خروشان شود نرگسان دژم",
      "lines": [
        "s550-l11",
        "s550-l12"
      ],
      "segs": [
        "s550-g11",
        "s550-g12"
      ]
    },
    "s550-s7": {
      "text": "همان چهره ارغوان زعفران سبک مردم شاد گردد گران",
      "lines": [
        "s550-l13",
        "s550-l14"
      ],
      "segs": [
        "s550-g13",
        "s550-g14"
      ]
    },
    "s550-s8": {
      "text": "اگر شهریاری و‌گر زیردست بجز خاک تیره نیابی نشست",
      "lines": [
        "s550-l15",
        "s550-l16"
      ],
      "segs": [
        "s550-g15",
        "s550-g16"
      ]
    },
    "s550-s9": {
      "text": "کجا آن بزرگان با تاج و تخت کجا آن سواران پیروزبخت",
      "lines": [
        "s550-l17",
        "s550-l18"
      ],
      "segs": [
        "s550-g17",
        "s550-g18"
      ]
    },
    "s550-s10": {
      "text": "کجا آن خردمند کندآوران کجا آن سرافراز و جنگی سران",
      "lines": [
        "s550-l19",
        "s550-l20"
      ],
      "segs": [
        "s550-g19",
        "s550-g20"
      ]
    },
    "s550-s11": {
      "text": "کجا آن گزیده نیاکان ما کجا آن دلیران و پاکان ما",
      "lines": [
        "s550-l21",
        "s550-l22"
      ],
      "segs": [
        "s550-g21",
        "s550-g22"
      ]
    },
    "s550-s12": {
      "text": "همه خاک دارند بالین و خشت خنک آنک جز تخم نیکی نکشت",
      "lines": [
        "s550-l23",
        "s550-l24"
      ],
      "segs": [
        "s550-g23",
        "s550-g24"
      ]
    },
    "s550-s13": {
      "text": "نشان بس بود شهریار اردشیر چو از من سخن بشنوی یادگیر",
      "lines": [
        "s550-l25",
        "s550-l26"
      ],
      "segs": [
        "s550-g25",
        "s550-g26"
      ]
    }
  },
