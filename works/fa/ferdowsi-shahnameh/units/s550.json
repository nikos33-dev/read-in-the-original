    },
    "s550-g9": {
      "text": "اگر ز آهنی چرخ بگدازدت",
      "sid": "s550-s5",
      "lines": [
        "s550-l9"
      ]
    },
    "s550-g10": {
      "text": "چو گشتی کهن نیز ننوازدت",
      "sid": "s550-s5",
      "lines": [
        "s550-l10"
      ]
    },
    "s550-g11": {
      "text": "چو سرو دلارای گردد به خم",
      "sid": "s550-s6",
      "lines": [
        "s550-l11"
      ]
    },
    "s550-g12": {
      "text": "خروشان شود نرگسان دژم",
      "sid": "s550-s6",
      "lines": [
        "s550-l12"
      ]
    },
    "s550-g13": {
      "text": "همان چهره ارغوان زعفران",
      "sid": "s550-s7",
      "lines": [
        "s550-l13"
      ]
    },
    "s550-g14": {
      "text": "سبک مردم شاد گردد گران",
      "sid": "s550-s7",
      "lines": [
        "s550-l14"
      ]
    },
    "s550-g15": {
      "text": "اگر شهریاری و‌گر زیردست",
      "sid": "s550-s8",
      "lines": [
        "s550-l15"
      ]
    },
    "s550-g16": {
      "text": "بجز خاک تیره نیابی نشست",
      "sid": "s550-s8",
      "lines": [
        "s550-l16"
      ]
    },
    "s550-g17": {
      "text": "کجا آن بزرگان با تاج و تخت",
      "sid": "s550-s9",
      "lines": [
        "s550-l17"
      ]
    },
    "s550-g18": {
      "text": "کجا آن سواران پیروزبخت",
      "sid": "s550-s9",
      "lines": [
        "s550-l18"
      ]
    },
    "s550-g19": {
      "text": "کجا آن خردمند کندآوران",
      "sid": "s550-s10",
      "lines": [
        "s550-l19"
      ]
    },
    "s550-g20": {
      "text": "کجا آن سرافراز و جنگی سران",
      "sid": "s550-s10",
      "lines": [
        "s550-l20"
      ]
    },
    "s550-g21": {
      "text": "کجا آن گزیده نیاکان ما",
      "sid": "s550-s11",
      "lines": [
        "s550-l21"
      ]
    },
    "s550-g22": {
      "text": "کجا آن دلیران و پاکان ما",
      "sid": "s550-s11",
      "lines": [
        "s550-l22"
      ]
    },
    "s550-g23": {
      "text": "همه خاک دارند بالین و خشت",
      "sid": "s550-s12",
      "lines": [
        "s550-l23"
      ]
    },
    "s550-g24": {
      "text": "خنک آنک جز تخم نیکی نکشت",
      "sid": "s550-s12",
      "lines": [
        "s550-l24"
      ]
    },
    "s550-g25": {
      "text": "نشان بس بود شهریار اردشیر",
      "sid": "s550-s13",
      "lines": [
        "s550-l25"
      ]
    },
    "s550-g26": {
      "text": "چو از من سخن بشنوی یادگیر",
      "sid": "s550-s13",
      "lines": [
        "s550-l26"
      ]
    }
  }
}