-g32", "sid": "s011-s16"}]}}, "sentences": {"s011-s1": {"text": "بدین نامه چون دست کردم دراز یکی مهتری بود گردن‌فراز", "lines": ["s011-l1", "s011-l2"], "segs": ["s011-g1", "s011-g2"]}, "s011-s2": {"text": "جوان بود و از گوهر پهلوان خردمند و بیدار و روشن‌روان", "lines": ["s011-l3", "s011-l4"], "segs": ["s011-g3", "s011-g4"]}, "s011-s3": {"text": "خداوند رای و خداوند شرم سخن گفتن خوب و آوای نرم", "lines": ["s011-l5", "s011-l6"], "segs": ["s011-g5", "s011-g6"]}, "s011-s4": {"text": "مرا گفت کز من چه باید همی که جانت سخن برگراید همی", "lines": ["s011-l7", "s011-l8"], "segs": ["s011-g7", "s011-g8"]}, "s011-s5": {"text": "به چیزی که باشد مرا دسترس بکوشم نیازت نیارم به کس", "lines": ["s011-l9", "s011-l10"], "segs": ["s011-g9", "s011-g10"]}, "s011-s6": {"text": "همی داشتم چون یکی تازه سیب که از باد نامد به من بر نهیب", "lines": ["s011-l11", "s011-l12"], "segs": ["s011-g11", "s011-g12"]}, "s011-s7": {"text": "به کیوان رسیدم ز خاک نژند از آن نیک‌دل نامدار ارجمند", "lines": ["s011-l13", "s011-l14"], "segs": ["s011-g13", "s011-g14"]}, "s011-s8": {"text": "به چشمش همان خاک و هم سیم و زر کریمی بدو یافته زیب و فر", "lines": ["s011-l15", "s011-l16"], "segs": ["s011-g15", "s011-g16"]}, "s011-s9": {"text": "سراسر جهان پیش او خوار بود جوانمرد بود و وفادار بود", "lines": ["s011-l17", "s011-l18"], "segs": ["s011-g17", "s011-g18"]}, "s011-s10": {"text": "چنان نامور گم شد از انجمن چو در باغ سرو سهی از چمن", "lines": ["s011-l19", "s011-l20"], "segs": ["s011-g19", "s011-g20"]}, "s011-s11": {"text": "نه ز او زنده بینم نه مرده نشان به دست نهنگان مردم کشان", "lines": ["s011-l21", "s011-l22"], "segs": ["s011-g21", "s011-g22"]}, "s011-s12": {"text": "دریغ آن کمربند و آن گردگاه دریغ آن کیی برز و بالای شاه", "lines": ["s011-l23", "s011-l24"], "segs": ["s011-g23", "s011-g24"]}, "s011-s13": {"text": "گرفتار ز او دل‌شده نا‌امید نوان لرز لرزان به کردار بید", "lines": ["s011-l25", "s011-l26"], "segs": ["s011-g25", "s011-g26"]}, "s011-s14": {"text": "یکی پند آن شاه یاد آوریم ز کژی روان سوی داد آوریم", "lines": ["s011-l27", "s011-l28"], "segs": ["s011-g27", "s011-g28"]}, "s011-s15": {"text": "مرا گفت کاین نامه شهریار گرت گفته آید به شاهان سپار", "lines": ["s011-l29", "s011-l30"], "segs": ["s011-g29", "s011-g30"]}, "s011-s16": {"text": "بدین نامه من دست بردم فراز به نام شهنشاه گردن‌فراز", "lines": ["s011-l31", "s011-l32"], "segs": ["s011-g31", "s011-g32"]}}, "segments": {"s011-g1": {"text": "بدین نامه چون دست کردم دراز", "sid": "s011-s1", "lines": ["s011-l1"]}, "s011-g2": {"text": "یکی مهتری بود گردن‌فراز", "sid": "s011-s1", "lines": ["s011-l2"]}, "s011-g3": {"text": "جوان بود و از گوهر پهلوان", "sid": "s011-s2", "lines": ["s011-l3"]}, "s011-g4": {"text": "خردمند و بیدار و روشن‌روان", "sid": "s011-s2", "lines": ["s011-l4"]}, "s011-g5": {"text": "خداوند رای و خداوند شرم", "sid": "s011-s3", "lines": ["s011-l5"]}, "s011-g6": {"text": "سخن گفتن خوب و آوای نرم", "sid": "s011-s3", "lines": ["s011-l6"]}, "s011-g7": {"text": "مرا گفت کز من چه باید همی", "sid": "s011-s4", "lines": ["s011-l7"]}, "s011-g8": {"text": "که جانت سخن برگراید همی", "sid": "s011-s4", "lines": ["s011-l8"]}, "s011-g9": {"text": "به چیزی که باشد مرا دسترس", "sid": "s011-s5", "lines": ["s011-l9"]}, "s011-g10": {"text": "بکوشم نیازت نیارم به کس", "sid": "s011-s5", "lines": ["s011-l10"]}, "s011-g11": {"text": "همی داشتم چون یکی تازه سیب", "sid": "s011-s6", "lines": ["s011-l11"]}, "s011-g12": {"text": "که از باد نامد به من بر نهیب", "sid": "s011-s6", "lines": ["s011-l12"]}, "s011-g13": {"text": "به کیوان رسیدم ز خاک نژند", "sid": "s011-s7", "lines": ["s011-l13"]}, "s011-g14": {"text": "از آن نیک‌دل نامدار ارجمند", "sid": "s011-s7", "lines": ["s011-l14"]}, "s011-g15": {"text": "به چشمش همان خاک و هم سیم و زر", "sid": "s011-s8", "lines": ["s011-l15"]}, "s011-g16": {"text": "کریمی بدو یافته زیب و فر", "sid": "s011-s8", "lines": ["s011-l16"]}, "s011-g17": {"text": "سراسر جهان پیش او خوار بود", "sid": "s011-s9", "lines": ["s011-l17"]}, "s011-g18": {"text": "جوانمرد بود و وفادار بود", "sid": "s011-s9", "lines": [