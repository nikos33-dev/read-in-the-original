, {"s": 15, "e": 17, "surface": "او", "lemma": "او", "pos": "NOUN", "seg": "s138-g36", "sid": "s138-s18"}, {"s": 18, "e": 20, "surface": "بر", "lemma": "بر", "pos": "NOUN", "seg": "s138-g36", "sid": "s138-s18"}, {"s": 21, "e": 23, "surface": "به", "lemma": "به", "pos": "NOUN", "seg": "s138-g36", "sid": "s138-s18"}, {"s": 24, "e": 27, "surface": "پای", "lemma": "پای", "pos": "NOUN", "seg": "s138-g36", "sid": "s138-s18"}]}, "s138-l37": {"text": "ز شهر و ز لشکر مهانرا بخواند", "sids": ["s138-s19"], "tokens": [{"s": 0, "e": 1, "surface": "ز", "lemma": "ز", "pos": "NOUN", "seg": "s138-g37", "sid": "s138-s19"}, {"s": 2, "e": 5, "surface": "شهر", "lemma": "شهر", "pos": "NOUN", "seg": "s138-g37", "sid": "s138-s19"}, {"s": 6, "e": 7, "surface": "و", "lemma": "و", "pos": "NOUN", "seg": "s138-g37", "sid": "s138-s19"}, {"s": 8, "e": 9, "surface": "ز", "lemma": "ز", "pos": "NOUN", "seg": "s138-g37", "sid": "s138-s19"}, {"s": 10, "e": 14, "surface": "لشکر", "lemma": "لشکر", "pos": "NOUN", "seg": "s138-g37", "sid": "s138-s19"}, {"s": 15, "e": 21, "surface": "مهانرا", "lemma": "مهانرا", "pos": "NOUN", "seg": "s138-g37", "sid": "s138-s19"}, {"s": 22, "e": 28, "surface": "بخواند", "lemma": "خواند#خوان", "pos": "NOUN", "seg": "s138-g37", "sid": "s138-s19"}]}, "s138-l38": {"text": "سزاوار با او به شادی نشاند", "sids": ["s138-s19"], "tokens": [{"s": 0, "e": 6, "surface": "سزاوار", "lemma": "سزاوار", "pos": "NOUN", "seg": "s138-g38", "sid": "s138-s19"}, {"s": 7, "e": 9, "surface": "با", "lemma": "با", "pos": "NOUN", "seg": "s138-g38", "sid": "s138-s19"}, {"s": 10, "e": 12, "surface": "او", "lemma": "او", "pos": "NOUN", "seg": "s138-g38", "sid": "s138-s19"}, {"s": 13, "e": 15, "surface": "به", "lemma": "به", "pos": "NOUN", "seg": "s138-g38", "sid": "s138-s19"}, {"s": 16, "e": 20, "surface": "شادی", "lemma": "شادی", "pos": "NOUN", "seg": "s138-g38", "sid": "s138-s19"}, {"s": 21, "e": 26, "surface": "نشاند", "lemma": "نشاست#نشا", "pos": "NOUN", "seg": "s138-g38", "sid": "s138-s19"}]}, "s138