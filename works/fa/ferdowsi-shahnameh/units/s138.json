g": "s138-g44", "sid": "s138-s22"}]}, "s138-l45": {"text": "سزاوار او جای آرام و خواب", "sids": ["s138-s23"], "tokens": [{"s": 0, "e": 6, "surface": "سزاوار", "lemma": "سزاوار", "pos": "NOUN", "seg": "s138-g45", "sid": "s138-s23"}, {"s": 7, "e": 9, "surface": "او", "lemma": "او", "pos": "NOUN", "seg": "s138-g45", "sid": "s138-s23"}, {"s": 10, "e": 13, "surface": "جای", "lemma": "جای", "pos": "NOUN", "seg": "s138-g45", "sid": "s138-s23"}, {"s": 14, "e": 18, "surface": "آرام", "lemma": "آرام", "pos": "NOUN", "seg": "s138-g45", "sid": "s138-s23"}, {"s": 19, "e": 20, "surface": "و", "lemma": "و", "pos": "NOUN", "seg": "s138-g45", "sid": "s138-s23"}, {"s": 21, "e": 25, "surface": "خواب", "lemma": "خواب", "pos": "NOUN", "seg": "s138-g45", "sid": "s138-s23"}]}, "s138-l46": {"text": "بیاراست و بنهاد مشک و گلاب", "sids": ["s138-s23"], "tokens": [{"s": 0, "e": 7, "surface": "بیاراست", "lemma": "بیاراست", "pos": "NOUN", "seg": "s138-g46", "sid": "s138-s23"}, {"s": 8, "e": 9, "surface": "و", "lemma": "و", "pos": "NOUN", "seg": "s138-g46", "sid": "s138-s23"}, {"s": 10, "e": 15, "surface": "بنهاد", "lemma": "بنهاد", "pos": "NOUN", "seg": "s138-g46", "sid": "s138-s23"}, {"s": 16, "e": 19, "surface": "مشک", "lemma": "مشک", "pos": "NOUN", "seg": "s138-g46", "sid": "s138-s23"}, {"s": 20, "e": 21, "surface": "و", "lemma": "و", "pos": "NOUN", "seg": "s138-g46", "sid": "s138-s23"}, {"s": 22, "e": 26, "surface": "گلاب", "lemma": "گلاب", "pos": "NOUN", "seg": "s138-g46", "sid": "s138-s23"}]}}, "sentences": {"s138-s1": {"text": "چو نزدیک شهر سمنگان رسید خبر زو بشاه و بزرگان رسید", "lines": ["s138-l1", "s138-l2"], "segs": ["s138-g1", "s138-g2"]}, "s138-s2": {"text": "که آمد پیاده گو تاج‌بخش به نخچیرگه زو رمیدست رخش", "lines": ["s138-l3", "s138-l4"], "segs": ["s138-g3", "s138-g4"]}, "s138-s3": {"text": "پذیره شدندش بزرگان و شاه کسی کاو بسر بر نهادی کلاه", "lines": ["s138-l5", "s138-l6"], "segs": ["s138-g5", "s138-g6"]}, "s138-s4": {"text": "بدو گفت شاه سمنگان چه بود که یارست با تو نبرد آزمود", "lines": ["s138-l7", "s138-l8"], "segs": ["s138-g7", "s138-g8"]}, "s138-s5": {"text": "درین شهر ما نیکخواه توایم ستاده بفرمان و راه توایم", "lines": ["s138-l9", "s138-l10"], "segs": ["s138-g9", "s138-g10"]}, "s138-s6": {"text": "تن و خواسته زیر فرمان تست سر ارجمندان و جان آن تست", "lines": ["s138-l11", "s138-l12"], "segs": ["s138-g11", "s138-g12"]}, "s138-s7": {"text": "چو رستم به گفتار او بنگرید ز بدها گمانیش کوتاه دید", "lines": ["s138-l13", "s138-l14"], "segs": ["s138-g13", "s138-g14"]}, "s138-s8": {"text": "بدو گفت رخشم بدین مرغزار ز من دور شد بی‌لگام و فسار", "lines": ["s138-l15", "s138-l16"], "segs": ["s138-g15", "s138-g16"]}, "s138-s9": {"text": "کنون تا سمنگان نشان پی است وز آنجا کجا جویبار و نی است", "lines": ["s138-l17", "s138-l18"], "segs": ["s138-g17", "s138-g18"]}, "s138-s10": {"text": "ترا باشد ار بازجویی سپاس بباشم بپاداش نیکی شناس", "lines": ["s138-l19", "s138-l20"], "segs": ["s138-g19", "s138-g20"]}, "s138-s11": {"text": "گر ایدون که ماند ز من ناپدید سران را بسی سر بباید برید", "lines": ["s138-l21", "s138-l22"], "segs": ["s138-g21", "s138-g22"]}, "s138-s12": {"text": "بدو گفت شاه‌ای سزاوار مرد نیارد کسی با تو این کار کرد", "lines": ["s138-l23", "s138-l24"], "segs": ["s138-g23", "s138-g24"]}, "s138-s13": {"text": "تو مهمان من باش و تندی مکن به کام تو گردد سراسر سخن", "lines": ["s138-l25", "s138-l26"], "segs": ["s138-g25", "s138-g26"]}, "s138-s14": {"text": "یک امشب به می‌شاد داریم دل وز اندیشه آزاد داریم دل", "lines": ["s138-l27", "s138-l28"], "segs": ["s138-g27", "s138-g28"]}, "s138-s15": {"text": "نماند پی رخش فرخ نهان چنان باره نامدار جهان", "lines": ["s138-l29", "s138-l30"], "segs": ["s138-g29", "s138-g30"]}, "s138-s16": {"text": "تهمتن به گفتار او شاد شد روانش ز اندیشه آزاد شد", "lines": ["s138-l31", "s138-l32"], "segs": ["s138-g31", "s138-g32"]}, "s138-s17": {"text": "سزا دید رفتن سوی خان او شد از مژده دلشاد مهمان او", "lines": ["s138-l33", "s138-l34"], "segs": ["s138-g33", "s138-g34"]}, "s138-s18": {"text": "سپهبد بدو داد در کاخ جای همی بود در پیش او بر به پای", "lines": ["s138-l35", "s138-l36"], "segs": ["s138-g35", "s138-g36"]}, "s138-s19": {"text": "ز شهر و ز لشکر مهانرا بخواند سزاوار با او به شادی نشاند", "lines": ["s138-l37", "s138-l38"], "segs": ["s138-g37", "s138-g38"]}, "s138-s20": {"text": "گسارنده باده آورد ساز سیه چشم و گلرخ بتان طراز", "lines": ["s138-l39", "s138-l40"], "segs": ["s138-g39", "s138-g40"]}, "s138-s21": {"text": "نشستند با رودسازان به هم بدان تا تهمتن نباشد دژم", "lines": ["s138-l41", "s138-l42"], "segs": ["s138-g41", "s138-g42"]}, "s138-s22": {"text": "چو شد مست و هنگام خواب آمدش همی از نشستن شتاب آمدش", "lines": ["s138-l43", "s138-l44"], "segs": ["s138-g43", "s138-g44"]}, "s138-s23": {"text": "سزاوار او جای آرام و خواب بیاراست و بنهاد مشک و گلاب", "lines": ["s138-l45", "s138-l46"], "segs": ["s138-g45", "s138-g46"]}}, "segments": {"s138-g1": {"text": "چو نزدیک شهر سمنگان رسید", "sid": "s138-s1", "lines": ["s138-l1"]}, "s138-g2": {"text": "خبر زو بشاه و بزرگان رسید", "sid": "s138-s1", "lines": ["s138-l2"]}, "s138-g3": {"text": "که آمد پیاده گو تاج‌بخش", "sid": "s138-s2", "lines": ["s138-l3"]}, "s138-g4": {"text": "به نخچیرگه زو رمیدست رخش", "sid": "s138-s2", "lines": ["s138-l4"]}, "s138-g5": {"text": "پذیره شدندش بزرگان و شاه", "sid": "s138-s3", "lines": ["s138-l5"]}, "s138-g6": {"text": "کسی کاو بسر بر نهادی کلاه", "sid": "s138-s3", "lines": ["s138-l6"]}, "s138-g7": {"text": "بدو گفت شاه سمنگان چه بود", "sid": "s138-s4", "lines": ["s138-l7"]}, "s138-g8": {"text": "که یارست با تو نبرد آزمود", "sid": "s138-s4", "lines": ["s138-l8"]}, "s138-g9": {"text": "درین شهر ما نیکخواه توایم", "sid": "s138-s5", "lines": ["s138-l9"]}, "s138-g10": {"text": "ستاده بفرمان و راه توایم", "sid": "s138-s5", "lines": ["s138-l10"]}, "s138-g11": {"text": "تن و خواسته زیر فرمان تست", "sid": "s138-s6", "lines": ["s138-l11"]}, "s138-g12": {"text": "سر ارجمندان و جان آن تست", "sid": "s138-s6", "lines": ["s138-l12"]}, "s138-g13": {"text": "چو رستم به گفتار او بنگرید", "sid": "s138-s7", "lines": ["s138-l13