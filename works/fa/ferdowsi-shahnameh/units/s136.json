s136-l11", "s136-l12"], "segs": ["s136-g11", "s136-g12"]}, "s136-s7": {"text": "دم مرگ چون آتش هولناک ندارد ز برنا و فرتوت باک", "lines": ["s136-l13", "s136-l14"], "segs": ["s136-g13", "s136-g14"]}, "s136-s8": {"text": "درین جای رفتن نه جای درنگ بر اسپ فنا‌گر کشد مرگ تنگ", "lines": ["s136-l15", "s136-l16"], "segs": ["s136-g15", "s136-g16"]}, "s136-s9": {"text": "چنان دان که دادست و بیداد نیست چو داد آمدش جای فریاد نیست", "lines": ["s136-l17", "s136-l18"], "segs": ["s136-g17", "s136-g18"]}, "s136-s10": {"text": "جوانی و پیری به نزدیک مرگ یکی دان چو اندر بدن نیست برگ", "lines": ["s136-l19", "s136-l20"], "segs": ["s136-g19", "s136-g20"]}, "s136-s11": {"text": "دل از نور ایمان‌گر آگنده‌ای ترا خامشی به که تو بنده‌ای", "lines": ["s136-l21", "s136-l22"], "segs": ["s136-g21", "s136-g22"]}, "s136-s12": {"text": "برین کار یزدان ترا راز نیست اگر جانت با دیو انباز نیست", "lines": ["s136-l23", "s136-l24"], "segs": ["s136-g23", "s136-g24"]}, "s136-s13": {"text": "به گیتی دران کوش چون بگذری سرانجام نیکی بر خود بری", "lines": ["s136-l25", "s136-l26"], "segs": ["s136-g25", "s136-g26"]}, "s136-s14": {"text": "کنون رزم سهراب رانم نخست ازان کین که او با پدر چون بجست", "lines": ["s136-l27", "s136-l28"], "segs": ["s136-g27", "s136-g28"]}}, "segments": {"s136-g1": {"text": "اگر تندبادی براید ز کنج", "sid": "s136-s1", "lines": ["s136-l1"]}, "s136-g2": {"text": "بخاک افگند نارسیده ترنج", "sid": "s136-s1", "lines": ["s136-l2"]}, "s136-g3": {"text": "ستمکاره خوانیمش ار دادگر", "sid": "s136-s2", "lines": ["s136-l3"]}, "s136-g4": {"text": "هنرمند دانیمش ار بی‌هنر", "sid": "s136-s2", "lines": ["s136-l4"]}, "s136-g5": {"text": "اگر مرگ دادست بیداد چیست", "sid": "s136-s3", "lines": ["s136-l5"]}, "s136-g6": {"text": "ز داد این همه بانگ و فریاد چیست", "sid": "s136-s3", "lines": ["s136-l6"]}, "s136-g7": {"text": "ازین راز جان تو آگاه نیست", "sid": "s136-s4", "lines": ["s136-l7"]}, "s136-g8": {"text": "بدین پرده اندر ترا راه نیست", "sid": "s136-s4", "lines": ["s136-l8"]}, "s136-g9": {"text": "همه تا د