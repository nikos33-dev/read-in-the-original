: ["s077-l31", "s077-l32"], "segs": ["s077-g31", "s077-g32"]}, "s077-s17": {"text": "سپه رانی و ما به کابل شویم بگوییم زین در سخن بشنویم", "lines": ["s077-l33", "s077-l34"], "segs": ["s077-g33", "s077-g34"]}, "s077-s18": {"text": "به دستان نگه کرد فرخنده سام بدانست کورا ازین چیست کام", "lines": ["s077-l35", "s077-l36"], "segs": ["s077-g35", "s077-g36"]}, "s077-s19": {"text": "سخن هر چه از دخت مهراب نیست به نزدیک زال آن جز از خواب نیست", "lines": ["s077-l37", "s077-l38"], "segs": ["s077-g37", "s077-g38"]}, "s077-s20": {"text": "بفرمود تا زنگ و هندی درای زدند و گشادند پرده سرای", "lines": ["s077-l39", "s077-l40"], "segs": ["s077-g39", "s077-g40"]}, "s077-s21": {"text": "هیونی برافگند مرد دلیر بدان تا شود نزد مهراب شیر", "lines": ["s077-l41", "s077-l42"], "segs": ["s077-g41", "s077-g42"]}, "s077-s22": {"text": "بگوید که آمد سپهبد ز راه ابا زال با پیل و چندی سپاه", "lines": ["s077-l43", "s077-l44"], "segs": ["s077-g43", "s077-g44"]}, "s077-s23": {"text": "فرستاده تازان به کابل رسید خروشی برآمد چنان چون سزید", "lines": ["s077-l45", "s077-l46"], "segs": ["s077-g45", "s077-g46"]}, "s077-s24": {"text": "چنان شاد شد شاه کابلستان ز پیوند خورشید زابلستان", "lines": ["s077-l47", "s077-l48"], "segs": ["s077-g47", "s077-g48"]}, "s077-s25": {"text": "که گفتی همی جان برافشاندند ز هر جای رامشگران خواندند", "lines": ["s077-l49", "s077-l50"], "segs": ["s077-g49", "s077-g50"]}}, "segments": {"s077-g1": {"text": "همی راند دستان گرفته شتاب", "sid": "s077-s1", "lines": ["s077-l1"]}, "s077-g2": {"text": "چو پرنده مرغ و چو کشتی برآب", "sid": "s077-s1", "lines": ["s077-l2"]}, "s077-g3": {"text": "کسی را نبد ز آمدنش آگهی", "sid": "s077-s2", "lines": ["s077-l3"]}, "s077-g4": {"text": "پذیره نرفتند با فرهی", "sid": "s077-s2", "lines": ["s077-l4"]}, "s077-g5": {"text": "خروشی برآمد ز پرده سرای", "sid": "s077-s3", "lines": ["s077-l5"]}, "s077-g6": {"text": "که آمد ز ره زال فرخنده‌رای", "sid": "s077-s3", "lines": ["s077-l6"]}, "s077-g7": {"text": "پذیره شدش سام یل شادمان", "sid": "s077-s4", "lines