, {"s": 23, "e": 26, "surface": "نام", "lemma": "نام", "pos": "NOUN", "seg": "s340-g43", "sid": "s340-s22"}]}, "s340-l44": {"text": "که با فرخی بود و با برز و کام", "sids": ["s340-s22"], "tokens": [{"s": 0, "e": 2, "surface": "که", "lemma": "که", "pos": "NOUN", "seg": "s340-g44", "sid": "s340-s22"}, {"s": 3, "e": 5, "surface": "با", "lemma": "با", "pos": "NOUN", "seg": "s340-g44", "sid": "s340-s22"}, {"s": 6, "e": 10, "surface": "فرخی", "lemma": "فرخی", "pos": "NOUN", "seg": "s340-g44", "sid": "s340-s22"}, {"s": 11, "e": 14, "surface": "بود", "lemma": "بود#است", "pos": "NOUN", "seg": "s340-g44", "sid": "s340-s22"}, {"s": 15, "e": 16, "surface": "و", "lemma": "و", "pos": "NOUN", "seg": "s340-g44", "sid": "s340-s22"}, {"s": 17, "e": 19, "surface": "با", "lemma": "با", "pos": "NOUN", "seg": "s340-g44", "sid": "s340-s22"}, {"s": 20, "e": 23, "surface": "برز", "lemma": "برز", "pos": "NOUN", "seg": "s340-g44", "sid": "s340-s22"}, {"s": 24, "e": 25, "surface": "و", "lemma": "و", "pos": "NOUN", "seg": "s340-g44", "sid": "s340-s22"}, {"s": 26, "e": 29, "surface": "کام", "lemma": "کام", "pos": "NOUN", "seg": "s340-g44", "sid": "s340-s22"}]}}, "sentences": {"s340-s1": {"text": "چو لهراسپ بنشست بر تخت داد به شاهنشهی تاج بر سر نهاد", "lines": ["s340-l1", "s340-l2"], "segs": ["s340-g1", "s340-g2"]}, "s340-s2": {"text": "جهان‌آفرین را ستایش گرفت نیایش ورا در فزایش گرفت", "lines": ["s340-l3", "s340-l4"], "segs": ["s340-g3", "s340-g4"]}, "s340-s3": {"text": "چنین گفت کز داور داد و پاک پر امید باشید و با ترس و باک", "lines": ["s340-l5", "s340-l6"], "segs": ["s340-g5", "s340-g6"]}, "s340-s4": {"text": "نگارنده چرخ گردنده اوست فراینده فره بنده اوست", "lines": ["s340-l7", "s340-l8"], "segs": ["s340-g7", "s340-g8"]}, "s340-s5": {"text": "چو دریا و کوه و زمین آفرید بلند آسمان از برش برکشید", "lines": ["s340-l9", "s340-l10"], "segs": ["s340-g9", "s340-g10"]}, "s340-s6": {"text": "یکی تیز گردان و دیگر بجای به جنبش ندادش نگارنده پای", "lines": ["s340-l11", "s340-l12"], "segs": ["s340-g11", "