  },
  "sentences": {
    "s611-s1": {
      "text": "به هشتم بیامد به دشت شکار خود و روزبه با سواری هزار",
      "lines": [
        "s611-l1",
        "s611-l2"
      ],
      "segs": [
        "s611-g1",
        "s611-g2"
      ]
    },
    "s611-s2": {
      "text": "همه دشت یکسر پر از گور دید ز قربان کمان کیان برکشید",
      "lines": [
        "s611-l3",
        "s611-l4"
      ],
      "segs": [
        "s611-g3",
        "s611-g4"
      ]
    },
    "s611-s3": {
      "text": "دو زاغ کمان را به زه بر نهاد ز یزدان پیروزگر کرد یاد",
      "lines": [
        "s611-l5",
        "s611-l6"
      ],
      "segs": [
        "s611-g5",
        "s611-g6"
      ]
    },
    "s611-s4": {
      "text": "بهاران و گوران شده جفت جوی ز کشتن به روی اندر آورده روی",
      "lines": [
        "s611-l7",
        "s611-l8"
      ],
      "segs": [
        "s611-g7",
        "s611-g8"
      ]
    },
    "s611-s5": {
      "text": "همی پوست کند این ازآن آن ازین ز خونشان شده لعل روی زمین",
      "lines": [
        "s611-l9",
        "s611-l10"
      ],
      "segs": [
        "s611-g9",
        "s611-g10"
      ]
    },
    "s611-s6": {
      "text": "همی بود بهرام تا گور نر به مستی جدا شد یک از یک دگر",
      "lines": [
        "s611-l11",
        "s611-l12"
      ],
      "segs": [
        "s611-g11",
        "s611-g12"
      ]
    },
    "s611-s7": {
      "text": "چو پیروز شد نره گور دلیر یکی ماده را اندر آورد زیر",
      "lines": [
        "s611-l13",
        "s611-l14"
      ],
      "segs": [
        "s611-g13",
        "s611-g14"
      ]
    },
    "s611-s8": {
      "text": "به زه داشت بهرام جنگی کمان بخندید چون گور شد شادمان",
      "lines": [
        "s611-l15",
        "s611-l16"
      ],
      "segs": [
        "s611-g15",
        "s611-g16"
      ]
    },
    "s611-s9": {
      "text": "بزد تیر بر پشت آن گور نر گذر کرد بر گور پیکان و پر",
      "lines": [
        "s611-l17",
        "s611-l18"
      ],
      "segs": [
        "s611-g17",
        "s611-g18"
      ]
    },
    "s611-s10": {
      "text": "نر و ماده را هر دو بر هم بدوخت دل لشکر از زخم او بر فروخت",
      "lines": [
        "s611-l19",
        "s611-l20"
      ],
      "segs": [
        "s611-g19",
        "s611-g20"
      ]
    },
    "s611-s11": {
      "text": "ز لشکر هرانکس که آن زخم دید بران شهریار آفرین گسترید",
      "lines": [
        "s611-l21",
        "s611-l22"
      ],
      "segs": [
        "s611-g21",
        "s611-g22"
      ]
    },
    "s611-s12": {
      "text": "که چشم بد از فر تو دور باد همه روزگاران تو سور باد",
      "lines": [
        "s611-l23",
        "s611-l24"
      ],
      "segs": [
        "s611-g23",
        "s611-g24"
      ]
    },
    "s611-s13": {
      "text": "به مردی تواندر زمانه نوی که هم شاه و هم خسرو و هم گوی",
      "lines": [
        "s611-l25",
        "s611-l26"
      ],
      "segs": [
        "s611-g25",
        "s611-g26"
      ]
    }
  },
