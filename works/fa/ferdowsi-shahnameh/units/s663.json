  "sentences": {
    "s663-s1": {
      "text": "بخندید تموز بر سرخ سیب همی‌کرد با بار و برگش عتیب",
      "lines": [
        "s663-l1",
        "s663-l2"
      ],
      "segs": [
        "s663-g1",
        "s663-g2"
      ]
    },
    "s663-s2": {
      "text": "که آن دسته گل بوقت بهار بمستی همی‌داشتی درکنار",
      "lines": [
        "s663-l3",
        "s663-l4"
      ],
      "segs": [
        "s663-g3",
        "s663-g4"
      ]
    },
    "s663-s3": {
      "text": "همی باد شرم آمد از رنگ اوی همی یاد یار آمد از چنگ اوی",
      "lines": [
        "s663-l5",
        "s663-l6"
      ],
      "segs": [
        "s663-g5",
        "s663-g6"
      ]
    },
    "s663-s4": {
      "text": "چه کردی که بودت خریدار آن کجا یافتی تیز بازار آن",
      "lines": [
        "s663-l7",
        "s663-l8"
      ],
      "segs": [
        "s663-g7",
        "s663-g8"
      ]
    },
    "s663-s5": {
      "text": "عقیق و زبرجد که دادت بهم ز بار گران شاخ تو هم بخم",
      "lines": [
        "s663-l9",
        "s663-l10"
      ],
      "segs": [
        "s663-g9",
        "s663-g10"
      ]
    },
    "s663-s6": {
      "text": "همانا که گل را بها خواستی بدان رنگ رخ را بیاراستی",
      "lines": [
        "s663-l11",
        "s663-l12"
      ],
      "segs": [
        "s663-g11",
        "s663-g12"
      ]
    },
    "s663-s7": {
      "text": "همی رنگ شرم آید از گردنت همی مشک بوید ز پیراهنت",
      "lines": [
        "s663-l13",
        "s663-l14"
      ],
      "segs": [
        "s663-g13",
        "s663-g14"
      ]
    },
    "s663-s8": {
      "text": "مگر جامه از مشتری بستدی به لوئلؤ بر از خون نقط برزدی",
      "lines": [
        "s663-l15",
        "s663-l16"
      ],
      "segs": [
        "s663-g15",
        "s663-g16"
      ]
    },
    "s663-s9": {
      "text": "زبرجدت برگست و چرمت بنفش سرت برتر از کاویانی درفش",
      "lines": [
        "s663-l17",
        "s663-l18"
      ],
      "segs": [
        "s663-g17",
        "s663-g18"
      ]
    },
    "s663-s10": {
      "text": "بپیرایه زرد وسرخ وسپید مرا کردی از برگ گل ناامید",
      "lines": [
        "s663-l19",
        "s663-l20"
      ],
      "segs": [
        "s663-g19",
        "s663-g20"
      ]
    },
    "s663-s11": {
      "text": "نگارا بهارا کجا رفته‌ای که آرایش باغ بنهفته‌ای",
      "lines": [
        "s663-l21",
        "s663-l22"
      ],
      "segs": [
        "s663-g21",
        "s663-g22"
      ]
    },
    "s663-s12": {
      "text": "همی مهرگان بوید از باد تو بجام می‌اندر کنم یاد تو",
      "lines": [
        "s663-l23",
        "s663-l24"
      ],
      "segs": [
        "s663-g23",
        "s663-g24"
      ]
    },
    "s663-s13": {
      "text": "چورنگت شود سبز بستایمت چو دیهیم هرمز بیارایمت",
      "lines": [
        "s663-l25",
        "s663-l26"
      ],
      "segs": [
        "s663-g25",
        "s663-g26"
      ]
    },
    "s663-s14": {
      "text": "که امروز تیزست بازار من نبینی پس از مرگ آثار من",
      "lines": [
        "s663-l27",
        "s663-l28"
      ],
      "segs": [
        "s663-g27",
        "s663-g28"
      ]
    }
  },
  "segments": {
    "s663-g1": {
      "text": "بخندید تموز بر سرخ سیب",
      "sid": "s663-s1",
      "lines": [
        "s663-l1"
      ]
    },
    "s663-g2": {
      "text": "همی‌کرد با بار و برگش عتیب",
      "sid": "s663-s1",
      "lines": [
        "s663-l2"
      ]
    },
    "s663-g3": {
      "text": "که آن دسته گل بوقت بهار",
      "sid": "s663-s2",
      "lines": [
        "s663-l3"
      ]
    },
    "s663-g4": {
      "text": "بمستی همی‌داشتی درکنار",
      "sid": "s663-s2",
      "lines": [
        "s663-l4"
      ]
    },
    "s663-g5": {
      "text": "همی باد شرم آمد از رنگ اوی",
      "sid": "s663-s3",
      "lines": [
        "s663-l5"
      ]
    },
    "s663-g6": {
      "text": "همی یاد یار آمد از چنگ اوی",
      "sid": "s663-s3",
      "lines": [
        "s663-l6"
      ]
    },
    "s663-g7": {
      "text": "چه کردی که بودت خریدار آن",
      "sid": "s663-s4",
      "lines": [
        "s663-l7"
      ]
    },
    "s663-g8": {
      "text": "کجا یافتی تیز بازار آن",
      "sid": "s663-s4",
      "lines": [
        "s663-l8"
      ]
    },
    "s663-g9": {
      "text": "عقیق و زبرجد که دادت بهم",
      "sid": "s663-s5",
      "lines": [
        "s663-l9"
      ]
    },
    "s663-g10": {
      "text": "ز بار گران شاخ تو هم بخم",
      "sid": "s663-s5",
      "lines": [
        "s663-l10"
      ]
    },
    "s663-g11": {
      "text": "همانا که گل را بها خواستی",
      "sid": "s663-s6",
      "lines": [
        "s663-l11"
      ]
    },
    "s663-g12": {
      "text": "بدان رنگ رخ را بیاراستی",
      "sid": "s663-s6",
      "lines": [
        "s663-l12"
      ]
    },
    "s663-g13": {
      "text": "همی رنگ شرم آید از گردنت",
      "sid": "s663-s7",
      "lines": [
        "s663-l13"
      ]
    },
    "s663-g14": {
      "text": "همی مشک بوید ز پیراهنت",
      "sid": "s663-s7",
      "lines": [
        "s663-l14"
      ]
    },
    "s663-g15": {
      "text": "مگر جامه از مشتری بستدی",
      "sid": "s663-s8",
      "lines": [
        "s663-l15"
      ]
    },
    "s663-g16": {
      "text": "به لوئلؤ بر از خون نقط برزدی",
      "sid": "s663-s8",
      "lines": [
        "s663-l16"
      ]
    },
    "s663-g17": {
      "text": "زبرجدت برگست و چرمت بنفش",
      "sid": "s663-s9",
      "lines": [
        "s663-l17"
      ]
    },
    "s663-g18": {
      "text": "سرت برتر از کاویانی درفش",
      "sid": "s663-s9",
      "lines": [
        "s663-l18"
      ]
    },
    "s663-g19": {
      "text": "بپیرایه زرد وسرخ وسپید",
      "sid": "s663-s10",
      "lines": [
        "s663-l19"
      ]
    },
    "s663-g20": {
      "text": "مرا کردی از برگ گل ناامید",
      "sid": "s663-s10",
      "lines": [
        "s663-l20"
      ]
    },
    "s663-g21": {
      "text": "نگارا بهارا کجا رفته‌ای",
      "sid": "s663-s11",
      "lines": [
        "s663-l21"
      ]
    },
    "s663-g22": {
      "text": "که آرایش باغ بنهفته‌ای",
      "sid": "s663-s11",
      "lines": [
        "s663-l22"
      ]
    },
    "s663-g23": {
      "text": "همی مهرگان بوید از باد تو",
      "sid": "s663-s12",
      "lines": [
        "s663-l23"
      ]
    },
    "s663-g24": {
      "text": "بجام می‌اندر کنم یاد تو",
      "sid": "s663-s12",
      "lines": [
        "s663-l24"
      ]
    },
    "s663-g25": {
      "text": "چورنگت شود سبز بستایمت",
      "sid": "s663-s13",
      "lines": [
        "s663-l25"
      ]
    },
    "s663-g26": {
