"sid": "s343-s19"}, {"s": 9, "e": 11, "surface": "آن", "lemma": "آن", "pos": "NOUN", "seg": "s343-g37", "sid": "s343-s19"}, {"s": 12, "e": 15, "surface": "بهر", "lemma": "بهر", "pos": "NOUN", "seg": "s343-g37", "sid": "s343-s19"}, {"s": 16, "e": 22, "surface": "لهراسپ", "lemma": "لهراسپ", "pos": "NOUN", "seg": "s343-g37", "sid": "s343-s19"}, {"s": 23, "e": 26, "surface": "بود", "lemma": "بود#است", "pos": "NOUN", "seg": "s343-g37", "sid": "s343-s19"}]}, "s343-l38": {"text": "غم و رنج تن بهر گشتاسپ بود", "sids": ["s343-s19"], "tokens": [{"s": 0, "e": 2, "surface": "غم", "lemma": "غم", "pos": "NOUN", "seg": "s343-g38", "sid": "s343-s19"}, {"s": 3, "e": 4, "surface": "و", "lemma": "و", "pos": "NOUN", "seg": "s343-g38", "sid": "s343-s19"}, {"s": 5, "e": 8, "surface": "رنج", "lemma": "رنج", "pos": "NOUN", "seg": "s343-g38", "sid": "s343-s19"}, {"s": 9, "e": 11, "surface": "تن", "lemma": "تن", "pos": "NOUN", "seg": "s343-g38", "sid": "s343-s19"}, {"s": 12, "e": 15, "surface": "بهر", "lemma": "بهر", "pos": "NOUN", "seg": "s343-g38", "sid": "s343-s19"}, {"s": 16, "e": 22, "surface": "گشتاسپ", "lemma": "گشتاسپ", "pos": "NOUN", "seg": "s343-g38", "sid": "s343-s19"}, {"s": 23, "e": 26, "surface": "بود", "lemma": "بود#است", "pos": "NOUN", "seg": "s343-g38", "sid": "s343-s19"}]}}, "sentences": {"s343-s1": {"text": "شب تیره شبدیز لهراسپی بیاورد با زین گشتاسپی", "lines": ["s343-l1", "s343-l2"], "segs": ["s343-g1", "s343-g2"]}, "s343-s2": {"text": "بپوشید زربفت رومی قبای ز تاج اندر آویخت پر همای", "lines": ["s343-l3", "s343-l4"], "segs": ["s343-g3", "s343-g4"]}, "s343-s3": {"text": "ز دینار وز گوهر شاهوار بیاورد چندان کش آمد به کار", "lines": ["s343-l5", "s343-l6"], "segs": ["s343-g5", "s343-g6"]}, "s343-s4": {"text": "از ایران سوی روم بنهاد روی به دل گاه جوی و روان راه جوی", "lines": ["s343-l7", "s343-l8"], "segs": ["s343-g7", "s343-g8"]}, "s343-s5": {"text": "پدر چون ز گشتاسپ آگاه شد بپیچید و شادیش کوتاه شد", "lines": ["s343-l9", "s343-l10"], "segs": ["s343-g9", "s343-g10"]}, "s343-s6": {"text": "زریر و همه بخردان را بخواند ز گشتاسپ چندی سخنها براند", "lines": ["s343-l11", "s343-l12"], "segs": ["s343-g11", "s343-g12"]}, "s343-s7": {"text": "بدیشان چنین گفت کاین شیر مرد سر تاجدار اندر آرد به گرد", "lines": ["s343-l13", "s343-l14"], "segs": ["s343-g13", "s343-g14"]}, "s343-s8": {"text": "چه بینید و این را چه درمان کنید نشاید که این بر دل آسان کنید", "lines": ["s343-l15", "s343-l16"], "segs": ["s343-g15", "s343-g16"]}, "s343-s9": {"text": "چنین گفت موبد که این نیک‌بخت گرامی به مردان بود تاج و تخت", "lines": ["s343-l17", "s343-l18"], "segs": ["s343-g17", "s343-g18"]}, "s343-s10": {"text": "چو گشتاسپ فرزند کس را نبود نه هرگز کس از نامداران شنود", "lines": ["s343-l19", "s343-l20"], "segs": ["s343-g19", "s343-g20"]}, "s343-s11": {"text": "ز هر سو بباید فرستاد کس دلاور بزرگان فریادرس", "lines": ["s343-l21", "s343-l22"], "segs": ["s343-g21", "s343-g22"]}, "s343-s12": {"text": "گر او بازگردد تو زفتی مکن هنرجوی و با آز جفتی مکن", "lines": ["s343-l23", "s343-l24"], "segs": ["s343-g23", "s343-g24"]}, "s343-s13": {"text": "که تاج کیان چون تو بیند بسی نماند همی مهر او بر کسی", "lines": ["s343-l25", "s343-l26"], "segs": ["s343-g25", "s343-g26"]}, "s343-s14": {"text": "به گشتاسپ ده زین جهان کشوری بنه بر سرش نامدار افسری", "lines": ["s343-l27", "s343-l28"], "segs": ["s343-g27", "s343-g28"]}, "s343-s15": {"text": "جز از پهلوان رستم نامدار به گیتی نبینیم چون او سوار", "lines": ["s343-l29", "s343-l30"], "segs": ["s343-g29", "s343-g30"]}, "s343-s16": {"text": "به بالا و دیدار و فرهنگ و هوش چنو نامور نیز نشنید گوش", "lines": ["s343-l31", "s343-l32"], "segs": ["s343-g31", "s343-g32"]}, "s343-s17": {"text": "فرستاد لهراسپ چندی مهان به جستن گرفتند گرد جهان", "lines": ["s343-l33", "s343-l34"], "segs": ["s343-g33", "s343-g34"]}, "s343-s18": {"text": "برفتند و نومید بازآمدند که با اختر دیرساز آمدند", "lines": ["s343-l35", "s343-l36"], "segs": ["s343-g35", "s343-g36"]}, "s343-s19": {"text": "نکوهش از آن بهر لهراسپ بود غم و رنج تن بهر گشتاسپ بود", "lines": ["s343-l37", "s343-l38"], "segs": ["s343-g37", "s343-g38"]}}, "segments": {"s343-g1": {"text": "شب تیره شبدیز لهراسپی", "sid": "s343-s1", "lines": ["s343-l1"]}, "s343-g2": {"text": "بیاورد با زین گشتاسپی", "sid": "s343-s1", "lines": ["s343-l2"]}, "s343-g3": {"text": "بپوشید زربفت رومی قبای", "sid": "s343-s2", "lines": ["s343-l3"]}, "s343-g4": {"text": "ز تاج اندر آویخت پر همای", "sid": "s343-s2", "lines": ["s343-l4"]}, "s343-g5": {"text": "ز دینار وز گوهر شاهوار", "sid": "s343-s3", "lines": ["s343-l5"]}, "s343-g6": {"text": "بیاورد چندان کش آمد به کار", "sid": "s343-s3", "lines": ["s343-l6"]}, "s343-g7": {"text": "از ایران سوی روم بنهاد روی", "sid": "s343-s4", "lines": ["s343-l7"]}, "s343-g8": {"text": "به دل گاه جوی و روان راه جوی", "sid": "s343-s4", "lines": ["s343-l8"]}, "s343-g9": {"text": "پدر چون ز گشتاسپ آگاه شد", "sid": "s343-s5", "lines": ["s343-l9"]}, "s343-g10": {"text": "بپیچید و شادیش کوتاه شد", "sid": "s343-s5", "lines": ["s343-l10"]}, "s343-g11": {"text": "زریر و همه بخردان را بخواند", "sid": "s343-s6", "lines": ["s343-l11"]}, "s343-g12": {"text": "ز گشتاسپ چندی سخنها براند", "sid": "s343-s6", "lines": ["s343-l12"]}, "s343-g13": {"text": "بدیشان چنین گفت کاین شیر مرد", "sid": "s343-s7", "lines": ["s343-l13"]}, "s343-g14": {"text": "سر تاجدار اندر آرد به گرد", "sid": "s343-s7", "lines": ["s343-l14"]}, "s343-g15": {"text": "چه بینید و این را چه درمان کنید", "sid": "s343-s8", "lines": ["s343-l15"]}, "s343-g16": {"text": "نشاید که این بر دل آسان کنید", "sid": "s343-s8", "lines": ["s343-l16"]}, "s343-g17": {"text": "چنین گفت موبد که این نیک‌بخت", "sid": "s343-s9", "lines": ["s343-l17"]}, "s343-g18": {"text": "گرامی به مردان بود تاج و تخت", "sid": "s343-s9", "lines": ["s343-l18"]}, "s343-g19": {"text": "چو گشتاسپ فرزند کس را نبود", "sid": "s343-s10", "lines": ["s343-l19"]}, "s343-g20": {"text": "نه هرگز کس از نامداران شنود", "sid": "s343-s10", "lines": ["s343-l20"]}, "s343-g21": {"text": "ز هر سو بباید فرستاد کس", "sid": "s343-s11", "lines": ["s343-l21"]}, "s343-g22": {"t