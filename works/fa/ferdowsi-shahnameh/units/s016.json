016-g12": {"text": "همان و همین سنگ بشکست گرد", "sid": "s016-s6", "lines": ["s016-l12"]}, "s016-g13": {"text": "فروغی پدید آمد از هر دو سنگ", "sid": "s016-s7", "lines": ["s016-l13"]}, "s016-g14": {"text": "دل سنگ گشت از فروغ آذرنگ", "sid": "s016-s7", "lines": ["s016-l14"]}, "s016-g15": {"text": "نشد مار کشته ولیکن ز راز", "sid": "s016-s8", "lines": ["s016-l15"]}, "s016-g16": {"text": "از این طبع سنگ آتش آمد فراز", "sid": "s016-s8", "lines": ["s016-l16"]}, "s016-g17": {"text": "جهاندار پیش جهان‌آفرین", "sid": "s016-s9", "lines": ["s016-l17"]}, "s016-g18": {"text": "نیایش همی کرد و خواند آفرین", "sid": "s016-s9", "lines": ["s016-l18"]}, "s016-g19": {"text": "که او را فروغی چنین هدیه داد", "sid": "s016-s10", "lines": ["s016-l19"]}, "s016-g20": {"text": "همین آتش آنگاه قبله نهاد", "sid": "s016-s10", "lines": ["s016-l20"]}, "s016-g21": {"text": "بگفتا فروغی است این ایزدی", "sid": "s016-s11", "lines": ["s016-l21"]}, "s016-g22": {"text": "پرستید باید اگر بخردی", "sid": "s016-s11", "lines": ["s016-l22"]}, "s016-g23": {"text": "شب آمد بر افروخت آتش چو کوه", "sid": "s016-s12", "lines": ["s016-l23"]}, "s016-g24": {"text": "همان شاه در گرد او با گروه", "sid": "s016-s12", "lines": ["s016-l24"]}, "s016-g25": {"text": "یکی جشن کرد آن شب و باده خورد", "sid": "s016-s13", "lines": ["s016-l25"]}, "s016-g26": {"text": "سده نام آن جشن فرخنده کرد", "sid": "s016-s13", "lines": ["s016-l26"]}, "s016-g27": {"text": "ز هوشنگ ماند این سده یادگار", "sid": "s016-s14", "lines": ["s016-l27"]}, "s016-g28": {"text": "بسی باد چون او دگر شهریار", "sid": "s016-s14", "lines": ["s016-l28"]}, "s016-g29": {"text": "کز آباد کردن جهان شاد کرد", "sid": "s016-s15", "lines": ["s016-l29"]}, "s016-g30": {"text": "جهانی به نیکی از او یاد کرد", "sid": "s016-s15", "lines": ["s016-l30"]}}}