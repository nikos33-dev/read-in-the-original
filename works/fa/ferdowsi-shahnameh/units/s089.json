: ["s089-l3", "s089-l4"], "segs": ["s089-g3", "s089-g4"]}, "s089-s3": {"text": "چو افراسیاب آگهی یافت زوی که سوی بیابان نهادست روی", "lines": ["s089-l5", "s089-l6"], "segs": ["s089-g5", "s089-g6"]}, "s089-s4": {"text": "سپاه انجمن کرد و پویان برفت چو شیر از پسش روی بنهاد و تفت", "lines": ["s089-l7", "s089-l8"], "segs": ["s089-g7", "s089-g8"]}, "s089-s5": {"text": "چو تنگ اندر آمد بر شهریار همش تاختن دید و هم کارزار", "lines": ["s089-l9", "s089-l10"], "segs": ["s089-g9", "s089-g10"]}, "s089-s6": {"text": "بدان سان که آمد همی جست راه که تا بر سر آرد سری بی‌کلاه", "lines": ["s089-l11", "s089-l12"], "segs": ["s089-g11", "s089-g12"]}, "s089-s7": {"text": "شب تیره تا شد بلند آفتاب همی گشت با نوذر افراسیاب", "lines": ["s089-l13", "s089-l14"], "segs": ["s089-g13", "s089-g14"]}, "s089-s8": {"text": "ز گرد سواران جهان تار شد سرانجام نوذر گرفتار شد", "lines": ["s089-l15", "s089-l16"], "segs": ["s089-g15", "s089-g16"]}, "s089-s9": {"text": "خود و نامداران هزار و دویست تو گفتی کشان بر زمین جای نیست", "lines": ["s089-l17", "s089-l18"], "segs": ["s089-g17", "s089-g18"]}, "s089-s10": {"text": "بسی راه جستند و بگریختند به دام بلا هم برآویختند", "lines": ["s089-l19", "s089-l20"], "segs": ["s089-g19", "s089-g20"]}, "s089-s11": {"text": "چنان لشکری را گرفته به بند بیاورد با شهریار بلند", "lines": ["s089-l21", "s089-l22"], "segs": ["s089-g21", "s089-g22"]}, "s089-s12": {"text": "اگر با تو گردون نشیند به راز هم از گردش او نیابی جواز", "lines": ["s089-l23", "s089-l24"], "segs": ["s089-g23", "s089-g24"]}, "s089-s13": {"text": "همو تاج و تخت بلندی دهد همو تیرگی و نژندی دهد", "lines": ["s089-l25", "s089-l26"], "segs": ["s089-g25", "s089-g26"]}, "s089-s14": {"text": "به دشمن همی ماند و هم به دوست گهی مغز یابی ازو گاه پوست", "lines": ["s089-l27", "s089-l28"], "segs": ["s089-g27", "s089-g28"]}, "s089-s15": {"text": "سرت‌گر بساید به ابر سیاه سرانجام خاک است ازو جایگاه", "lines": ["s089-l29", "s089-l30"], "segs": ["s089-g29", "s089-g30"]}, "s089-s16": {"text": "وزان پس بفرمود افراسیاب که از غار و کوه و بیابان و آب", "lines": ["s089-l31", "s089-l32"], "segs": ["s089-g31", "s089-g32"]}, "s089-s17": {"text": "بجویید تا قارن رزم زن رهایی نیابد ازین انجمن", "lines": ["s089-l33", "s089-l34"], "segs": ["s089-g33", "s089-g34"]}, "s089-s18": {"text": "چو بشنید کاو پیش ازان رفته بود ز کار شبستان برآشفته بود", "lines": ["s089-l35", "s089-l36"], "segs": ["s089-g35", "s089-g36"]}, "s089-s19": {"text": "غمی گشت ازان کار افراسیاب ازو دور شد خورد و آرام و خواب", "lines": ["s089-l37", "s089-l38"], "segs": ["s089-g37", "s089-g38"]}, "s089-s20": {"text": "که قارن رها یافت از وی به جان بران درد پیچید و شد بدگمان", "lines": ["s089-l39", "s089-l40"], "segs": ["s089-g39", "s089-g40"]}, "s089-s21": {"text": "چنین گفت با ویسه نامور که دل‌سخت گردان به مرگ پسر", "lines": ["s089-l41", "s089-l42"], "segs": ["s089-g41", "s089-g42"]}, "s089-s22": {"text": "که چون قارن کاوه جنگ آورد پلنگ از شتابش درنگ آورد", "lines": ["s089-l43", "s089-l44"], "segs": ["s089-g43", "s089-g44"]}, "s089-s23": {"text": "ترا رفت باید ببسته کمر یکی لشکری ساخته پرهنر", "lines": ["s089-l45", "s089-l46"], "segs": ["s089-g45", "s089-g46"]}}, "segments": {"s089-g1": {"text": "چو بشنید نوذر که قارن برفت", "sid": "s089-s1", "lines": ["s089-l1"]}, "s089-g2": {"text": "دمان از پسش روی بنهاد و تفت", "sid": "s089-s1", "lines": ["s089-l2"]}, "s089-g3": {"text": "همی تاخت کز روز بد بگذرد", "sid": "s089-s2", "lines": ["s089-l3"]}, "s089-g4": {"text": "سپهرش مگر زیر پی نسپرد", "sid": "s089-s2", "lines": ["s089-l4"]}, "s089-g5": {"text": "چو افراسیاب آگهی یافت زوی", "sid": "s089-s3", "lines": ["s089-l5"]}, "s089-g6": {"text": "که سوی بیابان نهادست روی", "sid": "s089-s3", "lines": ["s089-l6"]}, "s089-g7": {"text": "سپاه انجمن کرد و پویان برفت", "sid": "s089-s4", "lines": ["s089-l7"]}, "s089-g8": {"text": "چو شیر از پسش روی بنهاد و تفت", "sid": "s089-s4", "lines": ["s089-l8"]}, "s089-g9": {"text": "چو تنگ اندر آمد بر شهریار", "sid": "s089-s5", "lines": ["s089-l9"]}, "s089-g10": {"text": "همش تاختن دید و هم کارزار", "sid": "s089-s