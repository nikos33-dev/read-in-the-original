د", "lemma": "گرد", "pos": "NOUN", "seg": "s014-g39", "sid": "s014-s20"}, {"s": 20, "e": 23, "surface": "کرد", "lemma": "کرد#کن", "pos": "NOUN", "seg": "s014-g39", "sid": "s014-s20"}]}, "s014-l40": {"text": "ره سود بنمود و خود مایه خورد", "sids": ["s014-s20"], "tokens": [{"s": 0, "e": 2, "surface": "ره", "lemma": "ره", "pos": "NOUN", "seg": "s014-g40", "sid": "s014-s20"}, {"s": 3, "e": 6, "surface": "سود", "lemma": "سود", "pos": "NOUN", "seg": "s014-g40", "sid": "s014-s20"}, {"s": 7, "e": 12, "surface": "بنمود", "lemma": "بنمود", "pos": "NOUN", "seg": "s014-g40", "sid": "s014-s20"}, {"s": 13, "e": 14, "surface": "و", "lemma": "و", "pos": "NOUN", "seg": "s014-g40", "sid": "s014-s20"}, {"s": 15, "e": 18, "surface": "خود", "lemma": "خود", "pos": "NOUN", "seg": "s014-g40", "sid": "s014-s20"}, {"s": 19, "e": 23, "surface": "مایه", "lemma": "مایه", "pos": "NOUN", "seg": "s014-g40", "sid": "s014-s20"}, {"s": 24, "e": 28, "surface": "خورد", "lemma": "خورد#خور", "pos": "NOUN", "seg": "s014-g40", "sid": "s014-s20"}]}, "s014-l41": {"text": "جهان سر به سر چو فسانست و بس", "sids": ["s014-s21"], "tokens": [{"s": 0, "e": 4, "surface": "جهان", "lemma": "جهان", "pos": "NOUN", "seg": "s014-g41", "sid": "s014-s21"}, {"s": 5, "e": 7, "surface": "سر", "lemma": "سر", "pos": "NOUN", "seg": "s014-g41", "sid": "s014-s21"}, {"s": 8, "e": 10, "surface": "به", "lemma": "به", "pos": "NOUN", "seg": "s014-g41", "sid": "s014-s21"}, {"s": 11, "e": 13, "surface": "سر", "lemma": "سر", "pos": "NOUN", "seg": "s014-g41", "sid": "s014-s21"}, {"s": 14, "e": 16, "surface": "چو", "lemma": "چو", "pos": "NOUN", "seg": "s014-g41", "sid": "s014-s21"}, {"s": 17, "e": 23, "surface": "فسانست", "lemma": "فسانست", "pos": "NOUN", "seg": "s014-g41", "sid": "s014-s21"}, {"s": 24, "e": 25, "surface": "و", "lemma": "و", "pos": "NOUN", "seg": "s014-g41", "sid": "s014-s21"}, {"s": 26, "e": 28, "surface": "بس", "lemma": "بس", "pos": "NOUN", "seg": "s014-g41", "sid": "s014-s21"}]}, "s014-l42": {"text": "نماند بد و نیک بر هیچ‌کس", "sids": ["s014-s21"], "tokens": [{"s": 0, "e": 5, "surface": "نماند", "lemma": "ماند#مان", "pos": "NOUN", "seg": "s014-g42", "sid": "s014-s21"}, {"s": 6, "e": 8, "surface": "بد", "lemma": "بد", "pos": "NOUN", "seg": "s014-g42", "sid": "s014-s21"}, {"s": 9, "e": 10, "surface": "و", "lemma": "و", "pos": "NOUN", "seg": "s014-g42", "sid": "s014-s21"}, {"s": 11, "e": 14, "surface": "نیک", "lemma": "نیک", "pos": "NOUN", "seg": "s014-g42", "sid": "s014-s21"}, {"s": 15, "e": 17, "surface": "بر", "lemma": "بر", "pos": "NOUN", "seg": "s014-g42", "sid": "s014-s21"}, {"s": 18, "e": 24, "surface": "هیچ‌کس", "lemma": "هیچ‌کس", "pos": "NOUN", "seg": "s014-g42", "sid": "s014-s21"}]}}, "sentences": {"s014-s1": {"text": "خجسته سیامک یکی پور داشت که نزد نیا جاه دستور داشت", "lines": ["s014-l1", "s014-l2"], "segs": ["s014-g1", "s014-g2"]}, "s014-s2": {"text": "گرانمایه را نام هوشنگ بود تو گفتی همه هوش و فرهنگ بود", "lines": ["s014-l3", "s014-l4"], "segs": ["s014-g3", "s014-g4"]}, "s014-s3": {"text": "به نزد نیا یادگار پدر نیا پروریده مر او را به بر", "lines": ["s014-l5", "s014-l6"], "segs": ["s014-g5", "s014-g6"]}, "s014-s4": {"text": "نیایش به جای پسر داشتی جز او بر کسی چشم نگماشتی", "lines": ["s014-l7", "s014-l8"], "segs": ["s014-g7", "s014-g8"]}, "s014-s5": {"text": "چو بنهاد دل کینه و جنگ را بخواند آن گرانمایه هوشنگ را", "lines": ["s014-l9", "s014-l10"], "segs": ["s014-g9", "s014-g10"]}, "s014-s6": {"text": "همه گفتنی‌ها بدو بازگفت همه رازها بر گشاد از نهفت", "lines": ["s014-l11", "s014-l12"], "segs": ["s014-g11", "s014-g12"]}, "s014-s7": {"text": "که من لشکری کرد خواهم همی خروشی برآورد خواهم همی", "lines": ["s014-l13", "s014-l14"], "segs": ["s014-g13", "s014-g14"]}, "s014-s8": {"text": "تو را بود باید همی پیشرو که من رفتنی‌ام تو سالار نو", "lines": ["s014-l15", "s014-l16"], "segs": ["s014-g15", "s014-g16"]}, "s014-s9": {"text": "پری و پلنگ انجمن کرد و شیر ز درندگان گرگ و ببر دلیر", "lines": ["s014-l17", "s014-l18"], "segs": ["s014-g17", "s014-g18"]}, "s014-s10": {"text": "سپاهی دد و دام و مرغ و پری سپهدار پرکین و کنداوری", "lines": ["s014-l19", "s014-l20"], "segs": ["s014-g19", "s014-g20"]}, "s014-s11": {"text": "پس پشت لشکر کیومرث شاه نبیره به پیش اندرون با سپاه", "lines": ["s014-l21", "s014-l22"], "segs": ["s014-g21", "s014-g22"]}, "s014-s12": {"text": "بیامد سیه دیو با ترس و باک همی بآسمان بر پراگند خاک", "lines": ["s014-l23", "s014-l24"], "segs": ["s014-g23", "s014-g24"]}, "s014-s13": {"text": "ز هرای درندگان چنگ دیو شده سست از خشم کیهان خدیو", "lines": ["s014-l25", "s014-l26"], "segs": ["s014-g25", "s014-g26"]}, "s014-s14": {"text": "به هم برشکستند هر دو گروه شدند از دد و دام دیوان ستوه", "lines": ["s014-l27", "s014-l28"], "segs": ["s014-g27", "s014-g28"]}, "s014-s15": {"text": "بیازید هوشنگ چون شیر چنگ جهان کرد بر دیو نستوه تنگ", "lines": ["s014-l29", "s014-l30"], "segs": ["s014-g29", "s014-g30"]}, "s014-s16": {"text": "کشیدش سراپای یک‌سر دوال سپهبد برید آن سر بی‌همال", "lines": ["s014-l31", "s014-l32"], "segs": ["s014-g31", "s014-g32"]}, "s014-s17": {"text": "به پای اندر افگند و بسپرد خوار دریده بر او چرم و برگشته کار", "lines": ["s014-l33", "s014-l34"], "segs": ["s014-g33", "s014-g34"]}, "s014-s18": {"text": "چو آمد مر آن کینه را خواستار سرآمد کیومرث را روزگار", "lines": ["s014-l35", "s014-l36"], "segs": ["s014-g35", "s014-g36"]}, "s014-s19": {"text": "برفت و جهان مردری ماند ازوی نگر تا که را نزد او آبروی", "lines": ["s014-l37", "s014-l38"], "segs": ["s014-g37", "s014-g38"]}, "s014-s20": {"text": "جهان فریبنده را گرد کرد ره سود بنمود و خود مایه خورد", "lines": ["s014-l39", "s014-l40"], "segs": ["s014-g39", "s014-g40"]}, "s014-s21": {"text": "جهان سر به سر چو فسانست و بس نماند بد و نیک بر هیچ‌کس", "lines": ["s014-l41", "s014-l42"], "segs": ["s014-g41", "s014-g42"]}}, "segments": {"s014-g1": {"text": "خجسته سیامک یکی پور داشت", "sid": "s014-s1", "lines": ["s014-l1"]}, "s014-g2": {"text": "که نزد نیا جاه دستور داشت", "sid": "s014-s1", "lines": ["s014-l2"]}, "s014-g3": {"text": "گرانمایه را نام هوشنگ بود", "sid": "s014-s2", "lines"