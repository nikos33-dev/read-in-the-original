-g38", "sid": "s358-s19"}]}, "s358-l39": {"text": "پشوتن دگر گرد شمشیر زن", "sids": ["s358-s20"], "tokens": [{"s": 0, "e": 5, "surface": "پشوتن", "lemma": "پشوتن", "pos": "NOUN", "seg": "s358-g39", "sid": "s358-s20"}, {"s": 6, "e": 9, "surface": "دگر", "lemma": "دگر", "pos": "NOUN", "seg": "s358-g39", "sid": "s358-s20"}, {"s": 10, "e": 13, "surface": "گرد", "lemma": "گرد", "pos": "NOUN", "seg": "s358-g39", "sid": "s358-s20"}, {"s": 14, "e": 19, "surface": "شمشیر", "lemma": "شمشیر", "pos": "NOUN", "seg": "s358-g39", "sid": "s358-s20"}, {"s": 20, "e": 22, "surface": "زن", "lemma": "زن", "pos": "NOUN", "seg": "s358-g39", "sid": "s358-s20"}]}, "s358-l40": {"text": "شه نامبردار لشکرشکن", "sids": ["s358-s20"], "tokens": [{"s": 0, "e": 2, "surface": "شه", "lemma": "شه", "pos": "NOUN", "seg": "s358-g40", "sid": "s358-s20"}, {"s": 3, "e": 11, "surface": "نامبردار", "lemma": "نامبردار", "pos": "NOUN", "seg": "s358-g40", "sid": "s358-s20"}, {"s": 12, "e": 19, "surface": "لشکرشکن", "lemma": "لشکرشکن", "pos": "NOUN", "seg": "s358-g40", "sid": "s358-s20"}]}, "s358-l41": {"text": "چو گیتی بران شاه نو راست شد", "sids": ["s358-s21"], "tokens": [{"s": 0, "e": 2, "surface": "چو", "lemma": "چو", "pos": "NOUN", "seg": "s358-g41", "sid": "s358-s21"}, {"s": 3, "e": 7, "surface": "گیتی", "lemma": "گیتی", "pos": "NOUN", "seg": "s358-g41", "sid": "s358-s21"}, {"s": 8, "e": 12, "surface": "بران", "lemma": "بران", "pos": "NOUN", "seg": "s358-g41", "sid": "s358-s21"}, {"s": 13, "e": 16, "surface": "شاه", "lemma": "شاه", "pos": "NOUN", "seg": "s358-g41", "sid": "s358-s21"}, {"s": 17, "e": 19, "surface": "نو", "lemma": "نو", "pos": "NOUN", "seg": "s358-g41", "sid": "s358-s21"}, {"s": 20, "e": 24, "surface": "راست", "lemma": "راست", "pos": "NOUN", "seg": "s358-g41", "sid": "s358-s21"}, {"s": 25, "e": 27, "surface": "شد", "lemma": "شد#شو", "pos": "NOUN", "seg": "s358-g41", "sid": "s358-s21"}]}, "s358-l42": {"text": "فریدون دیگر همی خواست شد", "sids": ["s358-s21"], "tokens": [{"s": 0, "e": 6, "surfa