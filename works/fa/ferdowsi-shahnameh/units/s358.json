ید#شنو", "pos": "NOUN", "seg": "s358-g48", "sid": "s358-s24"}, {"s": 14, "e": 15, "surface": "ز", "lemma": "ز", "pos": "NOUN", "seg": "s358-g48", "sid": "s358-s24"}, {"s": 15, "e": 16, "surface": "و", "lemma": "و", "pos": "NOUN", "seg": "s358-g48", "sid": "s358-s24"}, {"s": 17, "e": 20, "surface": "دید", "lemma": "دید", "pos": "NOUN", "seg": "s358-g48", "sid": "s358-s24"}, {"s": 21, "e": 24, "surface": "بند", "lemma": "بند", "pos": "NOUN", "seg": "s358-g48", "sid": "s358-s24"}]}, "s358-l49": {"text": "وزو بستدی نیز هر سال باژ", "sids": ["s358-s25"], "tokens": [{"s": 0, "e": 3, "surface": "وزو", "lemma": "وزو", "pos": "NOUN", "seg": "s358-g49", "sid": "s358-s25"}, {"s": 4, "e": 9, "surface": "بستدی", "lemma": "بستدی", "pos": "NOUN", "seg": "s358-g49", "sid": "s358-s25"}, {"s": 10, "e": 13, "surface": "نیز", "lemma": "نیز", "pos": "NOUN", "seg": "s358-g49", "sid": "s358-s25"}, {"s": 14, "e": 16, "surface": "هر", "lemma": "هر", "pos": "NOUN", "seg": "s358-g49", "sid": "s358-s25"}, {"s": 17, "e": 20, "surface": "سال", "lemma": "سال", "pos": "NOUN", "seg": "s358-g49", "sid": "s358-s25"}, {"s": 21, "e": 24, "surface": "باژ", "lemma": "باژ", "pos": "NOUN", "seg": "s358-g49", "sid": "s358-s25"}]}, "s358-l50": {"text": "چرا داد باید به هامال باژ", "sids": ["s358-s25"], "tokens": [{"s": 0, "e": 3, "surface": "چرا", "lemma": "چرا", "pos": "NOUN", "seg": "s358-g50", "sid": "s358-s25"}, {"s": 4, "e": 7, "surface": "داد", "lemma": "داد", "pos": "NOUN", "seg": "s358-g50", "sid": "s358-s25"}, {"s": 8, "e": 12, "surface": "باید", "lemma": "باید", "pos": "NOUN", "seg": "s358-g50", "sid": "s358-s25"}, {"s": 13, "e": 15, "surface": "به", "lemma": "به", "pos": "NOUN", "seg": "s358-g50", "sid": "s358-s25"}, {"s": 16, "e": 21, "surface": "هامال", "lemma": "هامال", "pos": "NOUN", "seg": "s358-g50", "sid": "s358-s25"}, {"s": 22, "e": 25, "surface": "باژ", "lemma": "باژ", "pos": "NOUN", "seg": "s358-g50", "sid": "s358-s25"}]}}, "sentences": {"s358-s1": {"text": "چو گشتاسپ را داد لهراسپ تخت فرود آمد از تخت و بربست رخت", "lines": ["s358-l1", "s358-l2"], "segs": ["s358-g1", "s358-g2"]}, "s358-s2": {"text": "به بلخ گزین شد بران نوبهار که یزدان پرستان بدان روزگار", "lines": ["s358-l3", "s358-l4"], "segs": ["s358-g3", "s358-g4"]}, "s358-s3": {"text": "مران جای را داشتندی چنان که مر مکه را تازیان این زمان", "lines": ["s358-l5", "s358-l6"], "segs": ["s358-g5", "s358-g6"]}, "s358-s4": {"text": "بدان خانه شد شاه یزدان‌پرست فرود آمد از جایگاه نشست", "lines": ["s358-l7", "s358-l8"], "segs": ["s358-g7", "s358-g8"]}, "s358-s5": {"text": "ببست آن در آفرین خانه را نماند اندرو خویش و بیگانه را", "lines": ["s358-l9", "s358-l10"], "segs": ["s358-g9", "s358-g10"]}, "s358-s6": {"text": "بپوشید جامه پرستش پلاس خرد را چنان کرد باید سپاس", "lines": ["s358-l11", "s358-l12"], "segs": ["s358-g11", "s358-g12"]}, "s358-s7": {"text": "بیفگند یاره فرو هشت موی سوی روشن دادگر کرد روی", "lines": ["s358-l13", "s358-l14"], "segs": ["s358-g13", "s358-g14"]}, "s358-s8": {"text": "همی بود سی سال پیشش به پای برینسان پرستید باید خدای", "lines": ["s358-l15", "s358-l16"], "segs": ["s358-g15", "s358-g16"]}, "s358-s9": {"text": "نیایش همی کرد خورشید را چنان بوده بد راه جمشید را", "lines": ["s358-l17", "s358-l18"], "segs": ["s358-g17", "s358-g18"]}, "s358-s10": {"text": "چو گشتاسپ بر شد به تخت پدر که هم فر او داشت و بخت پدر", "lines": ["s358-l19", "s358-l20"], "segs": ["s358-g19", "s358-g20"]}, "s358-s11": {"text": "به سر بر نهاد آن پدر داده تاج که زیبنده باشد بر آزاده تاج", "lines": ["s358-l21", "s358-l22"], "segs": ["s358-g21", "s358-g22"]}, "s358-s12": {"text": "منم گفت یزدان پرستنده شاه مرا ایزد پاک داد این کلاه", "lines": ["s358-l23", "s358-l24"], "segs": ["s358-g23", "s358-g24"]}, "s358-s13": {"text": "بدان داد ما را کلاه بزرگ که بیرون کنیم از رم میش گرگ", "lines": ["s358-l25", "s358-l26"], "segs": ["s358-g25", "s358-g26"]}, "s358-s14": {"text": "سوی راه یزدان بیازیم چنگ بر آزاده گیتی نداریم تنگ", "lines": ["s358-l27", "s358-l28"], "segs": ["s358-g27", "s358-g28"]}, "s358-s15": {"text": "چو آیین شاهان بجای آوریم بدان را به دین خدای آوریم", "lines": ["s358-l29", "s358-l30"], "segs": ["s358-g29", "s358-g30"]}, "s358-s16": {"text": "یکی داد گسترد کز داد اوی ابا گرگ میش آب خوردی به جوی", "lines": ["s358-l31", "s358-l32"], "segs": ["s358-g31", "s358-g32"]}, "s358-s17": {"text": "پس آن دختر نامور قیصرا که ناهید بد نام آن دخترا", "lines": ["s358-l33", "s358-l34"], "segs": ["s358-g33", "s358-g34"]}, "s358-s18": {"text": "کتایونش خواندی گرانمایه شاه دو فرزندش آمد چو تابنده ماه", "lines": ["s358-l35", "s358-l36"], "segs": ["s358-g35", "s358-g36"]}, "s358-s19": {"text": "یکی نامور فرخ اسفندیار شه کارزاری نبرده سوار", "lines": ["s358-l37", "s358-l38"], "segs": ["s358-g37", "s358-g38"]}, "s358-s20": {"text": "پشوتن دگر گرد شمشیر زن شه نامبردار لشکرشکن", "lines": ["s358-l39", "s358-l40"], "segs": ["s358-g39", "s358-g40"]}, "s358-s21": {"text": "چو گیتی بران شاه نو راست شد فریدون دیگر همی خواست شد", "lines": ["s358-l41", "s358-l42"], "segs": ["s358-g41", "s358-g42"]}, "s358-s22": {"text": "گزیدش بدادند شاهان همه نشستن دل نیک‌خواهان همه", "lines": ["s358-l43", "s358-l44"], "segs": ["s358-g43", "s358-g44"]}, "s358-s23": {"text": "مگر شاه ارجاسپ توران خدای که دیوان بدندی به پیشش به پای", "lines": ["s358-l45", "s358-l46"], "segs": ["s358-g45", "s358-g46"]}, "s358-s24": {"text": "گزیتش نپذرفت و نشنید پند اگر پند نشنید زو دید بند", "lines": ["s358-l47", "s358-l48"], "segs": ["s358-g47", "s358-g48"]}, "s358-s25": {"text": "وزو بستدی نیز هر سال باژ چرا داد باید به هامال باژ", "lines": ["s358-l49", "s358-l50"], "segs": ["s358-g49", "s358-g50"]}}, "segments": {"s358-g1": {"text": "چو گشتاسپ را داد لهراسپ تخت", "sid": "s358-s1", "lines": ["s358-l1"]}, "s358-g2": {"text": "فرود آمد از تخت و بربست رخت", "sid": "s358-s1", "lines": ["s358-l2"]}, "s358-g3": {"text": "به بلخ گزین شد بران نوبهار", "sid": "s358-s2", "lines": ["s358-l3"]}, "s358-g4": {"text": "که یزدان پرستان بدان روزگار", "sid": "s358-s2", "lines": ["s358-l4"]}, "s358-g5": {"text": "مران جای را داشتندی چنان", "sid": "s