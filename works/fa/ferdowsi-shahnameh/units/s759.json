  "sentences": {
    "s759-s1": {
      "text": "یکی دخت دیگر بد آزرم نام ز تاج بزرگان رسیده به کام",
      "lines": [
        "s759-l1",
        "s759-l2"
      ],
      "segs": [
        "s759-g1",
        "s759-g2"
      ]
    },
    "s759-s2": {
      "text": "بیامد به تخت کیان برنشست گرفت این جهان جهان را به دست",
      "lines": [
        "s759-l3",
        "s759-l4"
      ],
      "segs": [
        "s759-g3",
        "s759-g4"
      ]
    },
    "s759-s3": {
      "text": "نخستین چنین گفت کای بخردان جهان گشته و کار کرده ردان",
      "lines": [
        "s759-l5",
        "s759-l6"
      ],
      "segs": [
        "s759-g5",
        "s759-g6"
      ]
    },
    "s759-s4": {
      "text": "همه کار بر داد و آیین کنیم کزین پس همه خشت بالین کنیم",
      "lines": [
        "s759-l7",
        "s759-l8"
      ],
      "segs": [
        "s759-g7",
        "s759-g8"
      ]
    },
    "s759-s5": {
      "text": "هر آنکس که باشد مرا دوستدار چنانم مر او را چو پروردگار",
      "lines": [
        "s759-l9",
        "s759-l10"
      ],
      "segs": [
        "s759-g9",
        "s759-g10"
      ]
    },
    "s759-s6": {
      "text": "کس کو ز پیمان من بگذرد بپیچید ز آیین و راه خرد",
      "lines": [
        "s759-l11",
        "s759-l12"
      ],
      "segs": [
        "s759-g11",
        "s759-g12"
      ]
    },
    "s759-s7": {
      "text": "به خواری تنش را برآرم بدار ز دهقان و تازی و رومی شمار",
      "lines": [
        "s759-l13",
        "s759-l14"
      ],
      "segs": [
        "s759-g13",
        "s759-g14"
      ]
    },
