  "sentences": {
    "s755-s1": {
      "text": "چو بنشست بر تخت شاه اردشیر از ایران برفتند برنا و پیر",
      "lines": [
        "s755-l1",
        "s755-l2"
      ],
      "segs": [
        "s755-g1",
        "s755-g2"
      ]
    },
    "s755-s2": {
      "text": "بسی نامداران گشته کهن بدان تا چگونه سرآید سخن",
      "lines": [
        "s755-l3",
        "s755-l4"
      ],
      "segs": [
        "s755-g3",
        "s755-g4"
      ]
    },
    "s755-s3": {
      "text": "زبان برگشاد اردشیر جوان چنین گفت کای کار دیده گوان",
      "lines": [
        "s755-l5",
        "s755-l6"
      ],
      "segs": [
        "s755-g5",
        "s755-g6"
      ]
    },
    "s755-s4": {
      "text": "هر آنکس که برگاه شاهی نشست گشاده‌زبان باد و یزدان‌پرست",
      "lines": [
        "s755-l7",
        "s755-l8"
      ],
      "segs": [
        "s755-g7",
        "s755-g8"
      ]
    },
    "s755-s5": {
      "text": "بر آیین شاهان پیشین رویم همان از پس فره و دین رویم",
      "lines": [
        "s755-l9",
        "s755-l10"
      ],
      "segs": [
        "s755-g9",
        "s755-g10"
      ]
    },
    "s755-s6": {
      "text": "ز یزدان نیکی دهش یاد باد همه کار و کردار ما داد باد",
      "lines": [
        "s755-l11",
        "s755-l12"
      ],
      "segs": [
        "s755-g11",
        "s755-g12"
      ]
    },
    "s755-s7": {
      "text": "پرستندگان راهمه برکشیم ستمگارگان را به خون درکشیم",
      "lines": [
        "s755-l13",
        "s755-l14"
      ],
      "segs": [
        "s755-g13",
        "s755-g14"
      ]
    },
    "s755-s8": {
      "text": "بسی کس به گفتارش آرام یافت از آرام او هرکسی کام یافت",
      "lines": [
        "s755-l15",
        "s755-l16"
      ],
      "segs": [
        "s755-g15",
        "s755-g16"
      ]
    },
    "s755-s9": {
      "text": "به پیروز خسرو سپردم سپاه که از داد شادست و شادان ز شاه",
      "lines": [
        "s755-l17",
        "s755-l18"
      ],
      "segs": [
        "s755-g17",
        "s755-g18"
      ]
    },
    "s755-s10": {
      "text": "به ایران چو باشد چنو پهلوان بمانید شادان و روشن‌روان",
      "lines": [
        "s755-l19",
        "s755-l20"
      ],
      "segs": [
        "s755-g19",
        "s755-g20"
      ]
    }
  },
