  "sentences": {
    "s767-s1": {
      "text": "دبیر جهاندیده را پیش خواند دل آگنده بودش همه برفشاند",
      "lines": [
        "s767-l1",
        "s767-l2"
      ],
      "segs": [
        "s767-g1",
        "s767-g2"
      ]
    },
    "s767-s2": {
      "text": "جهاندار چون کرد آهنگ مرو به ماهوی سوری کنارنگ مرو",
      "lines": [
        "s767-l3",
        "s767-l4"
      ],
      "segs": [
        "s767-g3",
        "s767-g4"
      ]
    },
    "s767-s3": {
      "text": "یکی نامه بنوشت با درد و خشم پر از آرزو دل پر از آب چشم",
      "lines": [
        "s767-l5",
        "s767-l6"
      ],
      "segs": [
        "s767-g5",
        "s767-g6"
      ]
    },
    "s767-s4": {
      "text": "نخست آفرین کرد بر کردگار خداوند دانا و پروردگار",
      "lines": [
        "s767-l7",
        "s767-l8"
      ],
      "segs": [
        "s767-g7",
        "s767-g8"
      ]
    },
    "s767-s5": {
      "text": "خداوند گردنده بهرام و هور خداوند پیل و خداوند مور",
      "lines": [
        "s767-l9",
        "s767-l10"
      ],
      "segs": [
        "s767-g9",
        "s767-g10"
      ]
    },
    "s767-s6": {
      "text": "کند چون بخواهد ز ناچیز چیز که آموزگارش نباید به نیز",
      "lines": [
        "s767-l11",
        "s767-l12"
      ],
      "segs": [
        "s767-g11",
        "s767-g12"
      ]
    },
    "s767-s7": {
      "text": "بگفت آنک ما را چه آمد بروی وزین پادشاهی بشد رنگ و بوی",
      "lines": [
        "s767-l13",
        "s767-l14"
      ],
      "segs": [
        "s767-g13",
        "s767-g14"
      ]
    },
    "s767-s8": {
      "text": "ز رستم کجا کشته شد روز جنگ ز تیمار بر ما جهان گشت تنگ",
      "lines": [
        "s767-l15",
        "s767-l16"
      ],
      "segs": [
        "s767-g15",
        "s767-g16"
      ]
    },
    "s767-s9": {
      "text": "بدست یکی سعد وقاص نام نه بوم و نژاد و نه دانش نه کام",
      "lines": [
        "s767-l17",
        "s767-l18"
      ],
      "segs": [
        "s767-g17",
        "s767-g18"
      ]
    },
    "s767-s10": {
      "text": "کنون تا در طیسفون لشکرست همین زاغ پیسه به پیش اندرست",
      "lines": [
        "s767-l19",
        "s767-l20"
      ],
      "segs": [
        "s767-g19",
        "s767-g20"
      ]
    },
    "s767-s11": {
      "text": "تو با لشکرت رزم را ساز کن سپه را برین بر هم‌آواز کن",
      "lines": [
        "s767-l21",
        "s767-l22"
      ],
      "segs": [
        "s767-g21",
        "s767-g22"
      ]
    },
    "s767-s12": {
      "text": "من اینک پس نامه‌بر سان باد بیایم به نزد تو‌ای پاک و راد",
      "lines": [
        "s767-l23",
        "s767-l24"
      ],
      "segs": [
        "s767-g23",
        "s767-g24"
      ]
    },
    "s767-s13": {
      "text": "فرستاده دیگر از انجمن گزین کرد بینا‌دل و رای‌زن",
      "lines": [
        "s767-l25",
        "s767-l26"
      ],
      "segs": [
        "s767-g25",
        "s767-g26"
      ]
    }
  },
  "segments": {
    "s767-g1": {
      "text": "دبیر جهاندیده را پیش خواند",
      "sid": "s767-s1",
      "lines": [
        "s767-l1"
      ]
    },
    "s767-g2": {
      "text": "دل آگنده بودش همه برفشاند",
      "sid": "s767-s1",
      "lines": [
        "s767-l2"
      ]
    },
    "s767-g3": {
      "text": "جهاندار چون کرد آهنگ مرو",
      "sid": "s767-s2",
      "lines": [
        "s767-l3"
      ]
    },
    "s767-g4": {
      "text": "به ماهوی سوری کنارنگ مرو",
      "sid": "s767-s2",
      "lines": [
        "s767-l4"
      ]
    },
    "s767-g5": {
      "text": "یکی نامه بنوشت با درد و خشم",
      "sid": "s767-s3",
      "lines": [
        "s767-l5"
      ]
    },
    "s767-g6": {
      "text": "پر از آرزو دل پر از آب چشم",
      "sid": "s767-s3",
      "lines": [
        "s767-l6"
      ]
    },
    "s767-g7": {
      "text": "نخست آفرین کرد بر کردگار",
      "sid": "s767-s4",
      "lines": [
        "s767-l7"
      ]
    },
    "s767-g8": {
      "text": "خداوند دانا و پروردگار",
      "sid": "s767-s4",
      "lines": [
        "s767-l8"
      ]
    },
    "s767-g9": {
      "text": "خداوند گردنده بهرام و هور",
      "sid": "s767-s5",
      "lines": [
        "s767-l9"
      ]
    },
    "s767-g10": {
      "text": "خداوند پیل و خداوند مور",
      "sid": "s767-s5",
      "lines": [
        "s767-l10"
      ]
    },
    "s767-g11": {
      "text": "کند چون بخواهد ز ناچیز چیز",
      "sid": "s767-s6",
      "lines": [
        "s767-l11"
      ]
    },
    "s767-g12": {
      "text": "که آموزگارش نباید به نیز",
      "sid": "s767-s6",
      "lines": [
        "s767-l12"
      ]
    },
    "s767-g13": {
      "text": "بگفت آنک ما را چه آمد بروی",
      "sid": "s767-s7",
      "lines": [
        "s767-l13"
      ]
    },
    "s767-g14": {
      "text": "وزین پادشاهی بشد رنگ و بوی",
      "sid": "s767-s7",
      "lines": [
        "s767-l14"
      ]
    },
    "s767-g15": {
      "text": "ز رستم کجا کشته شد روز جنگ",
      "sid": "s767-s8",
      "lines": [
        "s767-l15"
      ]
    },
    "s767-g16": {
      "text": "ز تیمار بر ما جهان گشت تنگ",
      "sid": "s767-s8",
      "lines": [
        "s767-l16"
      ]
    },
    "s767-g17": {
      "text": "بدست یکی سعد وقاص نام",
      "sid": "s767-s9",
      "lines": [
        "s767-l17"
      ]
    },
    "s767-g18": {
      "text": "نه بوم و نژاد و نه دانش نه کام",
      "sid": "s767-s9",
      "lines": [
        "s767-l18"
      ]
    },
    "s767-g19": {
      "text": "کنون تا در طیسفون لشکرست",
      "sid": "s767-s10",
      "lines": [
        "s767-l19"
      ]
    },
    "s767-g20": {
      "text": "همین زاغ پیسه به پیش اندرست",
      "sid": "s767-s10",
      "lines": [
        "s767-l20"
      ]
    },
    "s767-g21": {
      "text": "تو با لشکرت رزم را ساز کن",
      "sid": "s767-s11",
      "lines": [
        "s767-l21"
      ]
    },
    "s767-g22": {
      "text": "سپه را برین بر هم‌آواز کن",
      "sid": "s767-s11",
      "lines": [
        "s767-l22"
      ]
    },
    "s767-g23": {
      "text": "من اینک پس نامه‌بر سان باد",
      "sid": "s767-s12",
      "lines": [
        "s767-l23"
      ]
    },
    "s767-g24": {
      "text": "بیایم به نزد تو‌ای پاک و راد",
      "sid": "s767-s12",
      "lines": [
        "s767-l24"
      ]
    },
    "s767-g25": {
      "text": "فرستاده دیگر از انجمن",
      "sid": "s767-s13",
      "lines": [
        "s767-l25"
      ]
    },
    "s767-g26": {
      "text": "گزین کرد بینا‌دل و رای‌زن",
      "sid": "s767-s13",
      "lines": [
