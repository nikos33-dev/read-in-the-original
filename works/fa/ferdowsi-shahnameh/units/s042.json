: 14, "surface": "چند", "lemma": "چند", "pos": "NOUN", "seg": "s042-g37", "sid": "s042-s19"}, {"s": 15, "e": 19, "surface": "برنا", "lemma": "برنا", "pos": "NOUN", "seg": "s042-g37", "sid": "s042-s19"}, {"s": 20, "e": 21, "surface": "و", "lemma": "و", "pos": "NOUN", "seg": "s042-g37", "sid": "s042-s19"}, {"s": 22, "e": 25, "surface": "پیر", "lemma": "پیر", "pos": "NOUN", "seg": "s042-g37", "sid": "s042-s19"}]}, "s042-l38": {"text": "چنان چون بود راه را ناگزیر", "sids": ["s042-s19"], "tokens": [{"s": 0, "e": 4, "surface": "چنان", "lemma": "چنان", "pos": "NOUN", "seg": "s042-g38", "sid": "s042-s19"}, {"s": 5, "e": 8, "surface": "چون", "lemma": "چون", "pos": "NOUN", "seg": "s042-g38", "sid": "s042-s19"}, {"s": 9, "e": 12, "surface": "بود", "lemma": "بود#است", "pos": "NOUN", "seg": "s042-g38", "sid": "s042-s19"}, {"s": 13, "e": 16, "surface": "راه", "lemma": "راه", "pos": "NOUN", "seg": "s042-g38", "sid": "s042-s19"}, {"s": 17, "e": 19, "surface": "را", "lemma": "را", "pos": "NOUN", "seg": "s042-g38", "sid": "s042-s19"}, {"s": 20, "e": 26, "surface": "ناگزیر", "lemma": "ناگزیر", "pos": "NOUN", "seg": "s042-g38", "sid": "s042-s19"}]}}, "sentences": {"s042-s1": {"text": "یکی نامه بنوشت شاه زمین به خاور خدای و به سالار چین", "lines": ["s042-l1", "s042-l2"], "segs": ["s042-g1", "s042-g2"]}, "s042-s2": {"text": "سر نامه کرد آفرین خدای کجا هست و باشد همیشه به جای", "lines": ["s042-l3", "s042-l4"], "segs": ["s042-g3", "s042-g4"]}, "s042-s3": {"text": "چنین گفت کاین نامه پندمند به نزد دو خورشید گشته بلند", "lines": ["s042-l5", "s042-l6"], "segs": ["s042-g5", "s042-g6"]}, "s042-s4": {"text": "دو سنگی دو جنگی دو شاه زمین میان کیان چون درخشان نگین", "lines": ["s042-l7", "s042-l8"], "segs": ["s042-g7", "s042-g8"]}, "s042-s5": {"text": "از آنکو ز هر گونه دیده جهان شده آشکارا برو بر نهان", "lines": ["s042-l9", "s042-l10"], "segs": ["s042-g9", "s042-g10"]}, "s042-s6": {"text": "گراینده تیغ و گرز گران فروزنده نامدار افسران", "lines": ["s042-l11", "s042-l12"], "segs": ["s042-g11", "s042-g12"]}, "s042-s7": {"text": "نماینده شب به‌روز سپید گشاینده گنج پیش امید", "lines": ["s042-l13", "s042-l14"], "segs": ["s042-g13", "s042-g14"]}, "s042-s8": {"text": "همه رنجها گشته آسان بدوی برو روشنی اندر آورده روی", "lines": ["s042-l15", "s042-l16"], "segs": ["s042-g15", "s042-g16"]}, "s042-s9": {"text": "نخواهم همی خویشتن را کلاه نه آگنده گنج و نه تاج و نه گاه", "lines": ["s042-l17", "s042-l18"], "segs": ["s042-g17", "s042-g18"]}, "s042-s10": {"text": "سه فرزند را خواهم آرام و ناز از آن پس که دیدیم رنج دراز", "lines": ["s042-l19", "s042-l20"], "segs": ["s042-g19", "s042-g20"]}, "s042-s11": {"text": "برادر کزو بود دلتان به درد وگر چند هرگز نزد باد سرد", "lines": ["s042-l21", "s042-l22"], "segs": ["s042-g21", "s042-g22"]}, "s042-s12": {"text": "دوان آمد از بهر آزارتان که بود آرزومند دیدارتان", "lines": ["s042-l23", "s042-l24"], "segs": ["s042-g23", "s042-g24"]}, "s042-s13": {"text": "بیفگند شاهی شما را گزید چنان کز ره نامداران سزید", "lines": ["s042-l25", "s042-l26"], "segs": ["s042-g25", "s042-g26"]}, "s042-s14": {"text": "ز تخت اندر آمد به زین برنشست برفت و میان بندگی را ببست", "lines": ["s042-l27", "s042-l28"], "segs": ["s042-g27", "s042-g28"]}, "s042-s15": {"text": "بدان کو به سال از شما کهترست نوازیدن کهتر اندر خورست", "lines": ["s042-l29", "s042-l30"], "segs": ["s042-g29", "s042-g30"]}, "s042-s16": {"text": "گرامیش دارید و نوشه خورید چو پرورده شد تن روان پرورید", "lines": ["s042-l31", "s042-l32"], "segs": ["s042-g31", "s042-g32"]}, "s042-s17": {"text": "چو از بودنش بگذرد روز چند فرستید با زی منش ارجمند", "lines": ["s042-l33", "s042-l34"], "segs": ["s042-g33", "s042-g34"]}, "s042-s18": {"text": "نهادند بر نامه‌بر مهر شاه ز ایوان بر ایرج گزین کرد راه", "lines": ["s042-l35", "s042-l36"], "segs": ["s042-g35", "s042-g36"]}, "s042-s19": {"text": "بشد با تنی چند برنا و پیر چنان چون بود راه را ناگزیر", "lines": ["s042-l37", "s042-l38"], "segs": ["s042-g37", "s042-g38"]}}, "segments": {"s042-g1": {"text": "یکی نامه بنوشت شاه زمین", "sid": "s042-s1", "lines": ["s042-l1"]}, "s042-g2": {"text": "به خاور خدای و به سالار چین", "sid": "s042-s1", "lines": ["s042-l2"]}, "s042-g3": {"text": "سر نامه کرد آفرین خدای", "sid": "s042-s2", "lines": ["s042-l3"]}, "s042-g4": {"text": "کجا هست و باشد همیشه به جای", "sid": "s042-s2", "lines": ["s042-l4"]}, "s042-g5": {"text": "چنین گفت کاین نامه پندمند", "sid": "s042-s3", "lines": ["s042-l5"]}, "s042-g6": {"text": "به نزد دو خورشید گشته بلند", "sid": "s042-s3", "lines": ["s042-l6"]}, "s042-g7": {"text": "دو سنگی دو جنگی دو شاه زمین", "sid": "s042-s4", "lines": ["s042-l7"]}, "s042-g8": {"text": "میان کیان چون درخشان نگین", "sid": "s042-s4", "lines": ["s042-l8"]}, "s042-g9": {"text": "از آنکو ز هر گونه دیده جهان", "sid": "s042-s5", "lines": ["s042-l9"]}, "s042-g10": {"text": "شده آشکارا برو بر نهان", "sid": "s042-s5", "lines": ["s042-l10"]}, "s042-g11": {"text": "گراینده تیغ و گرز گران", "sid": "s042-s6", "lines": ["s042-l11"]}, "s042-g12": {"text": "فروزنده نامدار افسران", "sid": "s042-s6", "lines": ["s042-l12"]}, "s042-g13": {"text": "نماینده شب به‌روز سپید", "sid": "s042-s7", "lines": ["s042-l13"]}, "s042-g14": {"text": "گشاینده گنج پیش امید", "sid": "s042-s7", "lines": ["s042-l14"]}, "s042-g15": {"text": "همه رنجها گشته آسان بدوی", "sid": "s042-s8", "lines": ["s042-l15"]}, "s042-g16": {"text": "برو روشنی اندر آورده روی", "sid": "s042-s8", "lines": ["s042-l16"]}, "s042-g17": {"text": "نخواهم همی خویشتن را کلاه", "sid": "s042-s9", "lines": ["s042-l17"]}, "s042-g18": {"text": "نه آگنده گنج و نه تاج و نه گاه", "sid": "s042-s9", "lines": ["s042-l18"]}, "s042-g19": {"text": "سه فرزند را خواهم آرام و ناز", "sid": "s042-s10", "lines": ["s042-l19"]}, "s042-g20": {"text": "از آن پس که دیدیم رنج دراز", "sid": "s042-s10", "lines": ["s042-l20"]}, "s042-g21": {"text": "برادر کزو بود دلتان به درد", "sid": "s042-s11", "lines": ["s042-l21"]}, "s042-g22": {"text": "وگر چند هرگز نزد باد سرد", "sid": "s042-s11", "lines": ["s042-l22"]}, "s042-g23": {"text": "دوان آمد از بهر آزارتان", "sid": "s042-s12", "lines": ["s