ace": "کس", "lemma": "کس", "pos": "NOUN", "seg": "s050-g33", "sid": "s050-s17"}, {"s": 16, "e": 21, "surface": "نیامد", "lemma": "نیامد", "pos": "NOUN", "seg": "s050-g33", "sid": "s050-s17"}, {"s": 22, "e": 24, "surface": "به", "lemma": "به", "pos": "NOUN", "seg": "s050-g33", "sid": "s050-s17"}, {"s": 25, "e": 28, "surface": "جنگ", "lemma": "جنگ", "pos": "NOUN", "seg": "s050-g33", "sid": "s050-s17"}]}, "s050-l34": {"text": "دو جنگی گرفتند ساز درنگ", "sids": ["s050-s17"], "tokens": [{"s": 0, "e": 2, "surface": "دو", "lemma": "دو", "pos": "NUM", "seg": "s050-g34", "sid": "s050-s17"}, {"s": 3, "e": 7, "surface": "جنگی", "lemma": "جنگی", "pos": "NOUN", "seg": "s050-g34", "sid": "s050-s17"}, {"s": 8, "e": 14, "surface": "گرفتند", "lemma": "گرفت#گیر", "pos": "NOUN", "seg": "s050-g34", "sid": "s050-s17"}, {"s": 15, "e": 18, "surface": "ساز", "lemma": "ساز", "pos": "NOUN", "seg": "s050-g34", "sid": "s050-s17"}, {"s": 19, "e": 23, "surface": "درنگ", "lemma": "درنگ", "pos": "NOUN", "seg": "s050-g34", "sid": "s050-s17"}]}}, "sentences": {"s050-s1": {"text": "سپیده چو از تیره شب بردمید میان شب تیره اندر خمید", "lines": ["s050-l1", "s050-l2"], "segs": ["s050-g1", "s050-g2"]}, "s050-s2": {"text": "منوچهر برخاست از قلب‌گاه ابا جوشن و تیغ و رومی کلاه", "lines": ["s050-l3", "s050-l4"], "segs": ["s050-g3", "s050-g4"]}, "s050-s3": {"text": "سپه یکسره نعره برداشتند سنان‌ها به ابر اندر افراشتند", "lines": ["s050-l5", "s050-l6"], "segs": ["s050-g5", "s050-g6"]}, "s050-s4": {"text": "پر از خشم سر ابروان پر ز چین همی بر نوشتند روی زمین", "lines": ["s050-l7", "s050-l8"], "segs": ["s050-g7", "s050-g8"]}, "s050-s5": {"text": "چپ و راست و قلب و جناح سپاه بیاراست لشکر چو بایست شاه", "lines": ["s050-l9", "s050-l10"], "segs": ["s050-g9", "s050-g10"]}, "s050-s6": {"text": "زمین شد به کردار کشتی بر آب تو گفتی سوی غرق دارد شتاب", "lines": ["s050-l11", "s050-l12"], "segs": ["s050-g11", "s050-g12"]}, "s050-s7": {"text": "بزد مهره بر کوهه ژنده پیل زمین جنب‌جنبان چو دریای نیل", "lines": ["s050-l13", "s050-l14"], "segs": ["s050-g13", "s050-g14"]}, "s050-s8": {"text": "همان پیش پیلان تبیره زنان خروشان و جوشان و پیلان دمان", "lines": ["s050-l15", "s050-l16"], "segs": ["s050-g15", "s050-g16"]}, "s050-s9": {"text": "یکی بزمگاه‌ست گفتی به‌جای ز شیپور و نالیدن کره نای", "lines": ["s050-l17", "s050-l18"], "segs": ["s050-g17", "s050-g18"]}, "s050-s10": {"text": "برفتند از جای یکسر چو کوه دهاده برآمد ز هر دو گروه", "lines": ["s050-l19", "s050-l20"], "segs": ["s050-g19", "s050-g20"]}, "s050-s11": {"text": "بیابان چو دریای خون شد درست تو گفتی که روی زمین لاله رست", "lines": ["s050-l21", "s050-l22"], "segs": ["s050-g21", "s050-g22"]}, "s050-s12": {"text": "پی ژنده پیلان به خون اندرون چنان چون ز بیجاده باشد ستون", "lines": ["s050-l23", "s050-l24"], "segs": ["s050-g23", "s050-g24"]}, "s050-s13": {"text": "همه چیرگی با منوچهر بود کزو مغز گیتی پر از مهر بود", "lines": ["s050-l25", "s050-l26"], "segs": ["s050-g25", "s050-g26"]}, "s050-s14": {"text": "چنین تا شب تیره سر بر کشید درخشنده خورشید شد ناپدید", "lines": ["s050-l27", "s050-l28"], "segs": ["s050-g27", "s050-g28"]}, "s050-s15": {"text": "زمانه به یک سان ندارد درنگ گهی شهد و نوش است و گاهی شرنگ", "lines": ["s050-l29", "s050-l30"], "segs": ["s050-g29", "s050-g30"]}, "s050-s16": {"text": "دل تور و سلم اندر آمد به‌جوش به راه شبیخون نهادند گوش", "lines": ["s050-l31", "s050-l32"], "segs": ["s050-g31", "s050-g32"]}, "s050-s17": {"text": "چو شب روز شد کس نیامد به جنگ دو جنگی گرفتند ساز درنگ", "lines": ["s050-l33", "s050-l34"], "segs": ["s050-g33", "s050-g34"]}}, "segments": {"s050-g1": {"text": "سپیده چو از تیره شب بردمید", "sid": "s050-s1", "lines": ["s050-l1"]}, "s050-g2": {"text": "میان شب تیره اندر خمید", "sid": "s050-s1", "lines": ["s050-l2"]}, "s050-g3": {"text": "منوچهر برخاست از قلب‌گاه", "sid": "s050-s2", "lines": ["s050-l3"]}, "s050-g4": {"text": "ابا جوشن و تیغ و رومی کلاه", "sid": "s050-s2", "lines": ["s050-l4"]}, "s050-g5": {"text": "سپه یکسره نعره برداشتند", "sid": "s050-s3", "lines": ["s050-l5"]}, "s050-g6": {"text": "