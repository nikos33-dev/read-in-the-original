6"], "segs": ["s282-g5", "s282-g6"]}, "s282-s4": {"text": "بگشتند ز اندازه بیرون به جنگ ز بس کوفتن گشت پیکار تنگ", "lines": ["s282-l7", "s282-l8"], "segs": ["s282-g7", "s282-g8"]}, "s282-s5": {"text": "فروماند اسبان جنگی ز تگ که گفتی به تنشان نجنبید رگ", "lines": ["s282-l9", "s282-l10"], "segs": ["s282-g9", "s282-g10"]}, "s282-s6": {"text": "چو خورشید تابان ز گنبد بگشت به کردار آهن بتفسید دشت", "lines": ["s282-l11", "s282-l12"], "segs": ["s282-g11", "s282-g12"]}, "s282-s7": {"text": "چنان تشنه گشتند کز جای خویش نجنبید و ننهاد کس پای پیش", "lines": ["s282-l13", "s282-l14"], "segs": ["s282-g13", "s282-g14"]}, "s282-s8": {"text": "زبان برگشادند یک با دگر که اکنون ز گرمی بسوزد جگر", "lines": ["s282-l15", "s282-l16"], "segs": ["s282-g15", "s282-g16"]}, "s282-s9": {"text": "بباید برآسود و دم برزدن پس آنگه سوی جنگ بازآمدن", "lines": ["s282-l17", "s282-l18"], "segs": ["s282-g17", "s282-g18"]}, "s282-s10": {"text": "برفتند و اسبان جنگی به جای فراز آوریدند و بستند پای", "lines": ["s282-l19", "s282-l20"], "segs": ["s282-g19", "s282-g20"]}, "s282-s11": {"text": "به آسودگی باز برخاستند به پیکار کینه بیاراستند", "lines": ["s282-l21", "s282-l22"], "segs": ["s282-g21", "s282-g22"]}, "s282-s12": {"text": "به کردار آتش ز نیزه سوار همی گشت بر مرکز کارزار", "lines": ["s282-l23", "s282-l24"], "segs": ["s282-g23", "s282-g24"]}, "s282-s13": {"text": "بدآنگه که زنگه بر او دست یافت سنان سوی او کرد و اندر شتافت", "lines": ["s282-l25", "s282-l26"], "segs": ["s282-g25", "s282-g26"]}, "s282-s14": {"text": "یکی نیزه زد بر کمرگاه اوی کز اسبش نگون کرد و برزد به روی", "lines": ["s282-l27", "s282-l28"], "segs": ["s282-g27", "s282-g28"]}, "s282-s15": {"text": "چو رعد خروشان یکی ویله کرد که گفتی بدرید دشت نبرد", "lines": ["s282-l29", "s282-l30"], "segs": ["s282-g29", "s282-g30"]}, "s282-s16": {"text": "فرود آمد از باره شد نزد اوی بر آن خاک تفته کشیدش به روی", "lines": ["s282-l31", "s282-l32"], "segs": ["s282-g31", "s282-g32"]}, "s282-s17": {"text": "مر او را به چاره ز روی زمین نگون اندر افگند بر پشت زین", "lines": ["s282-l33", "s282-l34"], "segs": ["s282-g33", "s282-g34"]}, "s282-s18": {"text": "نشست از بر اسب و بالا گرفت به ترکان چه آمد ز بخت‌ای شگفت", "lines": ["s282-l35", "s282-l36"], "segs": ["s282-g35", "s282-g36"]}, "s282-s19": {"text": "بر آن کوه فرخ برآمد ز پست یکی گرگ پیکر درفشی به دست", "lines": ["s282-l37", "s282-l38"], "segs": ["s282-g37", "s282-g38"]}, "s282-s20": {"text": "بشد پیش یاران و کرد آفرین ابر شاه و بر پهلوان زمین", "lines": ["s282-l39", "s282-l40"], "segs": ["s282-g39", "s282-g40"]}}, "segments": {"s282-g1": {"text": "به هشتم ز گردان ناماوران", "sid": "s282-s1", "lines": ["s282-l1"]}, "s282-g2": {"text": "بشد ساخته زنگه شاوران", "sid": "s282-s1", "lines": ["s282-l2"]}, "s282-g3": {"text": "که همرزمش از تخم اوخواست بود", "sid": "s282-s2", "lines": ["s282-l3"]}, "s282-g4": {"text": "که از جنگ هرگز نه بر کاست بود", "sid": "s282-s2", "lines": ["s282-l4"]}, "s282-g5": {"text": "گرفتند هر دو عمود گران", "sid": "s282-s3", "lines": ["s282-l5"]}, "s282-g6": {"text": "چو او خواست با زنگه شاوران", "sid": "s282-s3", "lines": ["s282-l6"]}, "s282-g7": {"text": "بگشتند ز اندازه بیرون به جنگ", "sid": "s282-s4", "lines": ["s282-l7"]}, "s282-g8": {"text": "ز بس کوفتن گشت پیکار تنگ", "sid": "s282-s4", "lines": ["s282-l8"]}, "s282-g9": {"text": "فروماند اسبان جنگی ز تگ", "sid": "s282-s5", "lines": ["s282-l9"]}, "s282-g10": {"text": "که گفتی به تنشان نجنبید رگ", "sid": "s282-s5", "lines": ["s282-l10"]}, "s282-g11": {"text": "چو خورشید تابان ز گنبد بگشت", "sid": "s282-s6", "lines": ["s282-l11"]}, "s282-g12": {"text": "به کردار آهن بتفسید دشت", "sid": "s282-s6", "lines": ["s282-l12"]}, "s282-g13": {"text": "چنان تشنه گشتند کز جای خویش", "sid": "s282-s7", "lines": ["s282-l13"]}, "s282-g14": {"text": "نجنبید و ننهاد کس پای پیش", "sid": "s282-s7", "lines": ["s282-l14"]}, "s282-g15": {"text": "زبان برگشادند یک با دگر", "sid": "s282-s8", "lines": ["s282-l15"]}, "s282-g16": {"text": "که اکنون ز گرمی بسوزد جگر", "sid": "s282-s8", "lines": ["s282-l16"]}, "s282-g17": {"