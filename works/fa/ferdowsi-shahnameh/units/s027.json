}, {"s": 16, "e": 19, "surface": "کاخ", "lemma": "کاخ", "pos": "NOUN", "seg": "s027-g34", "sid": "s027-s17"}, {"s": 20, "e": 24, "surface": "بلند", "lemma": "بلند", "pos": "NOUN", "seg": "s027-g34", "sid": "s027-s17"}]}}, "sentences": {"s027-s1": {"text": "نشد سیر ضحاک از آن جست جوی شد از گاو گیتی پر از گفت‌گوی", "lines": ["s027-l1", "s027-l2"], "segs": ["s027-g1", "s027-g2"]}, "s027-s2": {"text": "دوان مادر آمد سوی مرغزار چنین گفت با مرد زنهاردار", "lines": ["s027-l3", "s027-l4"], "segs": ["s027-g3", "s027-g4"]}, "s027-s3": {"text": "که اندیشه‌ای در دلم ایزدی فراز آمده‌ست از ره بخردی", "lines": ["s027-l5", "s027-l6"], "segs": ["s027-g5", "s027-g6"]}, "s027-s4": {"text": "همی کرد باید کزین چاره نیست که فرزند و شیرین روانم یکیست", "lines": ["s027-l7", "s027-l8"], "segs": ["s027-g7", "s027-g8"]}, "s027-s5": {"text": "ببرم پی از خاک جادوستان شوم تا سر مرز هندوستان", "lines": ["s027-l9", "s027-l10"], "segs": ["s027-g9", "s027-g10"]}, "s027-s6": {"text": "شوم ناپدید از میان گروه برم خوب‌رخ را به البرز کوه", "lines": ["s027-l11", "s027-l12"], "segs": ["s027-g11", "s027-g12"]}, "s027-s7": {"text": "بیاورد فرزند را چون نوند چو مرغان بر آن تیغ کوه بلند", "lines": ["s027-l13", "s027-l14"], "segs": ["s027-g13", "s027-g14"]}, "s027-s8": {"text": "یکی مرد دینی بر آن کوه بود که از کار گیتی بی‌اندوه بود", "lines": ["s027-l15", "s027-l16"], "segs": ["s027-g15", "s027-g16"]}, "s027-s9": {"text": "فرانک بدو گفت کای پاکدین منم سوگواری ز ایران‌زمین", "lines": ["s027-l17", "s027-l18"], "segs": ["s027-g17", "s027-g18"]}, "s027-s10": {"text": "بدان کاین گرانمایه فرزند من همی بود خواهد سر انجمن", "lines": ["s027-l19", "s027-l20"], "segs": ["s027-g19", "s027-g20"]}, "s027-s11": {"text": "تو را بود باید نگهبان او پدروار لرزنده بر جان او", "lines": ["s027-l21", "s027-l22"], "segs": ["s027-g21", "s027-g22"]}, "s027-s12": {"text": "پذیرفت فرزند او نیکمرد نیاورد هرگز بدو باد سرد", "lines": ["s027-l23", "s027-l24"], "segs": ["s027-g23", "s027-g24"]}, "s027-s13": {"text": "خبر شد به ضحاک بدروزگار از آن گاو برمایه و مرغزار", "lines": ["s027-l25", "s027-l26"], "segs": ["s027-g25", "s027-g26"]}, "s027-s14": {"text": "بیامد از آن کینه چون پیل مست مر آن گاو برمایه را کرد پست", "lines": ["s027-l27", "s027-l28"], "segs": ["s027-g27", "s027-g28"]}, "s027-s15": {"text": "همه هر چه دید اندر او چارپای بیفگند و زیشان بپرداخت جای", "lines": ["s027-l29", "s027-l30"], "segs": ["s027-g29", "s027-g30"]}, "s027-s16": {"text": "سبک سوی خان فریدون شتافت فراوان پژوهید و کس را نیافت", "lines": ["s027-l31", "s027-l32"], "segs": ["s027-g31", "s027-g32"]}, "s027-s17": {"text": "به ایوان او آتش اندر فگند ز پای اندر آورد کاخ بلند", "lines": ["s027-l33", "s027-l34"], "segs": ["s027-g33", "s027-g34"]}}, "segments": {"s027-g1": {"text": "نشد سیر ضحاک از آن جست جوی", "sid": "s027-s1", "lines": ["s027-l1"]}, "s027-g2": {"text": "شد از گاو گیتی پر از گفت‌گوی", "sid": "s027-s1", "lines": ["s027-l2"]}, "s027-g3": {"text": "دوان مادر آمد سوی مرغزار", "sid": "s027-s2", "lines": ["s027-l3"]}, "s027-g4": {"text": "چنین گفت با مرد زنهاردار", "sid": "s027-s2", "lines": ["s027-l4"]}, "s027-g5": {"text": "که اندیشه‌ای در دلم ایزدی", "sid": "s027-s3", "lines": ["s027-l5"]}, "s027-g6": {"text": "فراز آمده‌ست از ره بخردی", "sid": "s027-s3", "lines": ["s027-l6"]}, "s027-g7": {"text": "همی کرد باید کزین چاره نیست", "sid": "s027-s4", "lines": ["s027-l7"]}, "s027-g8": {"text": "که فرزند و شیرین روانم یکیست", "sid": "s027-s4", "lines": ["s027-l8"]}, "s027-g9": {"text": "ببرم پی از خاک جادوستان", "sid": "s027-s5", "lines": ["s027-l9"]}, "s027-g10": {"text": "شوم تا سر مرز هندوستان", "sid": "s027-s5", "lines": ["s027-l10"]}, "s027-g11": {"text": "شوم ناپدید از میان گروه", "sid": "s027-s6", "lines": ["s027-l11"]}, "s027-g12": {"text": "برم خوب‌رخ را به البرز کوه", "sid": "s027-s6", "lines": ["s027-l12"]}, "s027-g13": {"text": "بیاورد فرزند را چون نوند", "sid": "s027-s7", "lines": ["s027-l13"]}, "s027-g14": {"text": "چو مرغان بر آن تیغ کوه بلند", "sid": "s027-s7", "lines": ["s027-l14"]}, "s027-g15": {"text": "یک