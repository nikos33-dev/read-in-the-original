      "sid": "s680-s5",
      "lines": [
        "s680-l10"
      ]
    },
    "s680-g11": {
      "text": "ازیشان برزم اندرون نیست باک",
      "sid": "s680-s6",
      "lines": [
        "s680-l11"
      ]
    },
    "s680-g12": {
