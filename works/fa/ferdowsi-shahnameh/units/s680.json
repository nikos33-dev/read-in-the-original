  "sentences": {
    "s680-s1": {
      "text": "وزین روی بنشست بهرام گرد بزرگان برفتند با او وخرد",
      "lines": [
        "s680-l1",
        "s680-l2"
      ],
      "segs": [
        "s680-g1",
        "s680-g2"
      ]
    },
    "s680-s2": {
      "text": "سپهبد بپرسید زان سرکشان که آمد زخویشان شما را نشان",
      "lines": [
        "s680-l3",
        "s680-l4"
      ],
      "segs": [
        "s680-g3",
        "s680-g4"
      ]
    },
    "s680-s3": {
      "text": "فرستید هرکس که دارید خویش که باشند یکدل به گفتار وکیش",
      "lines": [
        "s680-l5",
        "s680-l6"
      ],
      "segs": [
        "s680-g5",
        "s680-g6"
      ]
    },
    "s680-s4": {
      "text": "گریشان بیایند وفرمان کنند به پیمان روان را گروگان کنند",
      "lines": [
        "s680-l7",
        "s680-l8"
      ],
      "segs": [
        "s680-g7",
        "s680-g8"
      ]
    },
    "s680-s5": {
      "text": "سپه ماند از بردع واردبیل از ارمنیه نیز بی‌مرد وخیل",
      "lines": [
        "s680-l9",
        "s680-l10"
      ],
      "segs": [
        "s680-g9",
        "s680-g10"
      ]
    },
    "s680-s6": {
      "text": "ازیشان برزم اندرون نیست باک چه مردان بردع چه یک مشت خاک",
      "lines": [
        "s680-l11",
        "s680-l12"
      ],
      "segs": [
        "s680-g11",
        "s680-g12"
      ]
    },
    "s680-s7": {
      "text": "شنیدند گردنکشان این سخن که بهرام جنگ‌آور افگند بن",
      "lines": [
        "s680-l13",
        "s680-l14"
      ],
      "segs": [
        "s680-g13",
        "s680-g14"
      ]
    },
    "s680-s8": {
      "text": "زلشکر گزیدند مردی دبیر سخن گوی و داننده ویادگیر",
      "lines": [
        "s680-l15",
        "s680-l16"
      ],
      "segs": [
        "s680-g15",
        "s680-g16"
      ]
    },
    "s680-s9": {
      "text": "بیامد گوی با دلی پر ز راز همی‌بود پویان شب دیریاز",
      "lines": [
        "s680-l17",
        "s680-l18"
      ],
      "segs": [
        "s680-g17",
        "s680-g18"
      ]
    },
    "s680-s10": {
      "text": "بگفت آنچ بشنید زان مهتران ازان نامداران وکنداوران",
      "lines": [
        "s680-l19",
        "s680-l20"
      ],
      "segs": [
        "s680-g19",
        "s680-g20"
      ]
    },
    "s680-s11": {
      "text": "از ایرانیان پاسخ ایدون شنید که تا رزم لشکر نیاید پدید",
      "lines": [
        "s680-l21",
        "s680-l22"
      ],
      "segs": [
        "s680-g21",
        "s680-g22"
      ]
    },
    "s680-s12": {
      "text": "یکی مازخسرو نگردیم باز بترسیم کین کارگردد دراز",
      "lines": [
        "s680-l23",
        "s680-l24"
      ],
      "segs": [
        "s680-g23",
        "s680-g24"
      ]
    },
    "s680-s13": {
      "text": "مباشید ایمن بران رزمگاه که خسرو شبیخون کند با سپاه",
      "lines": [
        "s680-l25",
        "s680-l26"
      ],
      "segs": [
        "s680-g25",
        "s680-g26"
      ]
    },
    "s680-s14": {
      "text": "چو پاسخ شنید آن فرستاده مرد سوی لشکر پهلوان شد چو گرد",
      "lines": [
        "s680-l27",
        "s680-l28"
      ],
      "segs": [
        "s680-g27",
        "s680-g28"
      ]
    },
    "s680-s15": {
      "text": "همه لشکرآتش برافروختند بهر جای شمعی همی‌سوختند",
      "lines": [
        "s680-l29",
        "s680-l30"
      ],
      "segs": [
        "s680-g29",
        "s680-g30"
      ]
    }
  },
  "segments": {
    "s680-g1": {
      "text": "وزین روی بنشست بهرام گرد",
