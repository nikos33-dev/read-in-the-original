      "sid": "s680-s3",
      "lines": [
        "s680-l6"
      ]
    },
    "s680-g7": {
      "text": "گریشان بیایند وفرمان کنند",
      "sid": "s680-s4",
      "lines": [
        "s680-l7"
      ]
    },
    "s680-g8": {
      "text": "به پیمان روان را گروگان کنند",
      "sid": "s680-s4",
      "lines": [
        "s680-l8"
      ]
    },
    "s680-g9": {
      "text": "سپه ماند از بردع واردبیل",
      "sid": "s680-s5",
      "lines": [
        "s680-l9"
      ]
    },
    "s680-g10": {
