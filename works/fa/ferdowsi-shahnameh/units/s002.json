urface": "شاخ", "lemma": "شاخ", "pos": "NOUN", "seg": "s002-g37", "sid": "s002-s19"}, {"s": 21, "e": 24, "surface": "سخن", "lemma": "سخن", "pos": "NOUN", "seg": "s002-g37", "sid": "s002-s19"}]}, "s002-l38": {"text": "بدانی که دانش نیاید به بن", "sids": ["s002-s19"], "tokens": [{"s": 0, "e": 5, "surface": "بدانی", "lemma": "دانست#دان", "pos": "NOUN", "seg": "s002-g38", "sid": "s002-s19"}, {"s": 6, "e": 8, "surface": "که", "lemma": "که", "pos": "NOUN", "seg": "s002-g38", "sid": "s002-s19"}, {"s": 9, "e": 13, "surface": "دانش", "lemma": "دانش", "pos": "NOUN", "seg": "s002-g38", "sid": "s002-s19"}, {"s": 14, "e": 19, "surface": "نیاید", "lemma": "نیاید", "pos": "NOUN", "seg": "s002-g38", "sid": "s002-s19"}, {"s": 20, "e": 22, "surface": "به", "lemma": "به", "pos": "NOUN", "seg": "s002-g38", "sid": "s002-s19"}, {"s": 23, "e": 25, "surface": "بن", "lemma": "بن", "pos": "NOUN", "seg": "s002-g38", "sid": "s002-s19"}]}}, "sentences": {"s002-s1": {"text": "کنون‌ای خردمند وصف خرد بدین جایگه گفتن اندر خورد", "lines": ["s002-l1", "s002-l2"], "segs": ["s002-g1", "s002-g2"]}, "s002-s2": {"text": "کنون تا چه داری بیار از خرد که گوش نیوشنده زو بر خورد", "lines": ["s002-l3", "s002-l4"], "segs": ["s002-g3", "s002-g4"]}, "s002-s3": {"text": "خرد بهتر از هر چه ایزد بداد ستایش خرد را به از راه داد", "lines": ["s002-l5", "s002-l6"], "segs": ["s002-g5", "s002-g6"]}, "s002-s4": {"text": "خرد رهنمای و خرد دلگشای خرد دست گیرد به هر دو سرای", "lines": ["s002-l7", "s002-l8"], "segs": ["s002-g7", "s002-g8"]}, "s002-s5": {"text": "از او شادمانی وزویت غمی است وزویت فزونی وزویت کمی است", "lines": ["s002-l9", "s002-l10"], "segs": ["s002-g9", "s002-g10"]}, "s002-s6": {"text": "خرد تیره و مرد روشن‌روان نباشد همی شادمان یک زمان", "lines": ["s002-l11", "s002-l12"], "segs": ["s002-g11", "s002-g12"]}, "s002-s7": {"text": "چه گفت آن خردمند مرد خرد که دانا ز گفتار او بر خورد", "lines": ["s002-l13", "s002-l14"], "segs": ["s002-g13", "s002-g14"]}, "s002-s8": {"text": "کسی کو خرد را ندارد ز پیش دلش گردد از کرده خویش ریش", "lines": ["s002-l15", "s002-l16"], "segs": ["s002-g15", "s002-g16"]}, "s002-s9": {"text": "هشیوار دیوانه خواند ورا همان خویش بیگانه داند ورا", "lines": ["s002-l17", "s002-l18"], "segs": ["s002-g17", "s002-g18"]}, "s002-s10": {"text": "از اویی به هر دو سرای ارجمند گسسته خرد پای دارد به بند", "lines": ["s002-l19", "s002-l20"], "segs": ["s002-g19", "s002-g20"]}, "s002-s11": {"text": "خرد چشم جان است چون بنگری تو بی‌چشم شادان جهان نسپری", "lines": ["s002-l21", "s002-l22"], "segs": ["s002-g21", "s002-g22"]}, "s002-s12": {"text": "نخست‌آفرینش خرد را شناس نگهبان جان است و آن سه پاس", "lines": ["s002-l23", "s002-l24"], "segs": ["s002-g23", "s002-g24"]}, "s002-s13": {"text": "سه پاس تو چشم است و گوش و زبان کز این سه رسد نیک و بد بی‌گمان", "lines": ["s002-l25", "s002-l26"], "segs": ["s002-g25", "s002-g26"]}, "s002-s14": {"text": "خرد را و جان را که یارد ستود و‌گر من ستایم که یارد شنود", "lines": ["s002-l27", "s002-l28"], "segs": ["s002-g27", "s002-g28"]}, "s002-s15": {"text": "حکیما چو کس نیست گفتن چه سود از این پس بگو کآفرینش چه بود", "lines": ["s002-l29", "s002-l30"], "segs": ["s002-g29", "s002-g30"]}, "s002-s16": {"text": "تویی کرده کردگار جهان ببینی همی آشکار و نهان", "lines": ["s002-l31", "s002-l32"], "segs": ["s002-g31", "s002-g32"]}, "s002-s17": {"text": "به گفتار دانندگان راه جوی به گیتی بپوی و به هر کس بگوی", "lines": ["s002-l33", "s002-l34"], "segs": ["s002-g33", "s002-g34"]}, "s002-s18": {"text": "ز هر دانشی چون سخن بشنوی از آموختن یک زمان نغنوی", "lines": ["s002-l35", "s002-l36"], "segs": ["s002-g35", "s002-g36"]}, "s002-s19": {"text": "چو دیدار یابی به شاخ سخن بدانی که دانش نیاید به بن", "lines": ["s002-l37", "s002-l38"], "segs": ["s002-g37", "s002-g38"]}}, "segments": {"s002-g1": {"text": "کنون‌ای خردمند وصف خرد", "sid": "s002-s1", "lines": ["s002-l1"]}, "s002-g2": {"text": "بدین جایگه گفتن اندر خورد", "sid": "s002-s1", "lines": ["s002-l2"]}, "s002-g3": {"text": "کنون تا چه داری بیار از خرد", "sid": "s002-s2", "lines": ["s002-l3"]}, "s002-g4": {"tex