21"], "tokens": [{"s": 0, "e": 6, "surface": "ندیدند", "lemma": "دید#بین", "pos": "NOUN", "seg": "s483-g42", "sid": "s483-s21"}, {"s": 7, "e": 10, "surface": "زان", "lemma": "زان", "pos": "NOUN", "seg": "s483-g42", "sid": "s483-s21"}, {"s": 11, "e": 13, "surface": "پس", "lemma": "پس", "pos": "NOUN", "seg": "s483-g42", "sid": "s483-s21"}, {"s": 14, "e": 16, "surface": "کس", "lemma": "کس", "pos": "NOUN", "seg": "s483-g42", "sid": "s483-s21"}, {"s": 17, "e": 21, "surface": "اندر", "lemma": "اندر", "pos": "NOUN", "seg": "s483-g42", "sid": "s483-s21"}, {"s": 22, "e": 26, "surface": "جهان", "lemma": "جهان", "pos": "NOUN", "seg": "s483-g42", "sid": "s483-s21"}]}, "s483-l43": {"text": "ز گنج نهان کرده بر کوهسار", "sids": ["s483-s22"], "tokens": [{"s": 0, "e": 1, "surface": "ز", "lemma": "ز", "pos": "NOUN", "seg": "s483-g43", "sid": "s483-s22"}, {"s": 2, "e": 5, "surface": "گنج", "lemma": "گنج", "pos": "NOUN", "seg": "s483-g43", "sid": "s483-s22"}, {"s": 6, "e": 10, "surface": "نهان", "lemma": "نهان", "pos": "NOUN", "seg": "s483-g43", "sid": "s483-s22"}, {"s": 11, "e": 15, "surface": "کرده", "lemma": "کرده", "pos": "NOUN", "seg": "s483-g43", "sid": "s483-s22"}, {"s": 16, "e": 18, "surface": "بر", "lemma": "بر", "pos": "NOUN", "seg": "s483-g43", "sid": "s483-s22"}, {"s": 19, "e": 25, "surface": "کوهسار", "lemma": "کوهسار", "pos": "NOUN", "seg": "s483-g43", "sid": "s483-s22"}]}, "s483-l44": {"text": "بیاورد با خویشتن یادگار", "sids": ["s483-s22"], "tokens": [{"s": 0, "e": 6, "surface": "بیاورد", "lemma": "بیاورد", "pos": "NOUN", "seg": "s483-g44", "sid": "s483-s22"}, {"s": 7, "e": 9, "surface": "با", "lemma": "با", "pos": "NOUN", "seg": "s483-g44", "sid": "s483-s22"}, {"s": 10, "e": 16, "surface": "خویشتن", "lemma": "خویشتن", "pos": "NOUN", "seg": "s483-g44", "sid": "s483-s22"}, {"s": 17, "e": 23, "surface": "یادگار", "lemma": "یادگار", "pos": "NOUN", "seg": "s483-g44", "sid": "s483-s22"}]}}, "sentences": {"s483-s1": {"text": "ازان پس بفرمود کان جام زرد بیارند پر کرده از آب سرد", "lines": ["s483-l1", "s483-l2"], "segs": ["s483-g1", "s483-g2"]}, "s483-s2": {"text": "همی خورد زان جام زر هرکس آب ز شبگیر تا بود هنگام خواب", "lines": ["s483-l3", "s483-l4"], "segs": ["s483-g3", "s483-g4"]}, "s483-s3": {"text": "بخوردند آب از پی خرمی ز خوردن نیامد بدو در کمی", "lines": ["s483-l5", "s483-l6"], "segs": ["s483-g5", "s483-g6"]}, "s483-s4": {"text": "بدان فیلسوف آن زمان شاه گفت که این دانش از من نباید نهفت", "lines": ["s483-l7", "s483-l8"], "segs": ["s483-g7", "s483-g8"]}, "s483-s5": {"text": "که افزایش آب این جام چیست نجومیست‌گر آلت هندویست", "lines": ["s483-l9", "s483-l10"], "segs": ["s483-g9", "s483-g10"]}, "s483-s6": {"text": "چنین داد پاسخ که‌ای شهریار تو این جام را خوارمایه مدار", "lines": ["s483-l11", "s483-l12"], "segs": ["s483-g11", "s483-g12"]}, "s483-s7": {"text": "که این در بسی سالیان کرده‌اند بدین در بسی رنجها برده‌اند", "lines": ["s483-l13", "s483-l14"], "segs": ["s483-g13", "s483-g14"]}, "s483-s8": {"text": "ز اختر شناسان هر کشوری به جایی که بد نامور مهتری", "lines": ["s483-l15", "s483-l16"], "segs": ["s483-g15", "s483-g16"]}, "s483-s9": {"text": "بر کید بودند کین جام کرد به‌روز سپید و شب لاژورد", "lines": ["s483-l17", "s483-l18"], "segs": ["s483-g17", "s483-g18"]}, "s483-s10": {"text": "همی طبع اختر نگه داشتند فراوان درین روز بگذاشتند", "lines": ["s483-l19", "s483-l20"], "segs": ["s483-g19", "s483-g20"]}, "s483-s11": {"text": "تو از مغنیاطیس گیر این نشان که او را کسی کرد ز آهن‌کشان", "lines": ["s483-l21", "s483-l22"], "segs": ["s483-g21", "s483-g22"]}, "s483-s12": {"text": "به طبع این‌چنین هم شدست آب‌کش ز گردون پذیره همی آب خوش", "lines": ["s483-l23", "s483-l24"], "segs": ["s483-g23", "s483-g24"]}, "s483-s13": {"text": "همی آب یابد چو گیرد کمی نبیند به روشن دو چشم آدمی", "lines": ["s483-l25", "s483-l26"], "segs": ["s483-g25", "s483-g26"]}, "s483-s14": {"text": "چو گفتار دانا پسند آمدش سخنهای او سودمند آمدش", "lines": ["s483-l27", "s483-l28"], "segs": ["s483-g27", "s483-g28"]}, "s483-s15": {"text": "چنین گفت پیران میلاد را که من عهد ک