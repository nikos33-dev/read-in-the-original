"sid": "s466-s18"}, {"s": 23, "e": 26, "surface": "جفت", "lemma": "جفت", "pos": "NOUN", "seg": "s466-g36", "sid": "s466-s18"}]}, "s466-l37": {"text": "کسی کو گراید به پیوند اوی", "sids": ["s466-s19"], "tokens": [{"s": 0, "e": 3, "surface": "کسی", "lemma": "کسی", "pos": "NOUN", "seg": "s466-g37", "sid": "s466-s19"}, {"s": 4, "e": 6, "surface": "کو", "lemma": "کو", "pos": "NOUN", "seg": "s466-g37", "sid": "s466-s19"}, {"s": 7, "e": 12, "surface": "گراید", "lemma": "گراید", "pos": "NOUN", "seg": "s466-g37", "sid": "s466-s19"}, {"s": 13, "e": 15, "surface": "به", "lemma": "به", "pos": "NOUN", "seg": "s466-g37", "sid": "s466-s19"}, {"s": 16, "e": 21, "surface": "پیوند", "lemma": "پیوند", "pos": "NOUN", "seg": "s466-g37", "sid": "s466-s19"}, {"s": 22, "e": 25, "surface": "اوی", "lemma": "اوی", "pos": "NOUN", "seg": "s466-g37", "sid": "s466-s19"}]}, "s466-l38": {"text": "به پوشیده‌رویان و فرزند اوی", "sids": ["s466-s19"], "tokens": [{"s": 0, "e": 2, "surface": "به", "lemma": "به", "pos": "NOUN", "seg": "s466-g38", "sid": "s466-s19"}, {"s": 3, "e": 15, "surface": "پوشیده‌رویان", "lemma": "پوشیده‌رو", "pos": "NOUN", "seg": "s466-g38", "sid": "s466-s19"}, {"s": 16, "e": 17, "surface": "و", "lemma": "و", "pos": "NOUN", "seg": "s466-g38", "sid": "s466-s19"}, {"s": 18, "e": 23, "surface": "فرزند", "lemma": "فرزند", "pos": "NOUN", "seg": "s466-g38", "sid": "s466-s19"}, {"s": 24, "e": 27, "surface": "اوی", "lemma": "اوی", "pos": "NOUN", "seg": "s466-g38", "sid": "s466-s19"}]}, "s466-l39": {"text": "نبیند مگر تخته گور تخت", "sids": ["s466-s20"], "tokens": [{"s": 0, "e": 5, "surface": "نبیند", "lemma": "دید#بین", "pos": "NOUN", "seg": "s466-g39", "sid": "s466-s20"}, {"s": 6, "e": 9, "surface": "مگر", "lemma": "مگر", "pos": "NOUN", "seg": "s466-g39", "sid": "s466-s20"}, {"s": 10, "e": 14, "surface": "تخته", "lemma": "تخته", "pos": "NOUN", "seg": "s466-g39", "sid": "s466-s20"}, {"s": 15, "e": 18, "surface": "گور", "lemma": "گور", "pos": "NOUN", "seg": "s466-g39", "sid": "s466-s20"}, {"s": 19, "e": 22, "surface": "تخت", "lemma": "تخت", "pos": "NOUN", "seg": "s466-g39", "sid": "s466-s20"}]}, "s466-l40": {"text": "گر آویخته سر ز شاخ درخت", "sids": ["s466-s20"], "tokens": [{"s": 0, "e": 2, "surface": "گر", "lemma": "گر", "pos": "NOUN", "seg": "s466-g40", "sid": "s466-s20"}, {"s": 3, "e": 9, "surface": "آویخته", "lemma": "آویخته", "pos": "NOUN", "seg": "s466-g40", "sid": "s466-s20"}, {"s": 10, "e": 12, "surface": "سر", "lemma": "سر", "pos": "NOUN", "seg": "s466-g40", "sid": "s466-s20"}, {"s": 13, "e": 14, "surface": "ز", "lemma": "ز", "pos": "NOUN", "seg": "s466-g40", "sid": "s466-s20"}, {"s": 15, "e": 18, "surface": "شاخ", "lemma": "شاخ", "pos": "NOUN", "seg": "s466-g40", "sid": "s466-s20"}, {"s": 19, "e": 23, "surface": "درخت", "lemma": "درخت", "pos": "NOUN", "seg": "s466-g40", "sid": "s466-s20"}]}, "s466-l41": {"text": "همه به اصفهانند بی‌درد و رنج", "sids": ["s466-s21"], "tokens": [{"s": 0, "e": 3, "surface": "همه", "lemma": "همه", "pos": "NOUN", "seg": "s466-g41", "sid": "s466-s21"}, {"s": 4, "e": 6, "surface": "به", "lemma": "به", "pos": "NOUN", "seg": "s466-g41", "sid": "s466-s21"}, {"s": 7, "e": 15, "surface": "اصفهانند", "lemma": "اصفهانند", "pos": "NOUN", "seg": "s466-g41", "sid": "s466-s21"}, {"s": 16, "e": 22, "surface": "بی‌درد", "lemma": "بی‌درد", "pos": "NOUN", "seg": "s466-g41", "sid": "s466-s21"}, {"s": 23, "e": 24, "surface": "و", "lemma": "و", "pos": "NOUN", "seg": "s466-g41", "sid": "s466-s21"}, {"s": 25, "e": 28, "surface": "رنج", "lemma": "رنج", "pos": "NOUN", "seg": "s466-g41", "sid": "s466-s21"}]}, "s466-l42": {"text": "ازیشان مبادا که خواهیم گنج", "sids": ["s466-s21"], "tokens": [{"s": 0, "e": 6, "surface": "ازیشان", "lemma": "از", "pos": "NOUN", "seg": "s466-g42", "sid": "s466-s21"}, {"s": 7, "e": 12, "surface": "مبادا", "lemma": "مبادا", "pos": "NOUN", "seg": "s466-g42", "sid": "s466-s21"}, {"s": 13, "e": 15, "surface": "که", "lemma": "که", "pos": "NOUN", "seg": "s466-g42", "sid": "s466-s21"}, {"s": 16, "e": 22, "surface": 