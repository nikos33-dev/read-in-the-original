urface": "و", "lemma": "و", "pos": "NOUN", "seg": "s003-g50", "sid": "s003-s25"}, {"s": 18, "e": 22, "surface": "نهان", "lemma": "نهان", "pos": "NOUN", "seg": "s003-g50", "sid": "s003-s25"}]}}, "sentences": {"s003-s1": {"text": "از آغاز باید که دانی درست سر مایه گوهران از نخست", "lines": ["s003-l1", "s003-l2"], "segs": ["s003-g1", "s003-g2"]}, "s003-s2": {"text": "که یزدان ز ناچیز چیز آفرید بدان تا توانایی آرد پدید", "lines": ["s003-l3", "s003-l4"], "segs": ["s003-g3", "s003-g4"]}, "s003-s3": {"text": "سر مایه گوهران این چهار برآورده بی‌رنج و بی‌روزگار", "lines": ["s003-l5", "s003-l6"], "segs": ["s003-g5", "s003-g6"]}, "s003-s4": {"text": "یکی آتشی بر شده تابناک میان آب و باد از بر تیره خاک", "lines": ["s003-l7", "s003-l8"], "segs": ["s003-g7", "s003-g8"]}, "s003-s5": {"text": "نخستین که آتش به جنبش دمید ز گرمیش پس خشکی آمد پدید", "lines": ["s003-l9", "s003-l10"], "segs": ["s003-g9", "s003-g10"]}, "s003-s6": {"text": "و زان پس ز آرام سردی نمود ز سردی همان باز‌تری فزود", "lines": ["s003-l11", "s003-l12"], "segs": ["s003-g11", "s003-g12"]}, "s003-s7": {"text": "چو این چار گوهر به جای آمدند ز بهر سپنجی سرای آمدند", "lines": ["s003-l13", "s003-l14"], "segs": ["s003-g13", "s003-g14"]}, "s003-s8": {"text": "گهرها یک اندر دگر ساخته ز هر گونه گردن برافراخته", "lines": ["s003-l15", "s003-l16"], "segs": ["s003-g15", "s003-g16"]}, "s003-s9": {"text": "پدید آمد این گنبد تیز رو شگفتی نماینده نو به نو", "lines": ["s003-l17", "s003-l18"], "segs": ["s003-g17", "s003-g18"]}, "s003-s10": {"text": "ابر ده و دو هفت شد کدخدای گرفتند هر یک سزاوار جای", "lines": ["s003-l19", "s003-l20"], "segs": ["s003-g19", "s003-g20"]}, "s003-s11": {"text": "در بخشش و دادن آمد پدید ببخشید دانا چنان چون سزید", "lines": ["s003-l21", "s003-l22"], "segs": ["s003-g21", "s003-g22"]}, "s003-s12": {"text": "فلک‌ها یک اندر دگر بسته شد بجنبید چون کار پیوسته شد", "lines": ["s003-l23", "s003-l24"], "segs": ["s003-g23", "s003-g24"]}, "s003-s13": {"text": "چو دریا و چون کوه و چون دشت و راغ زمین شد به کردار روشن چراغ", "lines": ["s003-l25", "s003-l26"], "segs": ["s003-g25", "s003-g26"]}, "s003-s14": {"text": "ببالید کوه آب‌ها بر دمید سر رستنی سوی بالا کشید", "lines": ["s003-l27", "s003-l28"], "segs": ["s003-g27", "s003-g28"]}, "s003-s15": {"text": "زمین را بلندی نبد جایگاه یکی مرکزی تیره بود و سیاه", "lines": ["s003-l29", "s003-l30"], "segs": ["s003-g29", "s003-g30"]}, "s003-s16": {"text": "ستاره بر او برشگفتی نمود به خاک اندرون روشنایی فزود", "lines": ["s003-l31", "s003-l32"], "segs": ["s003-g31", "s003-g32"]}, "s003-s17": {"text": "همی بر شد آتش فرود آمد آب همی گشت گرد زمین آفتاب", "lines": ["s003-l33", "s003-l34"], "segs": ["s003-g33", "s003-g34"]}, "s003-s18": {"text": "گیا رست با چند گونه درخت به زیر اندر آمد سران‌شان ز بخت", "lines": ["s003-l35", "s003-l36"], "segs": ["s003-g35", "s003-g36"]}, "s003-s19": {"text": "ببالد ندارد جز این نیرویی نپوید چو پویندگان هر سویی", "lines": ["s003-l37", "s003-l38"], "segs": ["s003-g37", "s003-g38"]}, "s003-s20": {"text": "و زان پس چو جنبنده آمد پدید همه رستنی زیر خویش آورید", "lines": ["s003-l39", "s003-l40"], "segs": ["s003-g39", "s003-g40"]}, "s003-s21": {"text": "خور و خواب و آرام جوید همی و زان زندگی کام جوید همی", "lines": ["s003-l41", "s003-l42"], "segs": ["s003-g41", "s003-g42"]}, "s003-s22": {"text": "نه گویا زبان و نه جویا خرد ز خاک و ز خاشاک تن پرورد", "lines": ["s003-l43", "s003-l44"], "segs": ["s003-g43", "s003-g44"]}, "s003-s23": {"text": "نداند بد و نیک‌فرجام کار نخواهد از او بندگی کردگار", "lines": ["s003-l45", "s003-l46"], "segs": ["s003-g45", "s003-g46"]}, "s003-s24": {"text": "چو دانا توانا بد و دادگر از ایرا نکرد ایچ پنهان هنر", "lines": ["s003-l47", "s003-l48"], "segs": ["s003-g47", "s003-g48"]}, "s003-s25": {"text": "چنین است فرجام کار جهان نداند کسی آشکار و نهان", "lines": ["s003-l49", "s003-l50"], "segs": ["s003-g49", "s003-g50"]}}, "segments": {"s003-g1": {"text": "از آغاز باید که دانی درست", "sid": "s003-s1", "lines": ["s003-l1"]}, "s003-g2": {"text": "سر مایه گوهران از نخست", "sid": "s003-s1", "lines": ["s003-l2"]}, "s003-g3": {"text": "که یزدان ز ناچیز چیز آفرید", "sid": "s003-s2", "lines": ["s003-l3"]}, "s003-g4": {"text": "بدان تا توانایی آرد پدید", "sid": "s003-s2", "lines": ["s003-l4"]}, "s003-g5": {"text": "سر مایه گوهران این چهار", "sid": "s003-s3", "lines": ["s003-l5"]}, "s003-g6": {"text": "برآورده بی‌رنج و بی‌روزگار", "sid": "s003-s3", "lines": ["s003-l6"]}, "s003-g7": {"text": "یکی آتشی بر شده تابناک", "sid": "s003-s4", "lines": ["s003-l7"]}, "s003-g8": {"text": "میان آب و باد از بر تیره خاک", "sid": "s003-s4", "lines": ["s003-l8"]}, "s003-g9": {"text": "نخستین که آتش به جنبش دمید", "sid": "s003-s5", "lines": ["s003-l9"]}, "s003-g10": {"text": "ز گرمیش پس خشکی آمد پدید", "sid": "s003-s5", "lines": ["s003-l10"]}, "s003-g11": {"text": "و زان پس ز آرام سردی نمود", "sid": "s003-s6", "lines": ["s003-l11"]}, "s003-g12": {"text": "ز سردی همان باز‌تری فزود", "sid": "s003-s6", "lines": ["s003-l12"]}, "s003-g13": {"text": "چو این چار گوهر به جای آمدند", "sid": "s003-s7", "lines": ["s003-l13"]}, "s003-g14": {"text": "ز بهر سپنجی سرای آمدند", "sid": "s003-s7", "lines": ["s003-l14"]}, "s003-g15": {"text": "گهرها یک اندر دگر ساخته", "sid": "s003-s8", "lines": ["s003-l15"]}, "s003-g16": {"text": "ز هر گونه گردن برافراخته", "sid": "s003-s8", "lines": ["s003-l16"]}, "s003-g17": {"text": "پدید آمد این گنبد تیز رو", "sid": "s003-s9", "lines": ["s003-l17"]}, "s003-g18": {"text": "شگفتی نماینده نو به نو", "sid": "s003-s9", "lines": ["s003-l18"]}, "s003-g19": {"text": "ابر ده و دو هفت شد کدخدای", "sid": "s003-s10", "lines": ["s003-l19"]}, "s003-g20": {"text": "گرفتند هر یک سزاوار جای", "sid": "s003-s10", "lines": ["s003-l20"]}, "s003-g21": {"text": "در بخشش و دادن آمد پدید", "sid": "s003-s11", "lines": ["s003-l21"]}, "s003-g22": {"text": "ببخشید دانا چنان چون سزید", "sid": "s003-s11", "lines": ["s003-l22"]}, "s003-g23": {"text": "فلک‌ها یک اندر دگر بسته شد", "sid": "s003-s12", "lines": ["s003-l23"]}, "s003-g24": {"text": "بجنبید چون کار پیوسته شد", "sid": "s003-s12", "lines": ["s003