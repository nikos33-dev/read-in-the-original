        "s692-g20"
      ]
    },
    "s692-s11": {
      "text": "که گاهی پناهست و گاهی گزند گهی با زیانیم و گه سودمند",
      "lines": [
        "s692-l21",
        "s692-l22"
      ],
      "segs": [
        "s692-g21",
        "s692-g22"
      ]
    },
    "s692-s12": {
      "text": "کنون تا سلیح و سپاه و درم فراز آورم تو نباشی دژم",
      "lines": [
        "s692-l23",
        "s692-l24"
      ],
      "segs": [
        "s692-g23",
        "s692-g24"
      ]
    },
    "s692-s13": {
      "text": "بر خسرو آمد فرستاده مرد سخنهای قیصر همه یاد کرد",
      "lines": [
        "s692-l25",
        "s692-l26"
      ],
      "segs": [
        "s692-g25",
        "s692-g26"
      ]
    }
  },
  "segments": {
    "s692-g1": {
      "text": "دبیر جهاندیده را پیش خواند",
      "sid": "s692-s1",
      "lines": [
        "s692-l1"
      ]
    },
    "s692-g2": {
      "text": "بران پیشگاه بزرگی نشاند",
      "sid": "s692-s1",
      "lines": [
        "s692-l2"
      ]
    },
    "s692-g3": {
      "text": "بفرمود تا نامه پاسخ نوشت",
      "sid": "s692-s2",
      "lines": [
        "s692-l3"
      ]
    },
    "s692-g4": {
      "text": "بیاراست چون مرغزار بهشت",
      "sid": "s692-s2",
      "lines": [
        "s692-l4"
      ]
    },
    "s692-g5": {
      "text": "ز بس بند و پیوند و نیکو سخن",
      "sid": "s692-s3",
      "lines": [
        "s692-l5"
      ]
    },
    "s692-g6": {
      "text": "ازان روز تا روزگار کهن",
      "sid": "s692-s3",
      "lines": [
        "s692-l6"
      ]
    },
    "s692-g7": {
      "text": "چوگشت از نوشتن نویسنده سیر",
      "sid": "s692-s4",
      "lines": [
        "s692-l7"
      ]
    },
    "s692-g8": {
      "text": "نگه کرد قیصر سواری دلیر",
      "sid": "s692-s4",
      "lines": [
        "s692-l8"
      ]
    },
    "s692-g9": {
      "text": "سخن گوی و روشن‌دل و یادگیر",
      "sid": "s692-s5",
      "lines": [
        "s692-l9"
      ]
    },
    "s692-g10": {
      "text": "خردمند و گویا و گرد و دبیر",
      "sid": "s692-s5",
      "lines": [
        "s692-l10"
      ]
    },
    "s692-g11": {
      "text": "بدو گفت رو پیش خسرو بگوی",
      "sid": "s692-s6",
      "lines": [
        "s692-l11"
      ]
    },
    "s692-g12": {
      "text": "که‌ای شاه بینا دل و راه جوی",
      "sid": "s692-s6",
      "lines": [
        "s692-l12"
      ]
    },
    "s692-g13": {
      "text": "مرا هم سلیحست و هم زر به گنج",
      "sid": "s692-s7",
      "lines": [
        "s692-l13"
      ]
    },
    "s692-g14": {
      "text": "نیاورد باید کسی را به رنج",
      "sid": "s692-s7",
      "lines": [
        "s692-l14"
      ]
    },
    "s692-g15": {
      "text": "وگر نیستیمان ز هر کشوری",
      "sid": "s692-s8",
      "lines": [
        "s692-l15"
      ]
    },
    "s692-g16": {
      "text": "درم خواستیمی ز هر مهتری",
      "sid": "s692-s8",
      "lines": [
        "s692-l16"
      ]
    },
    "s692-g17": {
      "text": "بدان تا تواز روم با کام خویش",
      "sid": "s692-s9",
      "lines": [
        "s692-l17"
      ]
    },
    "s692-g18": {
      "text": "به ایران گذشتی به آرام خویش",
      "sid": "s692-s9",
      "lines": [
        "s692-l18"
      ]
    },
    "s692-g19": {
      "text": "مباش اندرین بوم تیره روان",
      "sid": "s692-s10",
      "lines": [
        "s692-l19"
      ]
    },
    "s692-g20": {
      "text": "چنین است کردار چرخ روان",
      "sid": "s692-s10",
      "lines": [
        "s692-l20"
      ]
    },
    "s692-g21": {
      "text": "که گاهی پناهست و گاهی گزند",
      "sid": "s692-s11",
      "lines": [
        "s692-l21"
      ]
    },
    "s692-g22": {
      "text": "گهی با زیانیم و گه سودمند",
      "sid": "s692-s11",
      "lines": [
        "s692-l22"
      ]
    },
    "s692-g23": {
      "text": "کنون تا سلیح و سپاه و درم",
      "sid": "s692-s12",
      "lines": [
        "s692-l23"
      ]
    },
    "s692-g24": {
      "text": "فراز آورم تو نباشی دژم",
      "sid": "s692-s12",
      "lines": [
        "s692-l24"
      ]
    },
    "s692-g25": {
      "text": "بر خسرو آمد فرستاده مرد",
      "sid": "s692-s13",
      "lines": [
        "s692-l25"
      ]
    },
    "s692-g26": {
      "text": "سخنهای قیصر همه یاد کرد",
      "sid": "s692-s13",
      "lines": [
