  "sentences": {
    "s692-s1": {
      "text": "دبیر جهاندیده را پیش خواند بران پیشگاه بزرگی نشاند",
      "lines": [
        "s692-l1",
        "s692-l2"
      ],
      "segs": [
        "s692-g1",
        "s692-g2"
      ]
    },
    "s692-s2": {
      "text": "بفرمود تا نامه پاسخ نوشت بیاراست چون مرغزار بهشت",
      "lines": [
        "s692-l3",
        "s692-l4"
      ],
      "segs": [
        "s692-g3",
        "s692-g4"
      ]
    },
    "s692-s3": {
      "text": "ز بس بند و پیوند و نیکو سخن ازان روز تا روزگار کهن",
      "lines": [
        "s692-l5",
        "s692-l6"
      ],
      "segs": [
        "s692-g5",
        "s692-g6"
      ]
    },
    "s692-s4": {
      "text": "چوگشت از نوشتن نویسنده سیر نگه کرد قیصر سواری دلیر",
      "lines": [
        "s692-l7",
        "s692-l8"
      ],
      "segs": [
        "s692-g7",
        "s692-g8"
      ]
    },
    "s692-s5": {
      "text": "سخن گوی و روشن‌دل و یادگیر خردمند و گویا و گرد و دبیر",
      "lines": [
        "s692-l9",
        "s692-l10"
      ],
      "segs": [
        "s692-g9",
        "s692-g10"
      ]
    },
    "s692-s6": {
      "text": "بدو گفت رو پیش خسرو بگوی که‌ای شاه بینا دل و راه جوی",
      "lines": [
        "s692-l11",
        "s692-l12"
      ],
      "segs": [
        "s692-g11",
        "s692-g12"
      ]
    },
    "s692-s7": {
      "text": "مرا هم سلیحست و هم زر به گنج نیاورد باید کسی را به رنج",
      "lines": [
        "s692-l13",
        "s692-l14"
      ],
      "segs": [
        "s692-g13",
        "s692-g14"
      ]
    },
    "s692-s8": {
      "text": "وگر نیستیمان ز هر کشوری درم خواستیمی ز هر مهتری",
      "lines": [
        "s692-l15",
        "s692-l16"
      ],
      "segs": [
        "s692-g15",
        "s692-g16"
      ]
    },
    "s692-s9": {
      "text": "بدان تا تواز روم با کام خویش به ایران گذشتی به آرام خویش",
      "lines": [
        "s692-l17",
        "s692-l18"
      ],
      "segs": [
        "s692-g17",
        "s692-g18"
      ]
    },
    "s692-s10": {
      "text": "مباش اندرین بوم تیره روان چنین است کردار چرخ روان",
      "lines": [
        "s692-l19",
        "s692-l20"
      ],
      "segs": [
