  "sentences": {
    "s560-s1": {
      "text": "چو بنشست بهرام بهرامیان ببست از پی داد و بخشش میان",
      "lines": [
        "s560-l1",
        "s560-l2"
      ],
      "segs": [
        "s560-g1",
        "s560-g2"
      ]
    },
    "s560-s2": {
      "text": "به تاجش زبرجد برافشاندند همی نام کرمان شهش خواندند",
      "lines": [
        "s560-l3",
        "s560-l4"
      ],
      "segs": [
        "s560-g3",
        "s560-g4"
      ]
    },
    "s560-s3": {
      "text": "چنین گفت کز دادگر یک خدای خرد بادمان بهره و داد و رای",
      "lines": [
        "s560-l5",
        "s560-l6"
      ],
      "segs": [
        "s560-g5",
        "s560-g6"
      ]
    },
    "s560-s4": {
      "text": "سرای سپنجی نماند به کس ترا نیکوی باد فریادرس",
      "lines": [
        "s560-l7",
        "s560-l8"
      ],
      "segs": [
        "s560-g7",
        "s560-g8"
      ]
    },
    "s560-s5": {
      "text": "به نیکی گراییم و فرمان کنیم به داد و دهش دل گروگان کنیم",
      "lines": [
        "s560-l9",
        "s560-l10"
      ],
      "segs": [
        "s560-g9",
        "s560-g10"
      ]
    },
    "s560-s6": {
      "text": "که خوبی و زشتی ز ما یادگار بماند تو جز تخم نیکی مکار",
      "lines": [
        "s560-l11",
        "s560-l12"
      ],
      "segs": [
        "s560-g11",
        "s560-g12"
      ]
    },
    "s560-s7": {
      "text": "چو شد پادشاهیش بر چار ماه برو زار بگریست تخت و کلاه",
      "lines": [
        "s560-l13",
        "s560-l14"
      ],
      "segs": [
        "s560-g13",
        "s560-g14"
      ]
    },
    "s560-s8": {
      "text": "زمانه برین سان همی بگذرد پیش مردم آزور بشمرد",
      "lines": [
        "s560-l15",
        "s560-l16"
      ],
      "segs": [
        "s560-g15",
        "s560-g16"
      ]
    },
    "s560-s9": {
      "text": "می‌لعل پیش آور‌ای روزبه چو شد سال گوینده بر شست و سه",
      "lines": [
        "s560-l17",
        "s560-l18"
      ],
      "segs": [
        "s560-g17",
        "s560-g18"
      ]
    },
    "s560-s10": {
      "text": "چو بهرام دانست کامدش مرگ نهنگی کجا بشکرد پیل و کرگ",
      "lines": [
        "s560-l19",
        "s560-l20"
      ],
      "segs": [
        "s560-g19",
        "s560-g20"
      ]
    },
    "s560-s11": {
      "text": "جهان را به فرزند بسپرد و گفت که با مهتران آفرین باد جفت",
      "lines": [
        "s560-l21",
        "s560-l22"
      ],
      "segs": [
        "s560-g21",
        "s560-g22"
      ]
    },
    "s560-s12": {
      "text": "بنوش و بباز و بناز و ببخش مکن روز بر تاج و بر تخت دخش",
      "lines": [
        "s560-l23",
        "s560-l24"
      ],
      "segs": [
        "s560-g23",
        "s560-g24"
      ]
    },
    "s560-s13": {
      "text": "چو برگشت بهرام را روز و بخت به نرسی سپرد آن زمان تاج و تخت",
      "lines": [
        "s560-l25",
        "s560-l26"
      ],
      "segs": [
        "s560-g25",
        "s560-g26"
      ]
    },
    "s560-s14": {
      "text": "چنین است و این را بی‌اندازه دان گزاف فلک هر زمان تازه دان",
      "lines": [
        "s560-l27",
        "s560-l28"
      ],
      "segs": [
        "s560-g27",
        "s560-g28"
      ]
    },
    "s560-s15": {
      "text": "کنون کار نرسی بگویم همی ز دل زنگ و زنگار شویم همی",
      "lines": [
        "s560-l29",
        "s560-l30"
      ],
      "segs": [
        "s560-g29",
        "s560-g30"
      ]
    }
  },
