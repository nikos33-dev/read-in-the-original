": 5, "e": 7, "surface": "دل", "lemma": "دل", "pos": "NOUN", "seg": "s234-g54", "sid": "s234-s27"}, {"s": 8, "e": 11, "surface": "شاه", "lemma": "شاه", "pos": "NOUN", "seg": "s234-g54", "sid": "s234-s27"}, {"s": 12, "e": 17, "surface": "ایران", "lemma": "ایران", "pos": "NOUN", "seg": "s234-g54", "sid": "s234-s27"}, {"s": 18, "e": 22, "surface": "سپاه", "lemma": "سپاه", "pos": "NOUN", "seg": "s234-g54", "sid": "s234-s27"}]}}, "sentences": {"s234-s1": {"text": "بایوان شد و نامه پاسخ نوشت بباغ بزرگی درختی بکشت", "lines": ["s234-l1", "s234-l2"], "segs": ["s234-g1", "s234-g2"]}, "s234-s2": {"text": "نخست آفرین کرد بر کردگار کزو بود روشن‌دل و بختیار", "lines": ["s234-l3", "s234-l4"], "segs": ["s234-g3", "s234-g4"]}, "s234-s3": {"text": "خداوند ناهید و گردان سپهر کزویست پرخاش و آرام و مهر", "lines": ["s234-l5", "s234-l6"], "segs": ["s234-g5", "s234-g6"]}, "s234-s4": {"text": "سپهری برین گونه بر پای کرد شب و روز را گیتی آرای کرد", "lines": ["s234-l7", "s234-l8"], "segs": ["s234-g7", "s234-g8"]}, "s234-s5": {"text": "یکی را چنین تیره‌بخت آفرید یکی را سزاوار تخت آفرید", "lines": ["s234-l9", "s234-l10"], "segs": ["s234-g9", "s234-g10"]}, "s234-s6": {"text": "غم و شادمانی ز یزدان‌شناس کزویست هر گونه بر ما سپاس", "lines": ["s234-l11", "s234-l12"], "segs": ["s234-g11", "s234-g12"]}, "s234-s7": {"text": "رسید آنچ دادی بدین بارگاه اسیران و پیلان و تخت و کلاه", "lines": ["s234-l13", "s234-l14"], "segs": ["s234-g13", "s234-g14"]}, "s234-s8": {"text": "هیونان بسیار و افگندنی ز پوشیدنی هم ز گستردنی", "lines": ["s234-l15", "s234-l16"], "segs": ["s234-g15", "s234-g16"]}, "s234-s9": {"text": "همه آلت ناز و سورست و بزم بپیش تو زین سان که آید برزم", "lines": ["s234-l17", "s234-l18"], "segs": ["s234-g17", "s234-g18"]}, "s234-s10": {"text": "مگر آنکسی کش سرآید بپیش بدین گونه سیر آید از جان خویش", "lines": ["s234-l19", "s234-l20"], "segs": ["s234-g19", "s234-g20"]}, "s234-s11": {"text": "وزان رنج بردن ز توران سپاه شب و روز بودن به آوردگاه", "lines": ["s234-l21", "s234-l22"], "segs": ["s234-g21", "s234-g22"]}, "s234-s12": {"text": "ز کارت خبر بد مرا روز و شب گشاده نکردم به بیگانه لب", "lines": ["s234-l23", "s234-l24"], "segs": ["s234-g23", "s234-g24"]}, "s234-s13": {"text": "شب و روز بر پیش یزدان پاک نوان بودم و دل‌شده چاک چاک", "lines": ["s234-l25", "s234-l26"], "segs": ["s234-g25", "s234-g26"]}, "s234-s14": {"text": "کسی را که رستم بود پهلوان سزد‌گر بماند همیشه جوان", "lines": ["s234-l27", "s234-l28"], "segs": ["s234-g27", "s234-g28"]}, "s234-s15": {"text": "پرستنده چون تو ندارد سپهر ز تو بخت هرگز مبراد مهر", "lines": ["s234-l29", "s234-l30"], "segs": ["s234-g29", "s234-g30"]}, "s234-s16": {"text": "نویسنده پردخته شد ز آفرین نهاد از بر نامه خسرو نگین", "lines": ["s234-l31", "s234-l32"], "segs": ["s234-g31", "s234-g32"]}, "s234-s17": {"text": "بفرمود تا خلعت آراستند ستام و کمرها بپیراستند", "lines": ["s234-l33", "s234-l34"], "segs": ["s234-g33", "s234-g34"]}, "s234-s18": {"text": "صد از جعد مویان زرین کمر صد اسپ گرانمایه با زین زر", "lines": ["s234-l35", "s234-l36"], "segs": ["s234-g35", "s234-g36"]}, "s234-s19": {"text": "صد اشتر همه بار دیبای چین صد اشتر ز افگندنی هم‌چنین", "lines": ["s234-l37", "s234-l38"], "segs": ["s234-g37", "s234-g38"]}, "s234-s20": {"text": "ز یاقوت رخشان دو انگشتری ز خوشاب و در افسری بر سری", "lines": ["s234-l39", "s234-l40"], "segs": ["s234-g39", "s234-g40"]}, "s234-s21": {"text": "ز پوشیدن شاه دستی بزر همان یاره و طوق و زرین کمر", "lines": ["s234-l41", "s234-l42"], "segs": ["s234-g41", "s234-g42"]}, "s234-s22": {"text": "سران را همه هدیه‌ها ساختند یکی گنج زین سان بپرداختند", "lines": ["s234-l43", "s234-l44"], "segs": ["s234-g43", "s234-g44"]}, "s234-s23": {"text": "فریبرز با تاج و گرز و درفش یکی تخت زرین و زرینه کفش", "lines": ["s234-l45", "s234-l46"], "segs": ["s234-g45", "s234-g46"]}, "s234-s24": {"text": "فرستاد و فرمود تا بازگشت از ایران بسوی سپهبد گذشت", "lines": ["s234-l47", "s234-l48"], "segs": ["s234-g47", "s234-g48"]}, "s234-s25": {"text": "چنین گفت کز جنگ افراسیاب نه آرام باید نه خورد و نه خواب", "lines": ["s234-l49"