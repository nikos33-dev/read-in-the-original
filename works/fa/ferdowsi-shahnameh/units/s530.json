  "sentences": {
    "s530-s1": {
      "text": "چو خورشید شد زرد لشکر براند کسی را که نابردنی بد بماند",
      "lines": [
        "s530-l1",
        "s530-l2"
      ],
      "segs": [
        "s530-g1",
        "s530-g2"
      ]
    },
    "s530-s2": {
      "text": "چو شب نیم بگذشت و تاریک شد جهاندار با کرد نزدیک شد",
      "lines": [
        "s530-l3",
        "s530-l4"
      ],
      "segs": [
        "s530-g3",
        "s530-g4"
      ]
    },
    "s530-s3": {
      "text": "همه دشت زیشان پر از خفته دید یکایک دل لشکر آشفته دید",
      "lines": [
        "s530-l5",
        "s530-l6"
      ],
      "segs": [
        "s530-g5",
        "s530-g6"
      ]
    },
    "s530-s4": {
      "text": "چو آمد سپهبد به بالین کرد عنان باره تیزتگ را سپرد",
      "lines": [
        "s530-l7",
        "s530-l8"
      ],
      "segs": [
        "s530-g7",
        "s530-g8"
      ]
    },
    "s530-s5": {
      "text": "برآهخت شمشیر و اندرنهاد گیا را ز خون بر سر افسر نهاد",
      "lines": [
        "s530-l9",
        "s530-l10"
      ],
      "segs": [
        "s530-g9",
        "s530-g10"
      ]
    },
    "s530-s6": {
      "text": "همه دشت زیشان سر و دست شد ز انبوه کشته زمین گست شد",
      "lines": [
        "s530-l11",
        "s530-l12"
      ],
      "segs": [
        "s530-g11",
        "s530-g12"
      ]
    },
    "s530-s7": {
      "text": "بی‌اندازه زیشان گرفتار شد سترگی و نابخردی خوار شد",
      "lines": [
        "s530-l13",
        "s530-l14"
      ],
      "segs": [
        "s530-g13",
        "s530-g14"
      ]
    },
    "s530-s8": {
      "text": "همه بومهاشان به تاراج داد سپه را همه بدره و تاج داد",
      "lines": [
        "s530-l15",
        "s530-l16"
      ],
      "segs": [
        "s530-g15",
        "s530-g16"
      ]
    },
    "s530-s9": {
      "text": "چنان شد که دینار بر سر به تشت اگر پیر مردی ببردی به دشت",
      "lines": [
        "s530-l17",
        "s530-l18"
      ],
      "segs": [
        "s530-g17",
        "s530-g18"
      ]
    },
    "s530-s10": {
      "text": "به دینار او کس نکردی نگاه ز نیک‌اختر و بخت وز داد شاه",
      "lines": [
        "s530-l19",
        "s530-l20"
      ],
      "segs": [
        "s530-g19",
        "s530-g20"
      ]
    },
    "s530-s11": {
      "text": "ز مردی نکردی بدان جنگ فخر گرازان بیامد به شهر صطخر",
      "lines": [
        "s530-l21",
        "s530-l22"
      ],
      "segs": [
        "s530-g21",
        "s530-g22"
      ]
    },
    "s530-s12": {
      "text": "بفرمود کاسپان به نیرو کنید سلیح سواران بی‌آهو کنید",
      "lines": [
        "s530-l23",
        "s530-l24"
      ],
      "segs": [
        "s530-g23",
        "s530-g24"
      ]
    },
    "s530-s13": {
      "text": "چو آسوده گردید یکسر به بزم که زود آید اندیشه روز رزم",
      "lines": [
        "s530-l25",
        "s530-l26"
      ],
      "segs": [
        "s530-g25",
        "s530-g26"
      ]
    },
    "s530-s14": {
      "text": "دلیران به خوردن نهادند سر چو آسوده شد کردگاه و کمر",
      "lines": [
        "s530-l27",
        "s530-l28"
      ],
      "segs": [
        "s530-g27",
        "s530-g28"
      ]
    },
    "s530-s15": {
      "text": "پراندیشه رزم شد اردشیر چو این داستان بشنوی یادگیر",
      "lines": [
        "s530-l29",
        "s530-l30"
      ],
      "segs": [
        "s530-g29",
        "s530-g30"
      ]
    }
  },
