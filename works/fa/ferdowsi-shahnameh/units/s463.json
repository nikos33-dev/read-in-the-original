s463-g3", "s463-g4"]}, "s463-s3": {"text": "بیاورد لشکر ز رود فرات به هامون سپه بیش بود از نبات", "lines": ["s463-l5", "s463-l6"], "segs": ["s463-g5", "s463-g6"]}, "s463-s4": {"text": "سکندر چو بشنید کامد سپاه بزد کوس و آورد لشکر به راه", "lines": ["s463-l7", "s463-l8"], "segs": ["s463-g7", "s463-g8"]}, "s463-s5": {"text": "دو لشکر که آن را کرانه نبود چو اسکندر اندر زمانه نبود", "lines": ["s463-l9", "s463-l10"], "segs": ["s463-g9", "s463-g10"]}, "s463-s6": {"text": "ز ساز و ز گردان هر دو گروه زمین همچو دریا بد و گرد کوه", "lines": ["s463-l11", "s463-l12"], "segs": ["s463-g11", "s463-g12"]}, "s463-s7": {"text": "ز خفتان وز خنجر هندوان ز بالا و اسپ وز برگستوان", "lines": ["s463-l13", "s463-l14"], "segs": ["s463-g13", "s463-g14"]}, "s463-s8": {"text": "دو رویه سپه برکشیدند صف ز خنجر همی یافت خورشید تف", "lines": ["s463-l15", "s463-l16"], "segs": ["s463-g15", "s463-g16"]}, "s463-s9": {"text": "به پیش سپاه آوریدند پیل جهان شد به کردار دریای نیل", "lines": ["s463-l17", "s463-l18"], "segs": ["s463-g17", "s463-g18"]}, "s463-s10": {"text": "سواران جنگ از پس و پیل پیش همه برگرفته دل از جان خویش", "lines": ["s463-l19", "s463-l20"], "segs": ["s463-g19", "s463-g20"]}, "s463-s11": {"text": "تو گفتی هوا خون خروشد همی زمین از خروشش بجوشد همی", "lines": ["s463-l21", "s463-l22"], "segs": ["s463-g21", "s463-g22"]}, "s463-s12": {"text": "ز بس ناله بوق و هندی درای همی کوه را دل برآمد ز جای", "lines": ["s463-l23", "s463-l24"], "segs": ["s463-g23", "s463-g24"]}, "s463-s13": {"text": "ز آواز اسپان و بانگ سران چرنگیدن گرزهای گران", "lines": ["s463-l25", "s463-l26"], "segs": ["s463-g25", "s463-g26"]}, "s463-s14": {"text": "تو گفتی زمین کوه جنگی شدست ز گرد آسمان روی زنگی شدست", "lines": ["s463-l27", "s463-l28"], "segs": ["s463-g27", "s463-g28"]}, "s463-s15": {"text": "به یک هفته گردان پرخاشجوی به روی اندر آورده بودند روی", "lines": ["s463-l29", "s463-l30"], "segs": ["s463-g29", "s463-g30"]}, "s463-s16": {"text": "بهشتم برآمد یکی تیره گرد بران سان که خورشید شد لاژورد", "lines": ["s463-l31", "s463-l32"], "segs": ["s463-g31", "s463-g32"]}, "s463-s17": {"text": "بپوشید دیدار ایران سپاه گریزان برفتند از آن رزمگاه", "lines": ["s463-l33", "s463-l34"], "segs": ["s463-g33", "s463-g34"]}, "s463-s18": {"text": "سپاه سکندر پس اندر دمان یکی پرغم و دیگری شادمان", "lines": ["s463-l35", "s463-l36"], "segs": ["s463-g35", "s463-g36"]}, "s463-s19": {"text": "سکندر بشد تا لب رودبار بکشتند ز ایرانیان بی‌شمار", "lines": ["s463-l37", "s463-l38"], "segs": ["s463-g37", "s463-g38"]}, "s463-s20": {"text": "سپاه از لب رود برگاشتند بفرمود تا رود بگذاشتند", "lines": ["s463-l39", "s463-l40"], "segs": ["s463-g39", "s463-g40"]}, "s463-s21": {"text": "به پیروزی آمد بران رزمگاه کجا پیش بود آن گزیده سپاه", "lines": ["s463-l41", "s463-l42"], "segs": ["s463-g41", "s463-g42"]}}, "segments": {"s463-g1": {"text": "چو خورشید برزد سر از کوه و راغ", "sid": "s463-s1", "lines": ["s463-l1"]}, "s463-g2": {"text": "زمین شد به کردار زرین چراغ", "sid": "s463-s1", "lines": ["s463-l2"]}, "s463-g3": {"text": "جهاندار دارا سپه برگرفت", "sid": "s463-s2", "lines": ["s463-l3"]}, "s463-g4": {"text": "جهان چادر قیر بر سرگرفت", "sid": "s463-s2", "lines": ["s463-l4"]}, "s463-g5": {"text": "بیاورد لشکر ز رود فرات", "sid": "s463-s3", "lines": ["s463-l5"]}, "s463-g6": {"text": "به هامون سپه بیش بود از نبات", "sid": "s463-s3", "lines": ["s463-l6"]}, "s463-g7": {"text": "سکندر چو بشنید کامد سپاه", "sid": "s463-s4", "lines": ["s463-l7"]}, "s463-g8": {"text": "بزد کوس و آورد لشکر به راه", "sid": "s463-s4", "lines": ["s463-l8"]}, "s463-g9": {"text": "دو لشکر که آن را کرانه نبود", "sid": "s463-s5", "lines": ["s463-l9"]}, "s463-g10": {"text": "چو اسکندر اندر زمانه نبود", "sid": "s463-s5", "lines": ["s463-l10"]}, "s463-g11": {"text": "ز ساز و ز گردان هر دو گروه", "sid": "s463-s6", "lines": ["s463-l11"]}, "s463-g12": {"text": "زمین همچو دریا بد و گرد کوه", "sid": "s463-s6", "lines": ["s463-l12"]}, "s463-g13": {"text": "ز خفتان وز خنجر هندوان", "sid": "s463-s7", "lines": ["s463-l13"]}, "s463-g14": {"text": "ز بالا و اسپ وز برگ