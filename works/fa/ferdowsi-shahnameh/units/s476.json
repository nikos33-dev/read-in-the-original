, {"s": 11, "e": 15, "surface": "تختت", "lemma": "تخت", "pos": "NOUN", "seg": "s476-g34", "sid": "s476-s17"}, {"s": 16, "e": 18, "surface": "به", "lemma": "به", "pos": "NOUN", "seg": "s476-g34", "sid": "s476-s17"}, {"s": 19, "e": 21, "surface": "پی", "lemma": "پی", "pos": "NOUN", "seg": "s476-g34", "sid": "s476-s17"}, {"s": 22, "e": 27, "surface": "بسپرم", "lemma": "سپرد#سپر", "pos": "NOUN", "seg": "s476-g34", "sid": "s476-s17"}]}}, "sentences": {"s476-s1": {"text": "سکندر چو کرد اندر ایران نگاه بدانست کو را شد آن تاج و گاه", "lines": ["s476-l1", "s476-l2"], "segs": ["s476-g1", "s476-g2"]}, "s476-s2": {"text": "همی راه و بی‌راه لشکر کشید سوی کید هندی سپه برکشید", "lines": ["s476-l3", "s476-l4"], "segs": ["s476-g3", "s476-g4"]}, "s476-s3": {"text": "به جایی که آمد سکندر فراز در شارستانها گشادند باز", "lines": ["s476-l5", "s476-l6"], "segs": ["s476-g5", "s476-g6"]}, "s476-s4": {"text": "ازان مرز کس را به مردم نداشت ز ناهید مغفر همی برگذاشت", "lines": ["s476-l7", "s476-l8"], "segs": ["s476-g7", "s476-g8"]}, "s476-s5": {"text": "چو آمد بران شارستان بزرگ که میلاد خواندیش کید سترگ", "lines": ["s476-l9", "s476-l10"], "segs": ["s476-g9", "s476-g10"]}, "s476-s6": {"text": "بران مرز لشکر فرود آورید همه بوم ایشان سپه گسترید", "lines": ["s476-l11", "s476-l12"], "segs": ["s476-g11", "s476-g12"]}, "s476-s7": {"text": "نویسنده نامه را خواندند به پیش سکندرش بنشاندند", "lines": ["s476-l13", "s476-l14"], "segs": ["s476-g13", "s476-g14"]}, "s476-s8": {"text": "یکی نامه بنوشت نزدیک کید چو شیری که ارغنده گردد به صید", "lines": ["s476-l15", "s476-l16"], "segs": ["s476-g15", "s476-g16"]}, "s476-s9": {"text": "ز اسکندر راد پیروزگر خداوند شمشیر و تاج و کمر", "lines": ["s476-l17", "s476-l18"], "segs": ["s476-g17", "s476-g18"]}, "s476-s10": {"text": "سر نامه بود آفرین از نخست بدانکس که دل را به دانش بشست", "lines": ["s476-l19", "s476-l20"], "segs": ["s476-g19", "s476-g20"]}, "s476-s11": {"text": "ز کار آن گزیند که بی‌رنج‌تر چو خواهد که بردارد از گنج بر", "lines": ["s476-l21", "s476-l22"], "segs": ["s476-g21", "s476-g22"]}, "s476-s12": {"text": "گراینده باشد به یزدان پاک بدو دارد امید و زو ترس و باک", "lines": ["s476-l23", "s476-l24"], "segs": ["s476-g23", "s476-g24"]}, "s476-s13": {"text": "بداند که ما تخت را مایه‌ایم جهاندار پیروز را سایه‌ایم", "lines": ["s476-l25", "s476-l26"], "segs": ["s476-g25", "s476-g26"]}, "s476-s14": {"text": "نوشتم یکی نامه نزدیک تو که روشن کند جان تاریک تو", "lines": ["s476-l27", "s476-l28"], "segs": ["s476-g27", "s476-g28"]}, "s476-s15": {"text": "هم‌آنگه که بر تو بخواند دبیر منه پیش و این را سگالش مگیر", "lines": ["s476-l29", "s476-l30"], "segs": ["s476-g29", "s476-g30"]}, "s476-s16": {"text": "اگر شب رسد روشنی را مپای هم‌اندر زمان سوی فرمان گرای", "lines": ["s476-l31", "s476-l32"], "segs": ["s476-g31", "s476-g32"]}, "s476-s17": {"text": "وگر بگذری زین سخن نگذرم سر و تاج و تختت به پی بسپرم", "lines": ["s476-l33", "s476-l34"], "segs": ["s476-g33", "s476-g34"]}}, "segments": {"s476-g1": {"text": "سکندر چو کرد اندر ایران نگاه", "sid": "s476-s1", "lines": ["s476-l1"]}, "s476-g2": {"text": "بدانست کو را شد آن تاج و گاه", "sid": "s476-s1", "lines": ["s476-l2"]}, "s476-g3": {"text": "همی راه و بی‌راه لشکر کشید", "sid": "s476-s2", "lines": ["s476-l3"]}, "s476-g4": {"text": "سوی کید هندی سپه برکشید", "sid": "s476-s2", "lines": ["s476-l4"]}, "s476-g5": {"text": "به جایی که آمد سکندر فراز", "sid": "s476-s3", "lines": ["s476-l5"]}, "s476-g6": {"text": "در شارستانها گشادند باز", "sid": "s476-s3", "lines": ["s476-l6"]}, "s476-g7": {"text": "ازان مرز کس را به مردم نداشت", "sid": "s476-s4", "lines": ["s476-l7"]}, "s476-g8": {"text": "ز ناهید مغفر همی برگذاشت", "sid": "s476-s4", "lines": ["s476-l8"]}, "s476-g9": {"text": "چو آمد بران شارستان بزرگ", "sid": "s476-s5", "lines": ["s476-l9"]}, "s476-g10": {"text": "که میلاد خواندیش کید سترگ", "sid": "s476-s5", "lines": ["s476-l10"]}, "s476-g11": {"text": "بران مرز لشکر فرود آورید", "sid": "s476-s6", "lines": ["s476-l11"]}, "s476-g12": {"text": "همه بوم ایشان سپه گسترید", "sid": "s476-s6", "lines