"]}, "s457-s2": {"text": "برفتند و سالار ایشان شعیب یکی نامدار از نژاد قتیب", "lines": ["s457-l3", "s457-l4"], "segs": ["s457-g3", "s457-g4"]}, "s457-s3": {"text": "جهاندار ایران سپاهی ببرد بگفتند کان را نشاید شمرد", "lines": ["s457-l5", "s457-l6"], "segs": ["s457-g5", "s457-g6"]}, "s457-s4": {"text": "فراز آمدند آن دو لشکر بهم جهان شد ز پرخاشجویان دژم", "lines": ["s457-l7", "s457-l8"], "segs": ["s457-g7", "s457-g8"]}, "s457-s5": {"text": "زمین آن سپه را همی برنتافت بران بوم کس جای رفتن نیافت", "lines": ["s457-l9", "s457-l10"], "segs": ["s457-g9", "s457-g10"]}, "s457-s6": {"text": "ز باران ژوپین و باران تیر زمین شد ز خون چون یکی آبگیر", "lines": ["s457-l11", "s457-l12"], "segs": ["s457-g11", "s457-g12"]}, "s457-s7": {"text": "خروشی برآمد ز هر پهلوی تلی کشته دیدند بر هر سوی", "lines": ["s457-l13", "s457-l14"], "segs": ["s457-g13", "s457-g14"]}, "s457-s8": {"text": "سه روز و سه شب زین نشان جنگ بود تو گفتی بریشان جهان تنگ بود", "lines": ["s457-l15", "s457-l16"], "segs": ["s457-g15", "s457-g16"]}, "s457-s9": {"text": "چهارم عرب روی برگاشتند به شب دشت پیکار بگذاشتند", "lines": ["s457-l17", "s457-l18"], "segs": ["s457-g17", "s457-g18"]}, "s457-s10": {"text": "شعیب اندران رزمگه کشته شد عرب را همه روز برگشته شد", "lines": ["s457-l19", "s457-l20"], "segs": ["s457-g19", "s457-g20"]}, "s457-s11": {"text": "بسی اسپ تازی به زین خدنگ هم از نیزه و تیغ و خفتان جنگ", "lines": ["s457-l21", "s457-l22"], "segs": ["s457-g21", "s457-g22"]}, "s457-s12": {"text": "ازان رفتگان ماند آنجا به جای به نزد جهاندار پور همای", "lines": ["s457-l23", "s457-l24"], "segs": ["s457-g23", "s457-g24"]}, "s457-s13": {"text": "ببخشید چیزی که بد بر سپاه ز اسپ و ز رمح و ز تیغ و کلاه", "lines": ["s457-l25", "s457-l26"], "segs": ["s457-g25", "s457-g26"]}, "s457-s14": {"text": "ز لشکر یکی مرزبان برگزید که گفتار ایشان بداند شنید", "lines": ["s457-l27", "s457-l28"], "segs": ["s457-g27", "s457-g28"]}, "s457-s15": {"text": "فرستاد تا باژ خواهد ز دشت ازان سال و آن سال کاندر گذشت", "lines": ["s457-l29", "s457-l30"], "s