ر", "sid": "s031-s11", "lines": ["s031-l21"]}, "s031-g22": {"text": "همیدون به دریا نهادند سر", "sid": "s031-s11", "lines": ["s031-l22"]}, "s031-g23": {"text": "بر آن بادپایان با آفرین", "sid": "s031-s12", "lines": ["s031-l23"]}, "s031-g24": {"text": "به آب اندرون غرقه کردند زین", "sid": "s031-s12", "lines": ["s031-l24"]}, "s031-g25": {"text": "به خشکی رسیدند سر کینه جوی", "sid": "s031-s13", "lines": ["s031-l25"]}, "s031-g26": {"text": "به بیت‌المقدس نهادند روی", "sid": "s031-s13", "lines": ["s031-l26"]}, "s031-g27": {"text": "که بر پهلوانی زبان راندند", "sid": "s031-s14", "lines": ["s031-l27"]}, "s031-g28": {"text": "همی کنگ دژهودجش خواندند", "sid": "s031-s14", "lines": ["s031-l28"]}, "s031-g29": {"text": "به تازی کنون خانه پاک دان", "sid": "s031-s15", "lines": ["s031-l29"]}, "s031-g30": {"text": "برآورده ایوان ضحاک دان", "sid": "s031-s15", "lines": ["s031-l30"]}, "s031-g31": {"text": "چو از دشت نزدیک شهر آمدند", "sid": "s031-s16", "lines": ["s031-l31"]}, "s031-g32": {"text": "کزان شهر جوینده بهر آمدند", "sid": "s031-s16", "lines": ["s031-l32"]}, "s031-g33": {"text": "ز یک میل کرد آفریدون نگاه", "sid": "s031-s17", "lines": ["s031-l33"]}, "s031-g34": {"text": "یکی کاخ دید اندر آن شهر شاه", "sid": "s031-s17", "lines": ["s031-l34"]}, "s031-g35": {"text": "فروزنده چون مشتری بر سپهر", "sid": "s031-s18", "lines": ["s031-l35"]}, "s031-g36": {"text": "همه جای شادی و آرام و مهر", "sid": "s031-s18", "lines": ["s031-l36"]}, "s031-g37": {"text": "که ایوانش برتر ز کیوان نمود", "sid": "s031-s19", "lines": ["s031-l37"]}, "s031-g38": {"text": "که گفتی ستاره بخواهد بسود", "sid": "s031-s19", "lines": ["s031-l38"]}, "s031-g39": {"text": "بدانست کان خانه اژدهاست", "sid": "s031-s20", "lines": ["s031-l39"]}, "s031-g40": {"text": "که جای بزرگی و جای بهاست", "sid": "s031-s20", "lines": ["s031-l40"]}, "s031-g41": {"text": "به یارانش گفت آنکه بر تیره خاک", "sid": "s031-s21", "lines": ["s031-l41"]}, "s031-g42": {"text": "برآرد چنین برز جای از مغاک", "sid": "s031-s21", "lines": ["s031-l42"]},