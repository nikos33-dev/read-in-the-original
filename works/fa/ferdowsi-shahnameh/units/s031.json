, "seg": "s031-g53", "sid": "s031-s27"}, {"s": 24, "e": 29, "surface": "نماند", "lemma": "ماند#مان", "pos": "NOUN", "seg": "s031-g53", "sid": "s031-s27"}]}, "s031-l54": {"text": "فریدون جهان‌آفرین را بخواند", "sids": ["s031-s27"], "tokens": [{"s": 0, "e": 6, "surface": "فریدون", "lemma": "فریدون", "pos": "NOUN", "seg": "s031-g54", "sid": "s031-s27"}, {"s": 7, "e": 17, "surface": "جهان‌آفرین", "lemma": "جهان‌آفرین", "pos": "NOUN", "seg": "s031-g54", "sid": "s031-s27"}, {"s": 18, "e": 20, "surface": "را", "lemma": "را", "pos": "NOUN", "seg": "s031-g54", "sid": "s031-s27"}, {"s": 21, "e": 27, "surface": "بخواند", "lemma": "خواند#خوان", "pos": "NOUN", "seg": "s031-g54", "sid": "s031-s27"}]}, "s031-l55": {"text": "به اسب اندر آمد به کاخ بزرگ", "sids": ["s031-s28"], "tokens": [{"s": 0, "e": 2, "surface": "به", "lemma": "به", "pos": "NOUN", "seg": "s031-g55", "sid": "s031-s28"}, {"s": 3, "e": 6, "surface": "اسب", "lemma": "اسب", "pos": "NOUN", "seg": "s031-g55", "sid": "s031-s28"}, {"s": 7, "e": 11, "surface": "اندر", "lemma": "اندر", "pos": "NOUN", "seg": "s031-g55", "sid": "s031-s28"}, {"s": 12, "e": 15, "surface": "آمد", "lemma": "آمد#آ", "pos": "NOUN", "seg": "s031-g55", "sid": "s031-s28"}, {"s": 16, "e": 18, "surface": "به", "lemma": "به", "pos": "NOUN", "seg": "s031-g55", "sid": "s031-s28"}, {"s": 19, "e": 22, "surface": "کاخ", "lemma": "کاخ", "pos": "NOUN", "seg": "s031-g55", "sid": "s031-s28"}, {"s": 23, "e": 27, "surface": "بزرگ", "lemma": "بزرگ", "pos": "NOUN", "seg": "s031-g55", "sid": "s031-s28"}]}, "s031-l56": {"text": "جهان ناسپرده جوان سترگ", "sids": ["s031-s28"], "tokens": [{"s": 0, "e": 4, "surface": "جهان", "lemma": "جهان", "pos": "NOUN", "seg": "s031-g56", "sid": "s031-s28"}, {"s": 5, "e": 12, "surface": "ناسپرده", "lemma": "ناسپرده", "pos": "NOUN", "seg": "s031-g56", "sid": "s031-s28"}, {"s": 13, "e": 17, "surface": "جوان", "lemma": "جوان", "pos": "NOUN", "seg": "s031-g56", "sid": "s031-s28"}, {"s": 18, "e": 22, "surface": "سترگ", "lemma": "سترگ", "pos": "NOUN", "seg": "s031-g56", "sid": "s031-s28"}]}}, "sentences": {"s031-s1": {"text": "چو آمد به نزدیک اروندرود فرستاد زی رودبانان درود", "lines": ["s031-l1", "s031-l2"], "segs": ["s031-g1", "s031-g2"]}, "s031-s2": {"text": "بران رودبان گفت پیروز شاه که کشتی برافگن هم‌اکنون به راه", "lines": ["s031-l3", "s031-l4"], "segs": ["s031-g3", "s031-g4"]}, "s031-s3": {"text": "مرا با سپاهم بدان سو رسان از اینها کسی را بدین سو ممان", "lines": ["s031-l5", "s031-l6"], "segs": ["s031-g5", "s031-g6"]}, "s031-s4": {"text": "بدان تا گذر یابم از روی آب به کشتی و زورق هم اندر شتاب", "lines": ["s031-l7", "s031-l8"], "segs": ["s031-g7", "s031-g8"]}, "s031-s5": {"text": "نیاورد کشتی نگهبان رود نیامد بگفت فریدون فرود", "lines": ["s031-l9", "s031-l10"], "segs": ["s031-g9", "s031-g10"]}, "s031-s6": {"text": "چنین داد پاسخ که شاه جهان چنین گفت با من سخن در نهان", "lines": ["s031-l11", "s031-l12"], "segs": ["s031-g11", "s031-g12"]}, "s031-s7": {"text": "که مگذار یک پشه را تا نخست جوازی بیابی و مهری درست", "lines": ["s031-l13", "s031-l14"], "segs": ["s031-g13", "s031-g14"]}, "s031-s8": {"text": "فریدون چو بشنید شد خشمناک ازان ژرف دریا نیامدش باک", "lines": ["s031-l15", "s031-l16"], "segs": ["s031-g15", "s031-g16"]}, "s031-s9": {"text": "هم آنگه میان کیانی ببست بران باره تیزتک بر نشست", "lines": ["s031-l17", "s031-l18"], "segs": ["s031-g17", "s031-g18"]}, "s031-s10": {"text": "سرش تیز شد کینه و جنگ را به آب اندر افگند گلرنگ را", "lines": ["s031-l19", "s031-l20"], "segs": ["s031-g19", "s031-g20"]}, "s031-s11": {"text": "ببستند یارانش یکسر کمر همیدون به دریا نهادند سر", "lines": ["s031-l21", "s031-l22"], "segs": ["s031-g21", "s031-g22"]}, "s031-s12": {"text": "بر آن بادپایان با آفرین به آب اندرون غرقه کردند زین", "lines": ["s031-l23", "s031-l24"], "segs": ["s031-g23", "s031-g24"]}, "s031-s13": {"text": "به خشکی رسیدند سر کینه جوی به بیت‌المقدس نهادند روی", "lines": ["s031-l25", "s031-l26"], "segs": ["s031-g25", "s031-g26"]}, "s031-s14": {"text": "که بر پهلوانی زبان راندند همی کنگ دژهودجش خواندند", "lines": ["s031-l27", "s031-l28"], "segs": ["s031-g27", "s031-g28"]}, "s031-s15": {"text": "به تازی کنون خانه پاک دان برآورده ایوان ضحاک دان", "lines": ["s031-l29", "s031-l30"], "segs": ["s031-g29", "s031-g30"]}, "s031-s16": {"text": "چو از دشت نزدیک شهر آمدند کزان شهر جوینده بهر آمدند", "lines": ["s031-l31", "s031-l32"], "segs": ["s031-g31", "s031-g32"]}, "s031-s17": {"text": "ز یک میل کرد آفریدون نگاه یکی کاخ دید اندر آن شهر شاه", "lines": ["s031-l33", "s031-l34"], "segs": ["s031-g33", "s031-g34"]}, "s031-s18": {"text": "فروزنده چون مشتری بر سپهر همه جای شادی و آرام و مهر", "lines": ["s031-l35", "s031-l36"], "segs": ["s031-g35", "s031-g36"]}, "s031-s19": {"text": "که ایوانش برتر ز کیوان نمود که گفتی ستاره بخواهد بسود", "lines": ["s031-l37", "s031-l38"], "segs": ["s031-g37", "s031-g38"]}, "s031-s20": {"text": "بدانست کان خانه اژدهاست که جای بزرگی و جای بهاست", "lines": ["s031-l39", "s031-l40"], "segs": ["s031-g39", "s031-g40"]}, "s031-s21": {"text": "به یارانش گفت آنکه بر تیره خاک برآرد چنین برز جای از مغاک", "lines": ["s031-l41", "s031-l42"], "segs": ["s031-g41", "s031-g42"]}, "s031-s22": {"text": "بترسم همی زانکه با او جهان مگر راز دارد یکی در نهان", "lines": ["s031-l43", "s031-l44"], "segs": ["s031-g43", "s031-g44"]}, "s031-s23": {"text": "بباید که ما را بدین جای تنگ شتابیدن آید به‌روز درنگ", "lines": ["s031-l45", "s031-l46"], "segs": ["s031-g45", "s031-g46"]}, "s031-s24": {"text": "بگفت و به گرز گران دست برد عنان باره تیزتک را سپرد", "lines": ["s031-l47", "s031-l48"], "segs": ["s031-g47", "s031-g48"]}, "s031-s25": {"text": "تو گفتی یکی آتشستی درست که پیش نگهبان ایوان برست", "lines": ["s031-l49", "s031-l50"], "segs": ["s031-g49", "s031-g50"]}, "s031-s26": {"text": "گران گرز برداشت از پیش زین تو گفتی همی بر نوردد زمین", "lines": ["s031-l51", "s031-l52"], "segs": ["s031-g51", "s031-g52"]}, "s031-s27": {"text": "کس از روزبانان به در بر نماند فریدون جهان‌آفرین را بخواند", "lines": ["s031-l53", "s031-l54"], "segs": ["s031-g53", "s031-g54"]}, "s031-s28": {"text": "